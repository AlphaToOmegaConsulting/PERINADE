---
import type { VisitPageData } from "../../types/visits";
import { Image } from "astro:assets";
import Icon from "../ui/Icon.astro";
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
  hero: VisitPageData["hero"];
}

const { hero } = Astro.props;
---

<section class="visit-hero" id="visit-hero">
  <div class="shell visit-hero__inner">
    <div class="visit-hero__content">
      <p class="visit-hero__eyebrow">{hero.eyebrow}</p>
      <h1>
        {hero.titleLines[0]}
        <span>{hero.titleLines[1]}</span>
      </h1>
      <p class="visit-hero__body">{hero.body}</p>

      <ul class="visit-hero__badges">
        {hero.badges.map((badge) => (
          <li>
            <span class="visit-hero__badge-icon"><Icon name={badge.icon} /></span>
            <span>{badge.label}</span>
          </li>
        ))}
      </ul>

      <div class="visit-hero__actions">
        <ButtonLink href={hero.primaryCta.href} label={hero.primaryCta.label} variant="primary" size="lg" />
        <ButtonLink href={hero.secondaryCta.href} label={hero.secondaryCta.label} variant="ghost" size="lg" />
      </div>

      <p class="visit-hero__helper">{hero.helper}</p>
    </div>

    <figure class="visit-hero__media">
      <Image src={hero.image} alt={hero.imageAlt} loading="eager" />
    </figure>
  </div>
</section>

<style>
  .visit-hero {
    background: #1a1a1a;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    padding: calc(var(--header-height) + clamp(1rem, 4vw, 2rem)) 0 clamp(2rem, 7vw, 4rem);
  }

  .visit-hero__inner {
    align-items: center;
    display: grid;
    gap: clamp(1.8rem, 5vw, 3.75rem);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .visit-hero__eyebrow {
    color: var(--visit-accent-primary);
    font-size: var(--visit-type-eyebrow-size);
    font-weight: var(--visit-type-eyebrow-weight);
    letter-spacing: var(--visit-type-eyebrow-track);
    line-height: var(--visit-type-eyebrow-lh);
    margin: 0;
    text-transform: uppercase;
  }

  .visit-hero__content h1 {
    color: var(--color-white);
    font-size: var(--visit-type-display-size);
    font-weight: var(--visit-type-display-weight);
    letter-spacing: var(--visit-type-display-track);
    line-height: var(--visit-type-display-lh);
    margin: clamp(0.7rem, 2vw, 1.15rem) 0 0;
  }

  .visit-hero__content h1 span {
    color: var(--visit-accent-on-dark);
    display: block;
  }

  .visit-hero__body {
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--visit-type-body-size);
    line-height: var(--visit-type-body-lh);
    margin: clamp(1rem, 2.7vw, 1.55rem) 0 0;
    max-inline-size: clamp(20rem, 46vw, 34rem);
  }

  .visit-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    margin: clamp(1rem, 2.8vw, 1.6rem) 0 0;
    padding: 0;
  }

  .visit-hero__badges li {
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 100vmax;
    color: rgba(255, 255, 255, 0.84);
    display: inline-flex;
    font-size: var(--visit-type-caption-size);
    gap: clamp(0.4rem, 1.2vw, 0.55rem);
    min-block-size: var(--control-height-sm);
    padding: clamp(0.2rem, 0.9vw, 0.4rem) clamp(0.75rem, 2.6vw, 1.05rem);
  }

  .visit-hero__badge-icon {
    color: var(--visit-accent-on-dark);
    display: inline-flex;
    block-size: var(--icon-size-sm);
    inline-size: var(--icon-size-sm);
  }

  .visit-hero__badge-icon :global(svg) {
    height: 100%;
    width: 100%;
  }

  .visit-hero__actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: clamp(1rem, 3vw, 1.75rem);
  }

  .visit-hero__actions :global(.btn) {
    min-inline-size: clamp(10rem, 22vw, 12.5rem);
  }

  .visit-hero__actions :global(.btn--primary) {
    --btn-primary-bg: var(--visit-accent-primary);
    --btn-primary-bg-hover: color-mix(in srgb, var(--visit-accent-primary) 82%, black);
    --btn-primary-border: var(--visit-accent-primary);
    --btn-primary-shadow: none;
  }

  .visit-hero__actions :global(.btn--ghost) {
    --btn-ghost-bg-hover: rgba(255, 255, 255, 0.12);
    --btn-ghost-border: rgba(255, 255, 255, 0.22);
    --btn-ghost-color: var(--color-white);
  }

  .visit-hero__helper {
    color: rgba(255, 255, 255, 0.38);
    font-size: clamp(0.82rem, 2vw, 0.92rem);
    margin: var(--space-sm) 0 0;
  }

  .visit-hero__media {
    border-radius: var(--visit-radius-xl);
    box-shadow: 0 1.875rem 4.5rem rgba(0, 0, 0, 0.35);
    margin: 0;
    overflow: hidden;
  }

  .visit-hero__media img {
    aspect-ratio: 577 / 868;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  @media (max-width: 63.9375em) {
    .visit-hero {
      padding-top: calc(var(--header-height) + clamp(0.9rem, 3vw, 1.5rem));
    }

    .visit-hero__inner {
      grid-template-columns: 1fr;
    }

    .visit-hero__media {
      max-inline-size: clamp(24rem, 80vw, 38rem);
      width: 100%;
    }
  }

  @media (max-width: 47.9375em) {
    .visit-hero__actions {
      flex-direction: column;
    }

    .visit-hero__actions :global(.btn) {
      width: 100%;
    }

    .visit-hero__badges li {
      font-size: clamp(0.78rem, 3.2vw, 0.9rem);
      min-block-size: clamp(2.5rem, 8vw, 2.7rem);
    }
  }
</style>

---
import type { VisitPageData } from "../../types/visits";
import SectionHeading from "../ui/SectionHeading.astro";
import InfoCard from "../ui/surfaces/InfoCard.astro";

interface Props {
  access: VisitPageData["access"];
}

const { access } = Astro.props;
---

<section class="access section section--white" id="access">
  <div class="shell shell--narrow">
    <SectionHeading eyebrow={access.eyebrow} title={access.title} body={access.body} centered />

    <div class="access__grid" data-reveal-group data-reveal-stagger="90">
      <div data-reveal="up">
        <InfoCard
          class="access__card access__card--main"
          title={access.leftCard.title}
          subtitle={access.leftCard.subtitle}
          tag={access.leftCard.tag}
          lines={access.leftCard.content}
          ctaLabel={access.leftCard.ctaLabel}
          ctaHref={access.leftCard.ctaHref}
        />
      </div>

      <div class="access__stack" data-reveal-group data-reveal-stagger="70">
        {access.rightCards.map((card) => (
          <div data-reveal="up">
            <InfoCard
              class="access__card"
              title={card.title}
              subtitle={card.subtitle}
              tag={card.tag}
              icon={card.icon}
              lines={card.content}
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .access__grid {
    display: grid;
    align-items: start;
    gap: clamp(1rem, 2vw, 1.6rem);
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    margin-top: clamp(2.1rem, 4vw, 3rem);
  }

  .access__stack {
    display: grid;
    gap: clamp(0.85rem, 1.6vw, 1.1rem);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .access__stack > div:last-child {
    grid-column: 1 / -1;
  }

  .access__card {
    background: #fcfaf6;
    border-color: var(--visit-stroke-subtle);
  }

  .access__card--main {
    display: grid;
    min-height: 100%;
  }

  .access__card :global(.ui-card__tag) {
    color: var(--visit-accent-primary);
    font-size: var(--visit-type-caption-size);
    letter-spacing: var(--visit-type-caption-track);
    text-transform: uppercase;
  }

  .access__card :global(.ui-card__title) {
    font-size: 1.2rem;
    margin-top: 0.15rem;
  }

  .access__card :global(.ui-card__meta) {
    color: var(--color-muted);
    font-size: var(--visit-type-caption-size);
    letter-spacing: 0.03em;
    margin-top: 0.15rem;
  }

  .access__card :global(.ui-card__content) {
    gap: 0.95rem;
    padding: clamp(1.2rem, 2.5vw, 1.6rem);
  }

  .access__card :global(.ui-info-card__list li) {
    font-size: var(--visit-type-body-size);
    line-height: var(--visit-type-body-lh);
    margin: 0.22rem 0;
  }

  .access__card--main :global(.ui-info-card__cta) {
    --action-text-color: var(--visit-accent-primary);
    --action-text-color-hover: var(--visit-accent-primary);
    --action-text-underline: var(--visit-accent-primary);

    justify-self: start;
    margin-top: 0.8rem;
    width: fit-content;
  }

  @media (max-width: 900px) {
    .access__grid {
      grid-template-columns: 1fr;
    }

    .access__stack {
      grid-template-columns: 1fr;
    }
  }
</style>

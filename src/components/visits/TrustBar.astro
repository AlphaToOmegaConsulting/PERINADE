---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<section class="trust-bar" aria-label="proof points">
  <div class="shell trust-bar__inner">
    {items.map((item) => (
      <p>{item}</p>
    ))}
  </div>
</section>

<style>
  .trust-bar {
    background: color-mix(in srgb, var(--visit-accent-soft) 38%, #fff);
    border-bottom: 1px solid var(--visit-stroke-subtle);
    border-top: 1px solid var(--visit-stroke-subtle);
    padding: 0.78rem 0;
  }

  .trust-bar__inner {
    align-items: center;
    display: flex;
    gap: 1.25rem;
    justify-content: center;
  }

  .trust-bar p {
    color: #5c5b58;
    font-size: var(--visit-type-caption-size);
    font-weight: var(--visit-type-caption-weight);
    letter-spacing: var(--visit-type-caption-track);
    line-height: var(--visit-type-caption-lh);
    margin: 0;
    text-align: center;
    text-transform: uppercase;
  }

  .trust-bar p + p {
    border-left: 1px solid var(--visit-stroke-subtle);
    padding-left: 1.25rem;
  }

  @media (max-width: 900px) {
    .trust-bar__inner {
      flex-direction: column;
      gap: 0.45rem;
    }

    .trust-bar p + p {
      border-left: 0;
      padding-left: 0;
    }
  }
</style>

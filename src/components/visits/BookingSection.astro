---
import type { VisitPageData } from "../../types/visits";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  booking: VisitPageData["booking"];
}

const { booking } = Astro.props;
---

<section class="booking section section--soft" id="booking">
  <div class="shell">
    <SectionHeading eyebrow={booking.eyebrow} title={booking.title} body={booking.body} centered />

    <div
      class="booking__panel"
      data-booking
      data-config={JSON.stringify(booking.config)}
      style={`--booking-calendar-ratio:${booking.layout.calendarWidthRatio}; --booking-controls-ratio:${booking.layout.controlsWidthRatio}; --booking-panel-max:${booking.layout.panelMaxWidth}; --booking-calendar-cell-height:${booking.layout.calendarCellHeight}; --booking-control-row-height:${booking.layout.controlRowHeight};`}
    >
      <div class="booking__calendar">
        <header>
            <button type="button" data-calendar-prev aria-label="Mois précédent">‹</button>
            <h3 data-calendar-month>{booking.config.monthLabel}</h3>
            <button type="button" data-calendar-next aria-label="Mois suivant">›</button>
          </header>

        <div class="booking__days-row">
          {booking.config.dayLabels.map((day) => (
            <span>{day}</span>
          ))}
        </div>

          <div class="booking__grid" data-calendar-days>
            {booking.config.selectableDays.map((day) => (
              <button type="button" data-day={day} class:list={[day === booking.config.defaultDay && "is-active"]}>{day}</button>
            ))}
          </div>
      </div>

      <div class="booking__controls">
        <form
          class="booking__form"
          data-ui-form
          data-booking-form
          data-submit-endpoint={booking.config.submitEndpoint ?? ""}
          data-submit-success={booking.config.successMessage ?? ""}
          data-submit-error={booking.config.errorMessage ?? ""}
        >
        <section>
          <h4>Créneau</h4>
          <div class="booking__slot-grid" data-slot-grid>
            {booking.config.slots.map((slot) => (
              <button
                type="button"
                data-slot={slot.id}
                aria-pressed={slot.id === booking.config.defaultSlotId ? "true" : "false"}
                class:list={[slot.id === booking.config.defaultSlotId && "is-active"]}
              >
                {slot.label}
              </button>
            ))}
          </div>
        </section>

        <section>
          <h4>Participants</h4>
          <div class="booking__counter">
            <button type="button" data-count-dec aria-label="Diminuer">−</button>
            <output data-count-value>{booking.config.defaultParticipants}</output>
            <button type="button" data-count-inc aria-label="Augmenter">+</button>
          </div>
        </section>

        <label class="booking__addon">
          <input type="checkbox" data-addon />
          <span>{booking.config.addonLabel}</span>
        </label>

        <p class="booking__price">
          <span>From</span>
          <strong><span data-price-value>{booking.config.basePricePerPerson}</span>€ <small>/ person</small></strong>
        </p>

        <input type="hidden" name="day" data-booking-field-day />
        <input type="hidden" name="slotId" data-booking-field-slot />
        <input type="hidden" name="participants" data-booking-field-participants />
        <input type="hidden" name="addon" data-booking-field-addon />
        <input type="hidden" name="totalPerPerson" data-booking-field-total />

        <button class="booking__cta" type="submit">{booking.config.ctaLabel}</button>
        <a class="booking__call" href="tel:+33468000000">{booking.config.callLabel}</a>
        <p class="booking__status" data-booking-status aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .booking__panel {
    background: #fff;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: var(--visit-radius-xl);
    box-shadow: 0 1.25rem 2.625rem rgba(0, 0, 0, 0.08);
    display: grid;
    grid-template-columns: minmax(0, var(--booking-calendar-ratio)) minmax(0, var(--booking-controls-ratio));
    margin-top: clamp(1.2rem, 3.5vw, 2.3rem);
    max-width: var(--booking-panel-max);
    margin-inline: auto;
    overflow: hidden;
  }

  .booking__calendar {
    padding: clamp(1rem, 3vw, 2rem);
  }

  .booking__calendar header {
    align-items: center;
    display: grid;
    grid-template-columns: auto 1fr auto;
    margin-bottom: clamp(0.7rem, 2vw, 1.1rem);
  }

  .booking__calendar header h3 {
    font-size: clamp(1.6rem, 2.1vw, 1.85rem);
    margin: 0;
    text-align: center;
  }

  .booking__calendar header button {
    background: transparent;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: 100vmax;
    cursor: pointer;
    font-size: clamp(1.15rem, 4vw, 1.5rem);
    block-size: var(--control-height-sm);
    inline-size: var(--control-height-sm);
  }

  .booking__calendar header button:hover:not(:disabled),
  .booking__calendar header button:focus-visible:not(:disabled) {
    border-color: var(--visit-accent-primary);
    color: var(--visit-accent-primary);
  }

  .booking__calendar header button:active:not(:disabled) {
    transform: scale(0.97);
  }

  .booking__calendar header button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  .booking__days-row {
    display: grid;
    gap: var(--space-2xs);
    grid-template-columns: repeat(7, minmax(0, 1fr));
    margin-bottom: var(--space-2xs);
  }

  .booking__days-row span {
    color: var(--color-muted);
    font-size: var(--visit-type-caption-size);
    letter-spacing: var(--visit-type-caption-track);
    text-align: center;
    text-transform: uppercase;
  }

  .booking__grid {
    display: grid;
    gap: var(--space-2xs);
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }

  .booking__day-pad {
    min-block-size: var(--booking-calendar-cell-height);
  }

  .booking__grid button {
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--visit-radius-sm);
    color: #b7b7b7;
    cursor: pointer;
    font-size: clamp(0.84rem, 2.5vw, 0.95rem);
    min-block-size: var(--booking-calendar-cell-height);
  }

  .booking__grid button:hover:not(:disabled),
  .booking__grid button:focus-visible:not(:disabled) {
    border-color: var(--visit-accent-primary);
    color: var(--visit-accent-primary);
  }

  .booking__grid button:active:not(:disabled) {
    transform: scale(0.97);
  }

  .booking__grid button.is-active {
    border: 1px solid var(--visit-accent-primary);
    color: var(--visit-accent-primary);
    font-weight: 600;
  }

  .booking__grid button.is-disabled,
  .booking__grid button:disabled {
    color: #b7b7b7;
    cursor: not-allowed;
    opacity: 0.48;
  }

  .booking__controls {
    border-left: 1px solid var(--visit-stroke-subtle);
    padding: clamp(1rem, 3vw, 1.35rem);
  }

  .booking__form {
    display: grid;
    gap: var(--space-sm);
  }

  .booking__controls h4 {
    font-size: var(--visit-type-caption-size);
    letter-spacing: var(--visit-type-caption-track);
    margin: 0 0 clamp(0.35rem, 1.2vw, 0.55rem);
    text-transform: uppercase;
  }

  .booking__slot-grid {
    display: grid;
    gap: var(--space-xs);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .booking__slot-grid button {
    background: #fff;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: var(--visit-radius-sm);
    cursor: pointer;
    font-size: clamp(0.92rem, 2.6vw, 1rem);
    min-block-size: var(--booking-control-row-height);
  }

  .booking__slot-grid button:hover,
  .booking__slot-grid button:focus-visible {
    border-color: var(--visit-accent-primary);
    color: var(--visit-accent-primary);
  }

  .booking__slot-grid button:active {
    transform: scale(0.98);
  }

  .booking__slot-grid button.is-active {
    border-color: var(--visit-accent-primary);
    color: var(--visit-accent-primary);
    font-weight: 600;
  }

  .booking__counter {
    display: grid;
    gap: var(--space-xs);
    grid-template-columns: 1fr auto 1fr;
  }

  .booking__counter button {
    background: #fff;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: var(--visit-radius-sm);
    cursor: pointer;
    font-size: clamp(1.2rem, 4.5vw, 1.6rem);
    min-block-size: var(--booking-control-row-height);
  }

  .booking__counter button:hover,
  .booking__counter button:focus-visible {
    border-color: var(--visit-accent-primary);
    color: var(--visit-accent-primary);
  }

  .booking__counter button:active {
    transform: scale(0.98);
  }

  .booking__counter output {
    align-items: center;
    display: inline-flex;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2rem);
    justify-content: center;
    min-inline-size: clamp(2rem, 8vw, 3rem);
  }

  .booking__addon {
    align-items: center;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: var(--visit-radius-md);
    cursor: pointer;
    display: flex;
    gap: var(--space-xs);
    min-block-size: calc(var(--booking-control-row-height) + clamp(0.15rem, 0.8vw, 0.4rem));
    padding-inline: clamp(0.7rem, 2.4vw, 1rem);
  }

  .booking__addon input {
    accent-color: var(--visit-accent-primary);
    block-size: clamp(0.95rem, 3vw, 1.15rem);
    inline-size: clamp(0.95rem, 3vw, 1.15rem);
  }

  .booking__addon:hover,
  .booking__addon:focus-within {
    border-color: var(--visit-accent-primary);
  }

  .booking__price {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin: 0;
  }

  .booking__price > span {
    color: var(--color-muted);
  }

  .booking__price strong {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.7vw, 2rem);
    line-height: 1;
  }

  .booking__price small {
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 2.3vw, 0.95rem);
    font-weight: 400;
  }

  .booking__cta {
    align-items: center;
    background: var(--visit-accent-primary);
    border: 0;
    border-radius: var(--visit-radius-xl);
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    font-size: var(--visit-type-caption-size);
    justify-content: center;
    letter-spacing: var(--visit-type-caption-track);
    min-block-size: calc(var(--booking-control-row-height) + clamp(0.2rem, 1vw, 0.6rem));
    text-transform: uppercase;
  }

  .booking__cta:hover,
  .booking__cta:focus-visible {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .booking__cta:active {
    transform: translateY(0);
  }

  .booking__call {
    color: #6b6b6b;
    font-size: var(--visit-type-caption-size);
    letter-spacing: var(--visit-type-caption-track);
    text-align: center;
    text-transform: uppercase;
  }

  .booking__call:hover,
  .booking__call:focus-visible {
    color: var(--visit-accent-primary);
  }

  .booking__status {
    font-size: 0.9rem;
    margin: 0;
    min-block-size: 1.25rem;
  }

  .booking__status.is-success {
    color: #1f5b31;
  }

  .booking__status.is-error {
    color: #9f2517;
  }

  @media (max-width: 68.75em) {
    .booking__panel {
      grid-template-columns: 1fr;
    }

    .booking__controls {
      border-left: 0;
      border-top: 1px solid var(--visit-stroke-subtle);
    }
  }

  @media (max-width: 47.9375em) {
    .booking__calendar {
      padding: clamp(0.8rem, 3vw, 1rem);
    }

    .booking__controls {
      padding: clamp(0.8rem, 3vw, 1rem);
    }

    .booking__grid button {
      min-block-size: clamp(2.2rem, 9vw, 2.5rem);
    }

    .booking__slot-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

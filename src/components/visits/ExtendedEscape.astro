---
import type { VisitPageData } from "../../types/visits";
import { Image } from "astro:assets";
import Icon from "../ui/Icon.astro";
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
  escape: VisitPageData["escape"];
}

const { escape } = Astro.props;
---

<section
  class="escape section"
  id="escape"
  style={`--escape-bg:url('${escape.layout.backgroundImage.src}'); --escape-overlay:${escape.layout.overlayOpacity}; --escape-image-radius:${escape.layout.imagePanelRadius};`}
>
  <div class="escape__bg" aria-hidden="true"></div>
  <div class="shell escape__inner">
    <figure>
      <Image src={escape.image} alt={escape.imageAlt} loading="lazy" />
    </figure>

    <div class="escape__content">
      <p class="escape__eyebrow">{escape.eyebrow}</p>
      <h2>
        {escape.title[0]}
        <span>{escape.title[1]}</span>
      </h2>
      <p class="escape__body">{escape.body}</p>

      <ul>
        {escape.features.map((item) => (
          <li>
            <span><Icon name={item.icon} /></span>
            <span>{item.label}</span>
          </li>
        ))}
      </ul>

      <ButtonLink class="escape__cta" href={escape.cta.href} label={escape.cta.label} variant="ghost" size="lg" />
    </div>
  </div>
</section>

<style>
  .escape {
    overflow: clip;
    position: relative;
  }

  .escape__bg {
    background-image:
      linear-gradient(
        100deg,
        rgba(17, 41, 24, var(--escape-overlay)),
        rgba(19, 57, 27, calc(var(--escape-overlay) + 0.04))
      ),
      var(--escape-bg);
    background-position: center;
    background-size: cover;
    inset: 0;
    position: absolute;
  }

  .escape__inner {
    align-items: center;
    display: grid;
    gap: 3rem;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    position: relative;
  }

  .escape figure {
    border-radius: var(--escape-image-radius);
    margin: 0;
    overflow: hidden;
  }

  .escape figure img {
    aspect-ratio: 669 / 806;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .escape__eyebrow {
    color: var(--visit-accent-primary);
    font-size: var(--visit-type-eyebrow-size);
    font-weight: var(--visit-type-eyebrow-weight);
    letter-spacing: var(--visit-type-eyebrow-track);
    line-height: var(--visit-type-eyebrow-lh);
    margin: 0;
    text-transform: uppercase;
  }

  .escape__content h2 {
    color: var(--color-white);
    font-size: var(--visit-type-display-size);
    font-weight: var(--visit-type-display-weight);
    letter-spacing: var(--visit-type-display-track);
    line-height: var(--visit-type-display-lh);
    margin: 0.75rem 0 0;
  }

  .escape__content h2 span {
    color: var(--visit-accent-on-dark);
    display: block;
  }

  .escape__body {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--visit-type-body-size);
    line-height: var(--visit-type-body-lh);
    margin: 1rem 0 0;
  }

  .escape__content ul {
    display: grid;
    gap: 1rem;
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
  }

  .escape__content li {
    align-items: center;
    color: rgba(255, 255, 255, 0.84);
    display: flex;
    gap: 0.8rem;
  }

  .escape__content li span:first-child {
    align-items: center;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    color: var(--visit-accent-primary);
    display: inline-flex;
    height: 2rem;
    justify-content: center;
    width: 2rem;
  }

  .escape__content li span:first-child :global(svg) {
    height: 1rem;
    width: 1rem;
  }

  .escape :global(.escape__cta) {
    --btn-ghost-bg-hover: rgba(255, 255, 255, 0.12);
    --btn-ghost-border: rgba(255, 255, 255, 0.26);
    --btn-ghost-color: var(--color-white);

    margin-top: 1.9rem;
    min-height: 3.2rem;
    min-width: 23rem;
    padding: 0 1.4rem;
  }

  @media (max-width: 1023px) {
    .escape__inner {
      grid-template-columns: 1fr;
    }

    .escape :global(.escape__cta) {
      min-width: 0;
      width: 100%;
    }
  }
</style>

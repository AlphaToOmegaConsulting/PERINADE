---
import type { VisitPageData } from "../../types/visits";
import { Image } from "astro:assets";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  timeline: VisitPageData["timeline"];
}

const { timeline } = Astro.props;
---

<section class="timeline section section--white" id="experience">
  <div class="shell">
    <SectionHeading eyebrow={timeline.eyebrow} title={timeline.title} body={timeline.body} centered />

    <div class="timeline__stack">
      {timeline.steps.map((step, index) => (
        <article
          class:list={[
            "timeline__step",
            index % 2 === 1 && "timeline__step--reverse",
            step.layout?.align === "start" && "timeline__step--start"
          ]}
          style={[
            step.layout?.mediaMaxWidth && `--timeline-media-max:${step.layout.mediaMaxWidth}`,
            step.layout?.contentMaxWidth && `--timeline-copy-max:${step.layout.contentMaxWidth}`,
            step.layout?.mediaRatio && `--timeline-media-ratio:${step.layout.mediaRatio}`
          ]
            .filter(Boolean)
            .join(";")}
        >
          <figure>
            <Image src={step.image} alt={step.imageAlt} loading="lazy" />
          </figure>
          <div class="timeline__copy">
            <p class="timeline__number">{step.number}</p>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline__stack {
    display: grid;
    gap: 2.8rem;
    margin-top: 3.4rem;
  }

  .timeline__step {
    align-items: center;
    display: grid;
    gap: 2.1rem;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
  }

  .timeline__step--reverse figure {
    order: 2;
  }

  .timeline__step--reverse .timeline__copy {
    order: 1;
  }

  .timeline figure {
    border-radius: var(--visit-radius-lg);
    box-shadow: var(--shadow-card);
    margin: 0;
    max-width: var(--timeline-media-max, 28rem);
    overflow: hidden;
    width: 100%;
  }

  .timeline figure img {
    aspect-ratio: var(--timeline-media-ratio, 568/496);
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .timeline__copy {
    max-width: var(--timeline-copy-max, 25rem);
  }

  .timeline__step--start {
    align-items: start;
  }

  .timeline__number {
    color: var(--visit-accent-primary);
    font-family: var(--font-display);
    font-size: clamp(2.45rem, 4.2vw, 3.35rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0;
  }

  .timeline__copy h3 {
    font-size: clamp(1.65rem, 2.1vw, 2rem);
    margin: 0.35rem 0 0;
  }

  .timeline__copy p:last-child {
    color: var(--color-muted);
    font-size: var(--visit-type-body-size);
    line-height: var(--visit-type-body-lh);
    margin: 0.65rem 0 0;
    max-width: 32rem;
  }

  @media (max-width: 1023px) {
    .timeline__step,
    .timeline__step--reverse {
      gap: 1.2rem;
      grid-template-columns: 1fr;
    }

    .timeline__step--reverse figure,
    .timeline__step--reverse .timeline__copy {
      order: initial;
    }

    .timeline__stack {
      gap: 2.6rem;
    }

    .timeline figure,
    .timeline__copy {
      max-width: none;
    }
  }
</style>

---
interface Props {
  cartLabel?: string;
  cartHref?: string;
  closeAriaLabel?: string;
  countTemplate?: string;
}

const {
  cartLabel = "",
  cartHref = "/panier",
  closeAriaLabel = "",
  countTemplate = "",
} = Astro.props;
---

<div class="cart-popup" data-cart-popup hidden data-cart-count-template={countTemplate}>
  <button class="cart-popup__close" type="button" data-cart-popup-close aria-label={closeAriaLabel}>×</button>
  <div class="cart-popup__content">
    <span class="cart-popup__icon" aria-hidden="true">🛒</span>
    <p class="cart-popup__label" data-cart-popup-label>{countTemplate.replace("{count}", "0")}</p>
    <a class="cart-popup__cta" href={cartHref}>{cartLabel}</a>
  </div>
</div>

<script>
  import { cartCount } from "../../lib/cart/cart";

  let dismissed = false;
  let dismissedCount = 0;

  const updatePopup = ({ fromEvent = false }: { fromEvent?: boolean } = {}) => {
    const popup = document.querySelector<HTMLElement>("[data-cart-popup]");
    const label = document.querySelector<HTMLElement>("[data-cart-popup-label]");
    if (!popup || !label) return;

    const count = cartCount();
    const template = popup.dataset.cartCountTemplate ?? "Cart: {count} item(s)";
    label.textContent = template.replace("{count}", String(count));

    if (count <= 0) {
      popup.hidden = true;
      dismissed = false;
      dismissedCount = 0;
      return;
    }

    if (dismissed) {
      if (count > dismissedCount) {
        dismissed = false;
        dismissedCount = 0;
        popup.hidden = false;
      } else {
        popup.hidden = true;
      }
      return;
    }

    if (fromEvent || count > 0) {
      popup.hidden = false;
    }
  };

  const initCartPopup = () => {
    const popup = document.querySelector<HTMLElement>("[data-cart-popup]");
    const closeButton = document.querySelector<HTMLButtonElement>("[data-cart-popup-close]");
    if (!popup || !closeButton) return;

    if (popup.dataset.bound !== "true") {
      popup.dataset.bound = "true";

      closeButton.addEventListener("click", () => {
        dismissed = true;
        dismissedCount = cartCount();
        popup.hidden = true;
      });

      window.addEventListener("cart:changed", () => updatePopup({ fromEvent: true }));
    }

    updatePopup();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCartPopup, { once: true });
  } else {
    initCartPopup();
  }

  document.addEventListener("astro:after-swap", initCartPopup);
</script>

<style>
  .cart-popup {
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid rgba(44, 44, 44, 0.12);
    border-radius: 0.9rem;
    bottom: clamp(0.9rem, 2.5vw, 1.4rem);
    box-shadow: 0 14px 30px rgba(16, 24, 40, 0.14);
    padding: 0.72rem 0.85rem;
    position: fixed;
    right: clamp(0.9rem, 2.5vw, 1.4rem);
    z-index: 40;
  }

  .cart-popup__content {
    align-items: center;
    display: flex;
    gap: 0.58rem;
    padding-right: 1rem;
  }

  .cart-popup__icon {
    font-size: 1.02rem;
    line-height: 1;
  }

  .cart-popup__label {
    color: #2c2c2c;
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    white-space: nowrap;
  }

  .cart-popup__close {
    background: transparent;
    border: 0;
    color: #80858f;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0;
    position: absolute;
    right: 0.5rem;
    top: 0.22rem;
  }

  .cart-popup__close:hover,
  .cart-popup__close:focus-visible {
    color: #2c2c2c;
  }

  .cart-popup__cta {
    align-items: center;
    background: #101828;
    border-radius: 0.5rem;
    color: #fff;
    display: inline-flex;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    min-height: 1.9rem;
    padding: 0.35rem 0.55rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: filter 120ms ease, transform 120ms ease;
  }

  .cart-popup__cta:hover,
  .cart-popup__cta:focus-visible {
    filter: brightness(1.07);
    transform: translateY(-1px);
  }

  @media (max-width: 47.9375em) {
    .cart-popup {
      padding: 0.62rem 0.68rem;
      right: 0.7rem;
    }

    .cart-popup__label {
      font-size: 0.84rem;
    }
  }
</style>

---
import type { ShopPageData } from "../../types/shop";
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
  finalCta: ShopPageData["finalCta"];
}

const { finalCta } = Astro.props;
---

<section class="shop-band" aria-label={finalCta.sectionAriaLabel}>
  <div class="shell shop-shell shop-band__shell" data-reveal-group data-reveal-stagger="90">
    <div data-reveal="left">
      <h2>{finalCta.title}</h2>
      <p>{finalCta.body}</p>
    </div>

    <ButtonLink class="shop-band__cta" href={finalCta.ctaHref} label={finalCta.ctaLabel} variant="secondary" size="lg" data-reveal="right" />
  </div>
</section>

<style>
  .shop-band {
    background: #283a2c;
    padding: 3.25rem 0;
  }

  .shop-band__shell {
    align-items: center;
    display: flex;
    gap: 1.4rem;
    justify-content: space-between;
  }

  .shop-band h2 {
    color: var(--color-white);
    font-size: clamp(1.9rem, 3.1vw, 2.9rem);
    margin: 0;
  }

  .shop-band p {
    color: rgba(255, 255, 255, 0.8);
    margin: 0.6rem 0 0;
    max-width: 38rem;
  }

  :global(.shop-band__cta) {
    --action-secondary-bg: var(--color-white);
    --action-secondary-bg-hover: #f3ede4;
    --action-secondary-border: var(--color-white);
    --action-secondary-color: var(--color-cta);

    flex-shrink: 0;
    min-height: 4rem;
    padding-inline: 2.1rem;
  }

  @media (max-width: 1023px) {
    .shop-band__shell {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 767px) {
    .shop-band {
      padding: 2.25rem 0;
    }

    :global(.shop-band__cta) {
      justify-content: center;
      width: 100%;
    }
  }
</style>

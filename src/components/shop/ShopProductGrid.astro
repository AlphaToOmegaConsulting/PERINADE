---
import type { ShopPageData } from "../../types/shop";
import ProductCard from "../ui/surfaces/ProductCard.astro";

interface Props {
  productGrid: ShopPageData["productGrid"];
}

const { productGrid } = Astro.props;
---

<section id="produits" class="shop-grid section section--soft" aria-labelledby="shop-grid-title">
  <div class="shell">
    <header class="shop-grid__heading" data-reveal="up">
      <p>{productGrid.eyebrow}</p>
      <h2 id="shop-grid-title">{productGrid.title}</h2>
    </header>

    <div class="shop-grid__list" data-reveal-group data-reveal-stagger="60">
      {productGrid.products.map((product) => (
        <div class="shop-grid__item" data-reveal="up">
          <ProductCard product={product} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .shop-grid {
    background: #f5f5f5;
    border-bottom: 1px solid rgba(44, 44, 44, 0.08);
  }

  .shop-grid__heading {
    margin: 0 auto clamp(1.8rem, 4vw, 2.6rem);
    max-inline-size: 44rem;
    text-align: center;
  }

  .shop-grid__heading p {
    color: #c49c6e;
    font-size: 0.82rem;
    letter-spacing: 0.2em;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-grid__heading h2 {
    color: #2c2c2c;
    font-size: clamp(2rem, 4vw, 3.2rem);
    margin: 0.55rem 0 0;
  }

  .shop-grid__list {
    display: grid;
    gap: 1.15rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .shop-grid__item {
    display: flex;
    min-width: 0;
  }

  .shop-grid__item > * {
    width: 100%;
  }

  @media (max-width: 74.9375em) {
    .shop-grid__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 61.9375em) {
    .shop-grid__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 47.9375em) {
    .shop-grid__heading {
      margin-bottom: 1.35rem;
    }

    .shop-grid__list {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { Image } from "astro:assets";
import shopImage2 from "../../assets/perinade/shop/img-2.png";
import shopImage3 from "../../assets/perinade/shop/img-3.png";
import shopImage4 from "../../assets/perinade/shop/img-4.png";
import shopImage5 from "../../assets/perinade/shop/img-5.png";
import type { ImageMetadata } from "astro";

interface ProductCard {
  name: string;
  meta: string;
  description: string;
  price: string;
  stock: string;
  image: ImageMetadata;
  imageAlt: string;
  badges: string[];
  tone: string;
  ctaHref: string;
}

const products: ProductCard[] = [
  {
    name: "Cuvée du Domaine",
    meta: "AOP Minervois · 2022 · 75 cl",
    description: "Fruits noirs, garrigue, épices douces. Bouche soyeuse, belle longueur.",
    price: "12,50 € TTC",
    stock: "En stock",
    image: shopImage2,
    imageAlt: "Bouteille rouge en close-up",
    badges: ["Best Seller", "Rouge"],
    tone: "Rouge",
    ctaHref: "/boutique#produits"
  },
  {
    name: "Blanc de Périnade",
    meta: "IGP Pays d'Oc · 2023 · 75 cl",
    description: "Agrumes, fleurs blanches. Fraîcheur remarquable, finale minérale.",
    price: "10,00 € TTC",
    stock: "En stock",
    image: shopImage3,
    imageAlt: "Bouteille de blanc sur fond clair",
    badges: ["Best Seller", "Blanc"],
    tone: "Blanc",
    ctaHref: "/boutique#produits"
  },
  {
    name: "Grande Réserve",
    meta: "AOP Minervois · 2020 · 75 cl",
    description: "Élevé en fûts de chêne. Puissant, complexe, tanins fondus.",
    price: "22,00 € TTC",
    stock: "En stock",
    image: shopImage4,
    imageAlt: "Étagères de vins",
    badges: ["Best Seller", "Rouge"],
    tone: "Rouge",
    ctaHref: "/boutique#produits"
  },
  {
    name: "Rosé d'Été",
    meta: "IGP Pays d'Oc · 2024 · 75 cl",
    description: "Pêche, fraise. Bouche vive et gourmande, idéale pour l'apéritif.",
    price: "9,50 € TTC",
    stock: "En stock",
    image: shopImage5,
    imageAlt: "Scène rosé et panier",
    badges: ["Favori Visite", "Rosé"],
    tone: "Rosé",
    ctaHref: "/boutique#produits"
  },
  {
    name: "Blanc Réserve",
    meta: "AOP Minervois · 2022 · 75 cl",
    description: "Fruits exotiques, vanille subtile. Bouche ample et élégante.",
    price: "16,00 € TTC",
    stock: "En stock",
    image: shopImage3,
    imageAlt: "Bouteille blanc réserve",
    badges: ["Blanc"],
    tone: "Blanc",
    ctaHref: "/boutique#produits"
  },
  {
    name: "Rosé Prestige",
    meta: "IGP Pays d'Oc · 2024 · 75 cl",
    description: "Rose, fruits printaniers. Finale fraîche, structurée et vive.",
    price: "13,00 € TTC",
    stock: "En stock",
    image: shopImage5,
    imageAlt: "Rosé prestige",
    badges: ["Rosé"],
    tone: "Rosé",
    ctaHref: "/boutique#produits"
  }
];

---

<section id="produits" class="shop-grid section section--soft" aria-labelledby="shop-grid-title">
  <div class="shell shop-shell">
    <header class="shop-grid__heading">
      <p>Votre parcours</p>
      <h2 id="shop-grid-title">L'expérience pas à pas</h2>
    </header>

    <div class="shop-grid__cards">
      {products.map((product) => (
        <article class="shop-card">
          <div class="shop-card__image-wrap">
            <Image src={product.image} alt={product.imageAlt} loading="lazy" />
            <div class="shop-card__badges">
              {product.badges.map((badge, idx) => (
                <span class:list={["shop-card__badge", idx === 0 && badge !== product.tone && "shop-card__badge--accent"]}>{badge}</span>
              ))}
            </div>
          </div>

          <div class="shop-card__body">
            <p class="shop-card__meta">{product.meta}</p>
            <h3>{product.name}</h3>
            <p class="shop-card__desc">{product.description}</p>

            <div class="shop-card__footer">
              <div>
                <p class="shop-card__price">{product.price}</p>
                <p class="shop-card__stock">{product.stock}</p>
              </div>
              <a class="shop-card__cta" href={product.ctaHref}>Ajouter au panier</a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="shop-grid__dots" aria-hidden="true">
      <span class="is-active"></span><span></span><span></span>
    </div>
  </div>
</section>

<style>
  .shop-grid {
    border-bottom: 1px solid rgba(44, 44, 44, 0.08);
  }

  .shop-grid__heading {
    margin: 0 auto 2.5rem;
    max-width: 32rem;
    text-align: center;
  }

  .shop-grid__heading p {
    color: var(--color-accent);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-grid__heading h2 {
    font-size: clamp(2rem, 4vw, 2.85rem);
    margin: 0.75rem 0 0;
  }

  .shop-grid__cards {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .shop-card {
    background: var(--color-white);
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 1.25rem;
    overflow: hidden;
  }

  .shop-card__image-wrap {
    aspect-ratio: 1.11;
    position: relative;
  }

  .shop-card__image-wrap img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .shop-card__badges {
    display: flex;
    gap: 0.4rem;
    left: 0.85rem;
    position: absolute;
    right: 0.85rem;
    top: 0.85rem;
  }

  .shop-card__badge {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 999px;
    color: #6b6b6b;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.58rem;
    text-transform: uppercase;
  }

  .shop-card__badge--accent {
    background: rgba(214, 116, 0, 0.14);
    color: var(--color-cta);
  }

  .shop-card__body {
    display: grid;
    gap: 0.8rem;
    padding: 1rem 1rem 1.15rem;
  }

  .shop-card__meta {
    color: var(--color-muted);
    font-size: 0.72rem;
    letter-spacing: 0.11em;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-card h3 {
    font-size: 1.45rem;
    line-height: 1.1;
    margin: 0;
  }

  .shop-card__desc {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
  }

  .shop-card__footer {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin-top: 0.4rem;
  }

  .shop-card__price {
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.45rem;
    margin: 0;
  }

  .shop-card__stock {
    color: #2d4a2a;
    font-size: 0.85rem;
    margin: 0;
  }

  .shop-card__cta {
    align-items: center;
    background: var(--color-cta);
    border-radius: 999px;
    color: var(--color-white);
    display: inline-flex;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.11em;
    min-height: 2.65rem;
    padding: 0 0.95rem;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .shop-grid__dots {
    display: flex;
    gap: 0.42rem;
    justify-content: center;
    margin-top: 1.75rem;
  }

  .shop-grid__dots span {
    background: rgba(26, 26, 26, 0.24);
    border-radius: 999px;
    display: block;
    height: 0.44rem;
    width: 0.44rem;
  }

  .shop-grid__dots .is-active {
    background: #1c2738;
    width: 0.78rem;
  }

  @media (max-width: 1023px) {
    .shop-grid__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .shop-grid__cards {
      grid-template-columns: 1fr;
    }

    .shop-card__footer {
      align-items: stretch;
      flex-direction: column;
      gap: 0.75rem;
    }

    .shop-card__cta {
      justify-content: center;
      width: 100%;
    }
  }
</style>

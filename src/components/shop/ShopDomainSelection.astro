---
import type { ShopPageData } from "../../types/shop";

interface Props {
  domainSelection: ShopPageData["domainSelection"];
}

const { domainSelection } = Astro.props;

function iconSvg(icon: string) {
  if (icon === "shipping") {
    return `<svg viewBox="0 0 24 24" fill="none"><path d="M3 7h11v10H3zM14 10h4l3 3v4h-7zM7 18.5a1.5 1.5 0 1 0 0 .01M17 18.5a1.5 1.5 0 1 0 0 .01" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
  }
  if (icon === "map") {
    return `<svg viewBox="0 0 24 24" fill="none"><path d="M9 4 3 6v14l6-2 6 2 6-2V4l-6 2-6-2Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
  }
  if (icon === "return") {
    return `<svg viewBox="0 0 24 24" fill="none"><path d="M9 8H5V4M5 8l4-4M20 11a7 7 0 1 1-2.05-4.95" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
  }
  if (icon === "lock") {
    return `<svg viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 11V8a4 4 0 1 1 8 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`;
  }
  return `<svg viewBox="0 0 24 24" fill="none"><path d="M21 11.5a8.5 8.5 0 0 1-17 0 8.5 8.5 0 0 1 17 0ZM8.5 10a3.5 3.5 0 0 1 7 0v2" stroke="currentColor" stroke-width="1.6"/><path d="M12 18v.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`;
}
---

<section class="shop-selection section section--white" aria-labelledby="shop-selection-title">
  <div class="shell shop-shell">
    <header class="shop-selection__heading" data-reveal="up">
      <p>{domainSelection.eyebrow}</p>
      <h2 id="shop-selection-title">{domainSelection.title}</h2>
    </header>

    <!-- TODO_ADD_TIGER_DECOR: tiger visuals intentionally excluded in this iteration -->
    <div class="shop-selection__items" role="list" data-reveal-group data-reveal-stagger="65">
      {domainSelection.items.map((item) => (
        <article class="shop-selection__item ui-hover-lift" role="listitem" data-reveal="up">
          <span class="shop-selection__icon" aria-hidden="true" set:html={iconSvg(item.icon)}></span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .shop-selection {
    background: linear-gradient(180deg, #ffffff 0%, #f7f5f1 100%);
    position: relative;
  }

  .shop-selection::before {
    background: radial-gradient(circle at center, rgba(26, 26, 26, 0.06) 0%, rgba(26, 26, 26, 0) 62%);
    content: "";
    height: 16rem;
    left: 50%;
    pointer-events: none;
    position: absolute;
    top: 2.2rem;
    transform: translateX(-50%);
    width: min(62rem, 92%);
  }

  .shop-selection__heading {
    margin: 0 auto;
    max-width: 32rem;
    position: relative;
    text-align: center;
    z-index: 1;
  }

  .shop-selection__heading p {
    color: var(--color-accent-text);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-selection__heading h2 {
    font-size: clamp(1.95rem, 4vw, 2.9rem);
    margin: 0.7rem 0 0;
  }

  .shop-selection__items {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    margin-top: 2.1rem;
    position: relative;
    z-index: 1;
  }

  .shop-selection__item {
    align-items: flex-start;
    border-left: 1px solid rgba(44, 44, 44, 0.1);
    display: grid;
    gap: 0.7rem;
    grid-template-columns: auto 1fr;
    padding: 0.2rem 0 0.2rem 0.9rem;
  }

  .shop-selection__item:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .shop-selection__icon {
    align-items: center;
    border: 1px solid rgba(196, 156, 110, 0.42);
    border-radius: 999px;
    color: var(--color-accent-text);
    display: inline-flex;
    height: 1.45rem;
    justify-content: center;
    width: 1.45rem;
  }

  .shop-selection__icon :global(svg) {
    height: 0.85rem;
    width: 0.85rem;
  }

  .shop-selection__item h3 {
    font-size: 1.02rem;
    margin: 0;
  }

  .shop-selection__item p {
    color: var(--color-muted);
    font-size: 0.86rem;
    line-height: 1.45;
    margin: 0.25rem 0 0;
  }

  @media (max-width: 1023px) {
    .shop-selection__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .shop-selection__item:nth-child(odd) {
      border-left: 0;
      padding-left: 0;
    }
  }

  @media (max-width: 767px) {
    .shop-selection__items {
      grid-template-columns: 1fr;
    }

    .shop-selection__item {
      border-left: 0;
      border-top: 1px solid rgba(44, 44, 44, 0.1);
      padding: 0.8rem 0 0;
    }

    .shop-selection__item:first-child {
      border-top: 0;
      padding-top: 0;
    }
  }
</style>

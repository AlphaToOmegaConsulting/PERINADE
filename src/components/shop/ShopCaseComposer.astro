---
import { Image } from "astro:assets";
import type { ShopPageData } from "../../types/shop";
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
  caseComposer: ShopPageData["caseComposer"];
}

const { caseComposer } = Astro.props;

---

<section
  id="coffrets"
  class="shop-composer section"
  aria-labelledby="shop-composer-title"
  style={`--shop-composer-bg:url('${caseComposer.backdropImage.src}')`}
>
  <div class="shop-composer__backdrop" aria-hidden="true"></div>
  <div class="shell shop-shell shop-composer__shell">
    <figure class="shop-composer__crate">
      <Image src={caseComposer.crateImage} alt={caseComposer.crateImageAlt} loading="lazy" />
    </figure>

    <div class="shop-composer__content">
      <p class="shop-composer__eyebrow">{caseComposer.eyebrow}</p>
      <h2 id="shop-composer-title">{caseComposer.title}</h2>
      <p class="shop-composer__intro">{caseComposer.intro}</p>

      <div class="shop-composer__offers">
        {caseComposer.offers.map((offer) => (
          <article class="shop-offer">
            <h3>{offer.title}</h3>
            <p class="shop-offer__saving">{offer.saving}</p>
            <ul>
              {offer.lines.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
            <div class="shop-offer__price">
              <p>{offer.price}</p>
              <span>{offer.strikePrice}</span>
            </div>
            <p class="shop-offer__details">{offer.details}</p>

            <ButtonLink class="shop-offer__cta" href={offer.ctaHref} label={offer.ctaLabel} variant="secondary" size="md" />
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .shop-composer {
    background: #121212;
    overflow: clip;
    position: relative;
  }

  .shop-composer__backdrop {
    background:
      linear-gradient(180deg, rgba(18, 18, 18, 0.82), rgba(18, 18, 18, 0.94)),
      var(--shop-composer-bg) center / cover no-repeat;
    inset: 0;
    position: absolute;
  }

  .shop-composer__shell {
    align-items: end;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1fr);
    position: relative;
    z-index: 1;
  }

  .shop-composer__crate {
    border-radius: 1.25rem;
    margin: 0;
    overflow: hidden;
  }

  .shop-composer__crate img {
    aspect-ratio: 0.8;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    width: 100%;
  }

  .shop-composer__content {
    color: rgba(255, 255, 255, 0.84);
    padding-bottom: 0.5rem;
  }

  .shop-composer__eyebrow {
    color: var(--color-accent);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-composer h2 {
    color: var(--color-white);
    font-size: clamp(2rem, 4vw, 3.2rem);
    margin: 0.8rem 0;
  }

  .shop-composer__intro {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.6;
    margin: 0;
    max-width: 34rem;
  }

  .shop-composer__offers {
    display: grid;
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .shop-offer {
    background: rgba(255, 255, 255, 0.09);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1.25rem;
    padding: 1.35rem;
  }

  .shop-offer h3 {
    color: var(--color-white);
    font-size: 1.4rem;
    margin: 0;
  }

  .shop-offer__saving {
    color: var(--color-cta);
    font-size: 0.77rem;
    letter-spacing: 0.12em;
    margin: 0.45rem 0 0;
    text-transform: uppercase;
  }

  .shop-offer ul {
    display: grid;
    gap: 0.25rem;
    list-style: none;
    margin: 0.85rem 0 0;
    padding: 0;
  }

  .shop-offer li {
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }

  .shop-offer li::before {
    color: var(--color-accent);
    content: "›";
    left: 0;
    position: absolute;
  }

  .shop-offer__price {
    align-items: center;
    display: flex;
    gap: 0.65rem;
    margin-top: 0.9rem;
  }

  .shop-offer__price p {
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 1.85rem;
    margin: 0;
  }

  .shop-offer__price span {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.98rem;
    text-decoration: line-through;
  }

  .shop-offer__details {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.84rem;
    margin: 0.15rem 0 0;
  }

  .shop-offer :global(.shop-offer__cta) {
    --btn-secondary-bg: transparent;
    --btn-secondary-bg-hover: rgba(214, 116, 0, 0.14);
    --btn-secondary-border: var(--color-cta);
    --btn-secondary-color: var(--color-cta);

    margin-top: 1rem;
    min-height: 3rem;
    padding: 0 1.2rem;
  }

  @media (max-width: 1023px) {
    .shop-composer__shell {
      align-items: start;
      grid-template-columns: 1fr;
    }

    .shop-composer__crate {
      max-height: 22rem;
    }

    .shop-composer__crate img {
      aspect-ratio: 1.8;
    }
  }

  @media (max-width: 767px) {
    .shop-offer {
      padding: 1.1rem;
    }

    .shop-offer :global(.shop-offer__cta) {
      justify-content: center;
      width: 100%;
    }
  }
</style>

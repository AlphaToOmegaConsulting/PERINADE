---
import { Image } from "astro:assets";
import shopHeroImage from "../../assets/perinade/shop/img-1.png";

const primaryCta = { label: "Découvrir", href: "/boutique#produits" };
const secondaryCta = { label: "Composer ma caisse", href: "/boutique#coffrets" };
---

<section class="shop-hero section" aria-labelledby="shop-hero-title">
  <div class="shell shop-shell shop-hero__shell">
    <figure class="shop-hero__media">
      <Image src={shopHeroImage} alt="Cave avec étagères de bouteilles" loading="eager" />
    </figure>

    <div class="shop-hero__content">
      <p class="shop-hero__eyebrow">Boutique en ligne</p>
      <h1 id="shop-hero-title">Nos vins,<br /><span>chez vous</span></h1>
      <p class="shop-hero__body">
        Du domaine à votre table: commandez nos cuvées en ligne et recevez-les directement chez vous.
        Livraison gratuite dès 80 €.
      </p>

      <div class="shop-hero__actions">
        <a class="shop-hero__btn shop-hero__btn--primary" href={primaryCta.href}>{primaryCta.label}</a>

        <a class="shop-hero__btn shop-hero__btn--ghost" href={secondaryCta.href}>{secondaryCta.label}</a>
      </div>

      <ul class="shop-hero__meta" aria-label="Informations livraison boutique">
        <li>Livraison 48-72 h</li>
        <li>Paiement sécurisé</li>
        <li>Retours 14 jours</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .shop-hero {
    background: radial-gradient(circle at 75% 25%, rgba(214, 116, 0, 0.11), transparent 45%), #1a1a1a;
    padding-top: calc(var(--header-height) + 2.1rem);
  }

  .shop-hero__shell {
    align-items: center;
    display: grid;
    gap: 3.8rem;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
  }

  .shop-hero__media {
    border-radius: 1.875rem;
    box-shadow: 0 32px 68px rgba(0, 0, 0, 0.35);
    margin: 0;
    overflow: hidden;
  }

  .shop-hero__media img {
    aspect-ratio: 0.8;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .shop-hero__content {
    color: rgba(255, 255, 255, 0.84);
    max-width: 34rem;
  }

  .shop-hero__eyebrow {
    color: var(--color-accent);
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-hero h1 {
    color: var(--color-white);
    font-size: clamp(3.2rem, 6vw, 4.7rem);
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin: 1rem 0 1.35rem;
  }

  .shop-hero h1 span {
    color: var(--color-cta);
  }

  .shop-hero__body {
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.2rem;
    line-height: 1.6;
    margin: 0;
  }

  .shop-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2.2rem;
  }

  .shop-hero__btn {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 500;
    justify-content: center;
    letter-spacing: 0.16em;
    min-height: 3.55rem;
    padding: 0 1.65rem;
    text-transform: uppercase;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .shop-hero__btn--primary {
    background: var(--color-cta);
    box-shadow: 0 14px 24px rgba(214, 116, 0, 0.3);
    color: var(--color-white);
  }

  .shop-hero__btn--ghost {
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--color-white);
  }

  .shop-hero__meta {
    color: rgba(255, 255, 255, 0.52);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1.2rem;
    list-style: none;
    margin: 1.4rem 0 0;
    padding: 0;
  }

  .shop-hero__meta li {
    font-size: 0.95rem;
    line-height: 1.4;
    position: relative;
  }

  .shop-hero__meta li::before {
    content: "✓";
    margin-right: 0.38rem;
  }

  @media (max-width: 1023px) {
    .shop-hero {
      padding-top: calc(var(--header-height) + 1.65rem);
    }

    .shop-hero__shell {
      gap: 2.2rem;
      grid-template-columns: 1fr;
    }

    .shop-hero__content {
      max-width: 100%;
    }

    .shop-hero h1 {
      font-size: clamp(2.6rem, 9vw, 3.8rem);
    }
  }

  @media (max-width: 767px) {
    .shop-hero__body {
      font-size: 1rem;
    }

    .shop-hero__btn {
      min-height: 3.2rem;
      width: 100%;
    }
  }
</style>

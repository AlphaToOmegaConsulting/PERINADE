---
import type { ShopPageData } from "../../types/shop";

interface Props {
  faq: ShopPageData["faq"];
}

const { faq } = Astro.props;
---

<section class="shop-faq section section--soft" aria-labelledby="shop-faq-title">
  <div class="shell shop-shell shop-shell--narrow">
    <header class="shop-faq__heading" data-reveal="up">
      <p>{faq.eyebrow}</p>
      <h2 id="shop-faq-title">{faq.title}</h2>
    </header>

    <div class="shop-faq__list" data-accordion data-accordion-mode="single" data-reveal-group data-reveal-stagger="65">
      {faq.items.map((item, index) => {
        const panelId = `shop-faq-panel-${index}`;
        const triggerId = `shop-faq-trigger-${index}`;
        const isOpen = index === 0;

        return (
          <article class:list={["shop-faq__item", isOpen && "is-open"]} data-accordion-item data-reveal="up">
            <h3>
              <button
                id={triggerId}
                class="shop-faq__trigger"
                type="button"
                aria-expanded={isOpen ? "true" : "false"}
                aria-controls={panelId}
                data-accordion-trigger
              >
                <span>{item.question}</span>
                <span class="shop-faq__chevron" aria-hidden="true">⌄</span>
              </button>
            </h3>
            <div
              id={panelId}
              class="shop-faq__panel"
              role="region"
              aria-labelledby={triggerId}
              hidden={!isOpen}
              data-accordion-panel
            >
              <p>{item.answer}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .shop-faq__heading {
    margin: 0 auto 2.35rem;
    max-width: 42rem;
    text-align: center;
  }

  .shop-faq__heading p {
    color: var(--color-accent-text);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-faq__heading h2 {
    font-size: clamp(2rem, 4vw, 2.9rem);
    margin: 0.75rem 0 0;
  }

  .shop-faq__list {
    display: grid;
    gap: 0.85rem;
  }

  .shop-faq__item {
    background: var(--color-white);
    border: 1px solid rgba(44, 44, 44, 0.08);
    border-radius: 1.125rem;
    overflow: clip;
  }

  .shop-faq__trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--color-text-strong);
    cursor: pointer;
    display: flex;
    font-size: 1.02rem;
    font-weight: 500;
    justify-content: space-between;
    line-height: 1.5;
    padding: 1rem 1.35rem;
    text-align: left;
    width: 100%;
  }

  .shop-faq__trigger:hover,
  .shop-faq__trigger:focus-visible {
    background: rgba(196, 156, 110, 0.08);
  }

  .shop-faq__trigger:active {
    transform: scale(0.998);
  }

  .shop-faq__chevron {
    color: var(--color-muted);
    font-size: 1.2rem;
    transition: transform 180ms ease;
  }

  .shop-faq__item.is-open .shop-faq__chevron {
    transform: rotate(180deg);
  }

  .shop-faq__panel {
    border-top: 1px solid rgba(44, 44, 44, 0.08);
    padding: 1rem 1.35rem 1.2rem;
  }

  .shop-faq__panel p {
    color: var(--color-muted);
    line-height: 1.62;
    margin: 0;
  }

  @media (max-width: 767px) {
    .shop-faq__trigger {
      font-size: 0.95rem;
      padding-inline: 1rem;
    }

    .shop-faq__panel {
      padding-inline: 1rem;
    }
  }
</style>

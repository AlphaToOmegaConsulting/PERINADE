---
interface Props {
  eyebrow: string;
  title: string;
  centered?: boolean;
  light?: boolean;
  body?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  centered = false,
  light = false,
  body,
  class: className = ""
} = Astro.props;
---

<div class:list={["section-heading", centered && "section-heading--center", light && "section-heading--light", className]} data-reveal-group data-reveal-stagger="45">
  <p class="section-heading__eyebrow" data-reveal="up">{eyebrow}</p>
  <h2 class="section-heading__title" data-reveal="up">{title}</h2>
  {body && <p class="section-heading__body" data-reveal="up">{body}</p>}
</div>

<style>
  .section-heading {
    display: grid;
    gap: 0.75rem;
  }

  .section-heading--center {
    text-align: center;
  }

  .section-heading__eyebrow {
    color: var(--color-cta-strong);
    font-size: 0.8125rem;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .section-heading__title {
    font-size: var(--display-section-xl);
    letter-spacing: -0.03em;
    line-height: 1.04;
    margin: 0;
  }

  .section-heading__body {
    color: var(--color-muted-light);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
    max-width: 42rem;
  }

  .section-heading--center .section-heading__body {
    margin-inline: auto;
  }

  .section-heading--light .section-heading__eyebrow {
    color: var(--color-accent-text);
  }

  .section-heading--light .section-heading__title {
    color: var(--color-white);
  }

  .section-heading--light .section-heading__body {
    color: rgba(255, 255, 255, 0.8);
  }
  @media (max-width: 767px) {
    .section-heading {
      gap: 0.7rem;
    }

    .section-heading__body {
      font-size: 1rem;
    }
  }
</style>

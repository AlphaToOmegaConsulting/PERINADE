---
import ActionLink from "./actions/ActionLink.astro";
import SubmitButton from "./actions/SubmitButton.astro";
import ActionButton from "./actions/ActionButton.astro";
import type { ActionInteraction, ActionSize, ActionTone, ActionVariant } from "../../types/ui";

interface Props {
  label: string;
  variant?: ActionVariant;
  size?: ActionSize;
  tone?: ActionTone;
  interaction?: ActionInteraction;
  disabled?: boolean;
  fullWidth?: boolean;
  href?: string;
  type?: "button" | "submit";
  loading?: boolean;
  class?: string;
}

const {
  label,
  variant = "primary",
  size = "md",
  tone = "default",
  interaction = "default",
  disabled = false,
  fullWidth = false,
  href,
  type = "button",
  loading = false,
  class: className = "",
  ...rest
} = Astro.props;
---

{href ? (
  <ActionLink
    href={href}
    label={label}
    variant={variant}
    size={size}
    tone={tone}
    interaction={interaction}
    disabled={disabled}
    loading={loading}
    fullWidth={fullWidth}
    class={className}
    {...rest}
  />
) : type === "submit" ? (
  <SubmitButton
    label={label}
    variant={variant}
    size={size}
    tone={tone}
    interaction={interaction}
    disabled={disabled}
    loading={loading}
    fullWidth={fullWidth}
    class={className}
    {...rest}
  />
) : (
  <ActionButton
    label={label}
    variant={variant}
    size={size}
    tone={tone}
    interaction={interaction}
    disabled={disabled}
    loading={loading}
    fullWidth={fullWidth}
    type="button"
    class={className}
    {...rest}
  />
)}

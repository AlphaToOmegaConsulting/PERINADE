---
import { isPlaceholderLink } from "../../utils/link";

interface Props {
  label: string;
  variant?: "primary" | "secondary" | "ghost" | "text";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  fullWidth?: boolean;
  href?: string;
  type?: "button" | "submit";
  class?: string;
}

const {
  label,
  variant = "primary",
  size = "md",
  disabled = false,
  fullWidth = false,
  href,
  type = "button",
  class: className = ""
} = Astro.props;

const isPlaceholder = href ? isPlaceholderLink(href) : false;
const isDisabled = disabled || isPlaceholder;

const classes = [
  "btn",
  `btn--${variant}`,
  `btn--${size}`,
  fullWidth && "btn--block",
  isDisabled && "is-disabled",
  className
]
  .filter(Boolean)
  .join(" ");
---

{href && !isDisabled ? (
  <a class={classes} href={href}>{label}</a>
) : (
  <button class={classes} type={type} disabled={isDisabled} aria-disabled={isDisabled ? "true" : undefined}>
    {label}
  </button>
)}

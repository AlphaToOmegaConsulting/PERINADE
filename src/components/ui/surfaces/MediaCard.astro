---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Card from "./Card.astro";

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  title: string;
  eyebrow?: string;
  href?: string;
  class?: string;
  mediaClass?: string;
  contentClass?: string;
}

const {
  image,
  imageAlt,
  title,
  eyebrow,
  href,
  class: className = "",
  mediaClass = "",
  contentClass = ""
} = Astro.props;
---

<Card href={href} interactive={Boolean(href)} mediaInteractive class={className} padding="sm" radius="md" elevation="soft" contentClass={contentClass}>
  <div class:list={["ui-media-card__media", mediaClass]}>
    <Image src={image} alt={imageAlt} loading="lazy" />
  </div>
  {eyebrow && <p class="ui-card__eyebrow">{eyebrow}</p>}
  <h3 class="ui-card__title">{title}</h3>
</Card>

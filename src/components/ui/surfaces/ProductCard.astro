---
import { Image } from "astro:assets";
import type { ShopProduct } from "../../../types/shop";
import ActionLink from "../actions/ActionLink.astro";

interface Props {
  product: ShopProduct;
  class?: string;
}

const { product, class: className = "" } = Astro.props;

const suffixMatch = product.price.match(/\s(TTC|incl\. VAT|IVA incl\.)$/);
const priceSuffix = suffixMatch?.[1] ?? "";
const priceMain = suffixMatch ? product.price.replace(/\s(TTC|incl\. VAT|IVA incl\.)$/, "") : product.price;
---

<article class={["shop-card", className].filter(Boolean).join(" ")}>
  <div class="shop-card__image-wrap ui-hover-media">
    <Image src={product.image} alt={product.imageAlt} loading="lazy" />
  </div>

  <div class="shop-card__body">
    <p class="shop-card__meta">{product.meta}</p>
    <h3 class="shop-card__title">{product.name}</h3>
    <p class="shop-card__description">{product.description}</p>

    <div class="shop-card__footer">
      <div class="shop-card__price-wrap">
        <p class="shop-card__price">{priceMain}</p>
        {priceSuffix && <p class="shop-card__price-suffix">{priceSuffix}</p>}
      </div>
      <ActionLink class="shop-card__cta" href={product.ctaHref} label={product.ctaLabel} variant="primary" size="sm" />
    </div>
  </div>
</article>

<style>
  .shop-card {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 1.25rem;
    overflow: hidden;
  }

  .shop-card__image-wrap {
    aspect-ratio: 1.22;
    background: #f0ebe3;
    position: relative;
  }

  .shop-card__image-wrap img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .shop-card__body {
    display: grid;
    gap: 0.42rem;
    grid-template-rows: auto auto minmax(4.2rem, auto) auto;
    padding: 0.92rem 0.9rem 0.88rem;
  }

  .shop-card__meta {
    color: #6b6b6b;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    line-height: 1.25;
    margin: 0;
    text-transform: uppercase;
  }

  .shop-card__title {
    color: #2c2c2c;
    font-family: var(--font-body, "Inter", sans-serif);
    font-size: 1.22rem;
    font-weight: 600;
    line-height: 1.22;
    margin: 0;
    min-height: 2.44em;
  }

  .shop-card__description {
    color: #6b6b6b;
    font-size: 0.92rem;
    line-height: 1.42;
    margin: 0;
    min-height: 3.9rem;
  }

  .shop-card__footer {
    align-items: flex-end;
    display: flex;
    gap: 0.55rem;
    justify-content: space-between;
    margin-top: 0.08rem;
  }

  .shop-card__price-wrap {
    display: grid;
    gap: 0.1rem;
  }

  .shop-card__price,
  .shop-card__price-suffix {
    color: #2c2c2c;
    font-family: var(--font-body, "Inter", sans-serif);
    font-size: 1.06rem;
    font-weight: 600;
    line-height: 1;
    margin: 0;
  }

  .shop-card__price {
    font-size: 1.9rem;
    font-weight: 500;
  }

  .shop-card :global(.shop-card__cta) {
    min-height: 2.15rem;
    min-width: 10.2rem;
    padding-inline: 0.85rem;
    white-space: nowrap;
  }

  @media (max-width: 61.9375em) {
    .shop-card__title {
      font-size: 1.12rem;
      min-height: auto;
    }

    .shop-card__description {
      font-size: 0.88rem;
      min-height: 3.2rem;
    }

    .shop-card__price,
    .shop-card__price-suffix {
      font-size: 1rem;
    }

    .shop-card__price {
      font-size: 1.55rem;
    }
  }

  @media (max-width: 47.9375em) {
    .shop-card__footer {
      align-items: stretch;
      flex-direction: column;
    }

    .shop-card :global(.shop-card__cta) {
      justify-content: center;
      width: 100%;
    }
  }
</style>

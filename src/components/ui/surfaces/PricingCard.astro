---
import type { PricingFeatureGroup } from "../../../types/visits";
import Card from "./Card.astro";
import ActionLink from "../actions/ActionLink.astro";

interface Props {
  plan: PricingFeatureGroup;
  class?: string;
}

const { plan, class: className = "" } = Astro.props;
---

<Card
  class={["plan", className, plan.isHighlighted && "plan--highlighted"].filter(Boolean).join(" ")}
  surfaceTone={plan.isHighlighted ? "inverse" : "default"}
  radius="lg"
  padding="lg"
  elevation="flat"
  interactive
>
  {plan.badge && <span class="plan__badge">{plan.badge}</span>}
  <h3 class="ui-card__title">{plan.title}</h3>
  <p class="plan__subtitle">{plan.subtitle}</p>
  <p class="plan__price">
    <strong>{plan.price}</strong>
    <span>{plan.perLabel}</span>
  </p>

  <ul>
    {plan.features.map((feature) => (
      <li>{feature}</li>
    ))}
  </ul>

  <ActionLink
    href={plan.ctaHref}
    label={plan.ctaLabel}
    variant={plan.isHighlighted ? "primary" : "secondary"}
    size="lg"
    fullWidth
    class="plan__cta"
  />
</Card>

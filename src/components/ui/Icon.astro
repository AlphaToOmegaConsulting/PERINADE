---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = "" } = Astro.props;

const icon = name.toLowerCase();
---

{
  icon === "leaf" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M18 3c-6 1-10 4.5-11.4 10.3-.2.8-.4 1.7-.6 2.7 1.1-.7 2.2-1.1 3.2-1.4C15 13 18.5 9.1 20 4.5c.1-.5.2-1 .3-1.5H18Zm-6 10.5c-2.5 0-4.6.9-6.5 3.1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "terrain" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M3 16c1.8-2.3 3.6-3.4 5.4-3.4S12 13.7 13.7 16c1.8-2 3.5-3 5.3-3 1 0 2 .4 3 1.1M3 20h18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "glass" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M8 4h8l-1.2 7.2A4 4 0 0 1 11 14.5V20m0 0h2m-2 0H9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "clock" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.7"></circle>
        <path d="M12 7.5v5l3 1.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "users" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M8.5 12.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm7 0a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM4.5 18c.7-2 2.2-3 4-3h.5c1.8 0 3.3 1 4 3M14 18c.5-1.4 1.6-2.2 3.2-2.2h.3c1.1 0 2.1.4 3 1.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "globe" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.7"></circle>
        <path d="M4.5 9.5h15M4.5 14.5h15M12 4c2 2.2 3 5 3 8s-1 5.8-3 8c-2-2.2-3-5-3-8s1-5.8 3-8Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "pin" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 20s5-4.8 5-9a5 5 0 1 0-10 0c0 4.2 5 9 5 9Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
        <circle cx="12" cy="11" r="1.8" fill="currentColor"></circle>
      </svg>
    </span>
  ) : icon === "ticket" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M4 8.5A2.5 2.5 0 0 0 6.5 6H18v12H6.5A2.5 2.5 0 0 0 4 15.5v-7Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M11 9.5h3M11 14.5h2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
      </svg>
    </span>
  ) : icon === "phone" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M7.5 5.5c.4-.4 1-.5 1.5-.2l2 1c.6.3.8 1 .5 1.6l-.7 1.4c1 1.9 2.5 3.4 4.4 4.4l1.4-.7c.6-.3 1.3-.1 1.6.5l1 2c.3.5.2 1.1-.2 1.5l-1.2 1.2c-.7.7-1.7.9-2.6.6A17.6 17.6 0 0 1 4.4 8.1c-.3-.9-.1-1.9.6-2.6l1.2-1.2Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "mail" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M4 7.5h16v9H4v-9Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
        <path d="m5 8.5 7 5 7-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "calendar" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <rect x="4" y="5.5" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.7"></rect>
        <path d="M8 3.5v4M16 3.5v4M4 9h16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
      </svg>
    </span>
  ) : icon === "car" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M6.5 14.5h11l-1.2-3.3a2 2 0 0 0-1.9-1.3H9.6a2 2 0 0 0-1.9 1.3L6.5 14.5Zm0 0-1.5 1.2v2.3h1.7v-1.3h10.6V18H19v-2.3l-1.5-1.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
        <circle cx="8.2" cy="14.5" r=".9" fill="currentColor"></circle>
        <circle cx="15.8" cy="14.5" r=".9" fill="currentColor"></circle>
      </svg>
    </span>
  ) : icon === "plane" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M3 13.5 21 9l-9 9-1.6-3.9L6.5 12 3 13.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
      </svg>
    </span>
  ) : icon === "train" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <rect x="6" y="4.5" width="12" height="13" rx="2.5" stroke="currentColor" stroke-width="1.5"></rect>
        <path d="M9 8h6M9 11h6M8.5 18.5l-2 2M15.5 18.5l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      </svg>
    </span>
  ) : icon === "tree" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M12 3 7 10h3l-2 3h3l-2.2 3.5h6.4L13 13h3l-2-3h3L12 3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
        <path d="M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      </svg>
    </span>
  ) : icon === "pool" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M4 15c1.3 1.4 2.7 2 4 2s2.7-.6 4-2c1.3 1.4 2.7 2 4 2s2.7-.6 4-2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        <path d="M6 13V8.5A2.5 2.5 0 0 1 8.5 6h3A2.5 2.5 0 0 1 14 8.5V13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
      </svg>
    </span>
  ) : icon === "event" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="m4 18 5.8-8.7 3.5 3 2.3-3.7L20 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
        <circle cx="6" cy="6" r="1" fill="currentColor"></circle>
        <circle cx="12" cy="5" r="1" fill="currentColor"></circle>
        <circle cx="17.5" cy="5.5" r="1" fill="currentColor"></circle>
      </svg>
    </span>
  ) : icon === "instagram" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <rect x="4.5" y="4.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.7"></rect>
        <circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.7"></circle>
        <circle cx="17" cy="7.3" r="1" fill="currentColor"></circle>
      </svg>
    </span>
  ) : icon === "facebook" ? (
    <span class={className} aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M14.3 8H16V5.2c-.3 0-.9-.2-2-.2-2.1 0-3.5 1.3-3.5 3.8V11H8v3h2.5v5H14v-5h2.6l.4-3H14V9.2c0-.9.2-1.2 1.3-1.2Z" fill="currentColor"></path>
      </svg>
    </span>
  ) : null
}

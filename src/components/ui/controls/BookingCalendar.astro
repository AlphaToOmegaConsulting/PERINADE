---
import type { VisitPageData } from "../../../types/visits";
import SectionHeading from "../SectionHeading.astro";
import ChoiceChipGroup from "./ChoiceChipGroup.astro";
import CounterField from "./CounterField.astro";
import ToggleField from "./ToggleField.astro";
import SubmitButton from "../actions/SubmitButton.astro";

interface Props {
  booking: VisitPageData["booking"];
}

const { booking } = Astro.props;
---

<section class="booking section section--soft" id="booking">
  <div class="shell">
    <SectionHeading eyebrow={booking.eyebrow} title={booking.title} body={booking.body} centered />

    <div
      class="booking__panel ui-booking-panel ui-hover-lift"
      data-booking
      data-reveal="up"
      data-config={JSON.stringify(booking.config)}
      style={`--booking-calendar-ratio:${booking.layout.calendarWidthRatio}; --booking-controls-ratio:${booking.layout.controlsWidthRatio}; --booking-panel-max:${booking.layout.panelMaxWidth}; --booking-calendar-cell-height:${booking.layout.calendarCellHeight}; --booking-control-row-height:${booking.layout.controlRowHeight};`}
    >
      <div class="booking__calendar" data-reveal-group data-reveal-stagger="35">
        <header>
          <button type="button" data-calendar-prev aria-label={booking.ui.prevMonthAriaLabel}>‹</button>
          <h3 data-calendar-month>{booking.config.monthLabel}</h3>
          <button type="button" data-calendar-next aria-label={booking.ui.nextMonthAriaLabel}>›</button>
        </header>

        <div class="booking__days-row">
          {booking.config.dayLabels.map((day) => (
            <span>{day}</span>
          ))}
        </div>

        <div class="booking__grid" data-calendar-days>
          {booking.config.selectableDays.map((day) => (
            <button type="button" data-day={day} class:list={[day === booking.config.defaultDay && "is-active"]}>{day}</button>
          ))}
        </div>
      </div>

      <div class="booking__controls">
        <form
          class="booking__form"
          data-ui-form
          data-booking-form
          data-submit-endpoint={booking.config.submitEndpoint ?? ""}
          data-submit-success={booking.config.successMessage ?? ""}
          data-submit-error={booking.config.errorMessage ?? ""}
          data-error-missing-date={booking.ui.missingDateMessage}
          data-default-success={booking.ui.defaultSuccessMessage}
          data-default-error={booking.ui.defaultErrorMessage}
          data-mail-subject={booking.ui.mailSubjectFallback}
        >
          <section>
            <h4>{booking.ui.slotHeading}</h4>
            <ChoiceChipGroup class="booking__slot-grid" items={booking.config.slots} activeId={booking.config.defaultSlotId} />
          </section>

          <section>
            <h4>{booking.ui.participantsHeading}</h4>
            <CounterField
              class="booking__counter"
              value={booking.config.defaultParticipants}
              min={booking.config.minParticipants}
              max={booking.config.maxParticipants}
              decrementLabel="Diminuer"
              incrementLabel="Augmenter"
            />
          </section>

          <ToggleField id="booking-addon" class="booking__addon" label={booking.config.addonLabel} dataAddon />

          <p class="booking__price">
            <span>{booking.ui.priceFromLabel}</span>
            <strong><span data-price-value>{booking.config.basePricePerPerson}</span>€ <small>{booking.ui.pricePerPersonLabel}</small></strong>
          </p>

          <input type="hidden" name="day" data-booking-field-day />
          <input type="hidden" name="slotId" data-booking-field-slot />
          <input type="hidden" name="participants" data-booking-field-participants />
          <input type="hidden" name="addon" data-booking-field-addon />
          <input type="hidden" name="totalPerPerson" data-booking-field-total />

          <SubmitButton class="booking__cta" label={booking.config.ctaLabel} variant="primary" size="lg" fullWidth />
          <a class="booking__call" href="tel:+33468000000">{booking.config.callLabel}</a>
          <p class="booking__status ui-status-animate" data-booking-status aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .booking__panel {
    background: #fff;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: var(--visit-radius-xl);
    box-shadow: 0 1.25rem 2.625rem rgba(0, 0, 0, 0.08);
    display: grid;
    grid-template-columns: minmax(0, var(--booking-calendar-ratio)) minmax(0, var(--booking-controls-ratio));
    margin: clamp(1.2rem, 3.5vw, 2.3rem) auto 0;
    max-width: var(--booking-panel-max);
    overflow: hidden;
  }

  .booking__calendar {
    padding: clamp(1rem, 3vw, 2rem);
  }

  .booking__calendar header {
    align-items: center;
    display: grid;
    grid-template-columns: auto 1fr auto;
    margin-bottom: clamp(0.7rem, 2vw, 1.1rem);
  }

  .booking__calendar header h3 {
    font-size: clamp(1.6rem, 2.1vw, 1.85rem);
    margin: 0;
    text-align: center;
  }

  .booking__calendar header button {
    background: transparent;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: 100vmax;
    cursor: pointer;
    font-size: clamp(1.15rem, 4vw, 1.5rem);
    block-size: var(--control-height-sm);
    inline-size: var(--control-height-sm);
  }

  .booking__calendar header button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  .booking__days-row,
  .booking__grid {
    display: grid;
    gap: var(--space-2xs);
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }

  .booking__days-row {
    margin-bottom: var(--space-2xs);
  }

  .booking__days-row span {
    color: var(--color-muted);
    font-size: var(--visit-type-caption-size);
    letter-spacing: var(--visit-type-caption-track);
    text-align: center;
    text-transform: uppercase;
  }

  .booking__day-pad {
    min-block-size: var(--booking-calendar-cell-height);
  }

  .booking__grid button {
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--visit-radius-sm);
    color: #b7b7b7;
    cursor: pointer;
    font-size: clamp(0.84rem, 2.5vw, 0.95rem);
    min-block-size: var(--booking-calendar-cell-height);
  }

  .booking__grid button.is-active {
    border: 1px solid var(--visit-accent-primary);
    color: var(--visit-accent-primary);
    font-weight: 600;
    transform: translateY(var(--motion-distance-sm));
  }

  .booking__grid button.is-disabled,
  .booking__grid button:disabled {
    color: #b7b7b7;
    cursor: not-allowed;
    opacity: 0.48;
  }

  .booking__controls {
    border-left: 1px solid var(--visit-stroke-subtle);
    padding: clamp(1rem, 3vw, 1.35rem);
  }

  .booking__form {
    display: grid;
    gap: var(--space-sm);
  }

  .booking__controls h4 {
    font-size: var(--visit-type-caption-size);
    letter-spacing: var(--visit-type-caption-track);
    margin: 0 0 clamp(0.35rem, 1.2vw, 0.55rem);
    text-transform: uppercase;
  }

  .booking__slot-grid {
    display: grid;
    gap: var(--space-xs);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .booking__slot-grid .ui-choice-chip,
  .booking__counter .ui-counter__button {
    background: #fff;
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: var(--visit-radius-sm);
    font-size: clamp(0.92rem, 2.6vw, 1rem);
    min-block-size: var(--booking-control-row-height);
  }

  .booking__slot-grid .ui-choice-chip.is-active {
    border-color: var(--visit-accent-primary);
    color: var(--visit-accent-primary);
    font-weight: 600;
  }

  .booking__counter {
    display: grid;
    gap: var(--space-xs);
    grid-template-columns: 1fr auto 1fr;
  }

  .booking__counter .ui-counter__button {
    font-size: clamp(1.2rem, 4.5vw, 1.6rem);
  }

  .booking__counter .ui-counter__value {
    align-items: center;
    display: inline-flex;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2rem);
    justify-content: center;
    min-inline-size: clamp(2rem, 8vw, 3rem);
  }

  .booking__addon {
    border: 1px solid var(--visit-stroke-subtle);
    border-radius: var(--visit-radius-md);
    min-block-size: calc(var(--booking-control-row-height) + clamp(0.15rem, 0.8vw, 0.4rem));
    padding-inline: clamp(0.7rem, 2.4vw, 1rem);
  }

  .booking__price {
    align-items: end;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin: 0;
  }

  .booking__price [data-price-value] {
    display: inline-block;
    transition:
      transform var(--motion-duration-sm) var(--motion-ease-standard),
      color var(--motion-duration-sm) var(--motion-ease-standard);
  }

  .booking__price [data-price-value].is-updating {
    color: var(--visit-accent-primary);
    transform: scale(var(--motion-scale-subtle));
  }

  .booking__price > span {
    color: var(--color-muted);
  }

  .booking__price strong {
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 4vw, 1.75rem);
    font-weight: 500;
  }

  .booking__price small {
    font-family: var(--font-body);
    font-size: 0.8rem;
  }

  .booking__cta {
    margin-top: 0.35rem;
  }

  .booking__call {
    color: var(--visit-accent-primary);
    justify-self: center;
  }

  .booking__status {
    min-block-size: 1.2rem;
  }

  .booking__status.is-success {
    color: #1f6f4a;
  }

  .booking__status.is-error {
    color: #9f2517;
  }

  .booking__status {
    margin: 0;
    min-height: 1.5rem;
    text-align: center;
  }

  .booking__status.is-success {
    color: #2d4a2a;
  }

  .booking__status.is-error {
    color: #9b2c2c;
  }

  @media (max-width: 900px) {
    .booking__panel {
      grid-template-columns: 1fr;
    }

    .booking__controls {
      border-left: 0;
      border-top: 1px solid var(--visit-stroke-subtle);
    }
  }
</style>

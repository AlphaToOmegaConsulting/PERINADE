---
import { Image } from "astro:assets";
import type { NewsPageData } from "../../types/news";

interface Props {
  articles: NewsPageData["articles"];
}

const { articles } = Astro.props;
---

<section class="news-articles section">
  <div class="shell news-articles__shell">
    <header class="news-articles__header" data-reveal-group data-reveal-stagger="55">
      <div>
        <p class="news-articles__eyebrow" data-reveal="up">{articles.eyebrow}</p>
        <h2 class="news-articles__title" data-reveal="up">{articles.title}</h2>
      </div>
      <div class="news-articles__chips" aria-label="Article categories" data-reveal="up">
        {articles.chips.map((chip) => (
          <button class:list={["news-articles__chip", chip === articles.activeChip && "is-active"]} type="button">
            {chip}
          </button>
        ))}
      </div>
    </header>

    <article class="news-articles__lead" data-reveal="up">
      <div class="news-articles__lead-media">
        <Image src={articles.leadCard.image} alt={articles.leadCard.imageAlt} loading="lazy" />
      </div>
      <div class="news-articles__lead-content">
        <p class="news-articles__meta-row">
          <span>{articles.leadCard.category}</span>
        </p>
        <h3>{articles.leadCard.title}</h3>
        <p class="news-articles__separator"></p>
        <p class="news-articles__excerpt">{articles.leadCard.excerpt}</p>
        <p class="news-articles__meta-row">
          <span>{articles.leadCard.date}</span>
          <span>{articles.leadCard.readLabel}</span>
        </p>
        <a href={articles.leadCard.href} class="news-articles__link">{articles.leadCtaLabel}</a>
      </div>
    </article>

    <div class="news-articles__grid" data-reveal-group data-reveal-stagger="70">
      {articles.cards.map((card) => (
        <article class="news-articles__card" data-reveal="up">
          <div class="news-articles__card-media">
            <Image src={card.image} alt={card.imageAlt} loading="lazy" />
          </div>
          <p class="news-articles__meta-row">
            <span>{card.category}</span>
            <span>{card.date}</span>
          </p>
          <h3>{card.title}</h3>
          <p class="news-articles__excerpt">{card.excerpt}</p>
          <a href={card.href} class="news-articles__link">{card.readLabel}</a>
        </article>
      ))}
    </div>

    <div class="news-articles__actions" data-reveal="up">
      <a href={articles.viewMoreHref} class="news-articles__more">{articles.viewMoreLabel}</a>
    </div>
  </div>
</section>

<style>
  .news-articles {
    background: #f8f5f0;
    padding-block: 8rem;
  }

  .news-articles__shell {
    margin-inline: auto;
    max-width: 55.625rem;
    width: min(100%, calc(100vw - 12rem));
  }

  .news-articles__header {
    align-items: end;
    display: flex;
    gap: 2rem;
    justify-content: space-between;
    margin-bottom: 4.4rem;
  }

  .news-articles__eyebrow {
    color: #c49c6e;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-articles__title {
    color: #1a1a1a;
    font-size: 1.5rem;
    line-height: 1.2;
    margin: 1rem 0 0;
    max-width: 10rem;
  }

  .news-articles__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
    max-width: 38rem;
  }

  .news-articles__chip {
    background: transparent;
    border: 1px solid rgba(196, 156, 110, 0.32);
    border-radius: 100vmax;
    color: #6a6055;
    cursor: default;
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    min-height: 2.2rem;
    padding: 0.35rem 1rem;
    text-transform: uppercase;
  }

  .news-articles__chip.is-active {
    background: #1a1a1a;
    border-color: #1a1a1a;
    color: #f5f0e8;
  }

  .news-articles__lead {
    background: #fff;
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: 0.375rem;
    display: grid;
    grid-template-columns: 45% 55%;
    overflow: hidden;
  }

  .news-articles__lead-media :global(img) {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .news-articles__lead-media {
    aspect-ratio: 399 / 413;
    overflow: hidden;
  }

  .news-articles__lead-media :global(picture) {
    display: block;
    height: 100%;
    width: 100%;
  }

  .news-articles__lead-content {
    display: grid;
    gap: 1rem;
    padding: 3rem;
  }

  .news-articles__meta-row {
    color: #9a9088;
    display: flex;
    flex-wrap: wrap;
    font-size: 0.6875rem;
    gap: 0.65rem;
    letter-spacing: 0.14em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-articles__meta-row span + span::before {
    content: "·";
    margin-right: 0.65rem;
  }

  .news-articles__lead h3,
  .news-articles__card h3 {
    color: #1a1a1a;
    font-size: 1.52rem;
    line-height: 1.25;
    margin: 0;
  }

  .news-articles__separator {
    background: rgba(196, 156, 110, 0.35);
    height: 1px;
    margin: 0;
    width: 1.5rem;
  }

  .news-articles__excerpt {
    color: #6a6055;
    font-size: 0.875rem;
    line-height: 1.8;
    margin: 0;
  }

  .news-articles__link {
    color: #c49c6e;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-decoration: none;
    text-transform: uppercase;
    width: fit-content;
  }

  .news-articles__link::after {
    content: "  →";
  }

  .news-articles__grid {
    display: grid;
    gap: 4rem 3.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 5rem;
  }

  .news-articles__card {
    display: grid;
    gap: 1rem;
  }

  .news-articles__card-media {
    aspect-ratio: 417 / 278;
    overflow: hidden;
  }

  .news-articles__card-media :global(picture) {
    display: block;
    height: 100%;
    width: 100%;
  }

  .news-articles__card-media :global(img) {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .news-articles__card h3 {
    font-size: 1.17rem;
  }

  .news-articles__actions {
    display: flex;
    justify-content: center;
    margin-top: 4.75rem;
  }

  .news-articles__more {
    border: 1px solid rgba(26, 26, 26, 0.18);
    border-radius: 0.375rem;
    color: #3d332a;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    min-height: 3rem;
    padding: 0.95rem 2rem;
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 63.9375em) {
    .news-articles {
      padding-block: 5.75rem;
    }

    .news-articles__shell {
      width: min(100%, calc(100vw - 4rem));
    }

    .news-articles__header {
      align-items: start;
      flex-direction: column;
      margin-bottom: 2.75rem;
    }

    .news-articles__chips {
      justify-content: flex-start;
    }

    .news-articles__lead {
      grid-template-columns: 1fr;
    }

    .news-articles__lead-media {
      aspect-ratio: 16 / 10;
    }

    .news-articles__lead-content {
      padding: 2rem;
    }

    .news-articles__grid {
      gap: 2.8rem 2rem;
      margin-top: 3.25rem;
    }
  }

  @media (max-width: 47.9375em) {
    .news-articles {
      padding-block: 4rem;
    }

    .news-articles__shell {
      width: min(100%, calc(100vw - 2.5rem));
    }

    .news-articles__grid {
      grid-template-columns: 1fr;
    }

    .news-articles__actions {
      margin-top: 3.2rem;
    }

    .news-articles__more {
      text-align: center;
      width: 100%;
    }
  }
</style>

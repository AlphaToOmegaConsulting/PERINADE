---
import { Image } from "astro:assets";
import type { NewsPageData } from "../../types/news";

interface Props {
  featured: NewsPageData["featured"];
}

const { featured } = Astro.props;
---

<section class="news-featured section">
  <div class="news-featured__layout">
    <div class="news-featured__media" data-reveal="zoom">
      <Image src={featured.image} alt={featured.imageAlt} loading="eager" />
    </div>

    <div class="news-featured__content" data-reveal-group data-reveal-stagger="65">
      <p class="news-featured__eyebrow" data-reveal="up">{featured.eyebrow}</p>
      <span class="news-featured__chip" data-reveal="up">{featured.category}</span>
      <h2 class="news-featured__title" data-reveal="up">{featured.title}</h2>
      <p class="news-featured__excerpt" data-reveal="up">{featured.excerpt}</p>
      <p class="news-featured__meta" data-reveal="up">
        <span>{featured.date}</span>
        <span>{featured.readTime}</span>
      </p>
      <a class="news-featured__link" href={featured.ctaHref} data-reveal="up">
        {featured.ctaLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .news-featured {
    background: #f8f5f0;
    padding: 0;
  }

  .news-featured__layout {
    display: grid;
    grid-template-columns: 58% 42%;
    min-height: 40rem;
  }

  .news-featured__media {
    min-height: 40rem;
    overflow: hidden;
  }

  .news-featured__media :global(img) {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .news-featured__content {
    align-content: center;
    background: #1a1a1a;
    color: #f5f0e8;
    display: grid;
    gap: 1.6rem;
    padding: clamp(3rem, 6vw, 4rem);
  }

  .news-featured__eyebrow {
    color: #c49c6e;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-featured__chip {
    border: 1px solid rgba(196, 156, 110, 0.35);
    border-radius: 0.375rem;
    color: rgba(196, 156, 110, 0.8);
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    padding: 0.32rem 0.75rem;
    text-transform: uppercase;
    width: fit-content;
  }

  .news-featured__title {
    font-size: clamp(1.5rem, 2.35vw, 2rem);
    line-height: 1.2;
    margin: 0;
  }

  .news-featured__excerpt {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.875rem;
    line-height: 1.8;
    margin: 0;
  }

  .news-featured__meta {
    color: rgba(255, 255, 255, 0.38);
    display: flex;
    font-size: 0.6875rem;
    gap: 0.7rem;
    letter-spacing: 0.12em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-featured__meta span + span::before {
    content: "·";
    margin-right: 0.7rem;
  }

  .news-featured__link {
    color: #c49c6e;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .news-featured__link::after {
    content: "  →";
  }

  @media (max-width: 63.9375em) {
    .news-featured__layout {
      grid-template-columns: 1fr;
    }

    .news-featured__media,
    .news-featured__layout {
      min-height: 0;
    }

    .news-featured__media {
      aspect-ratio: 16 / 10;
    }
  }
</style>

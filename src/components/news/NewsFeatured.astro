---
import { Image } from "astro:assets";
import type { NewsPageData } from "../../types/news";
import SectionHeading from "../ui/SectionHeading.astro";
import ActionLink from "../ui/actions/ActionLink.astro";

interface Props {
  featured: NewsPageData["featured"];
}

const { featured } = Astro.props;
---

<section class="news-featured section section--soft">
  <div class="shell news-featured__shell">
    <div class="news-featured__layout" data-reveal-group data-reveal-stagger="65">
      <figure class="news-featured__media ui-hover-media" data-reveal="zoom">
        <Image src={featured.image} alt={featured.imageAlt} loading="lazy" />
      </figure>

      <article class="news-featured__content" data-reveal-group data-reveal-stagger="65">
        <SectionHeading eyebrow={featured.eyebrow} title={featured.title} class="news-featured__heading" />

        <p class="news-featured__chip" data-reveal="up">{featured.category}</p>
        <p class="news-featured__excerpt" data-reveal="up">{featured.excerpt}</p>

        <p class="news-featured__meta" data-reveal="up">
          <span>{featured.date}</span>
          <span>{featured.readTime}</span>
        </p>

        <div data-reveal="up">
          <ActionLink href={featured.ctaHref} label={featured.ctaLabel} variant="text" size="md" />
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .news-featured {
    border-top: 1px solid rgba(44, 44, 44, 0.06);
  }

  .news-featured__shell {
    max-width: 74rem;
  }

  .news-featured__layout {
    align-items: stretch;
    display: grid;
    gap: clamp(1.3rem, 3vw, 2rem);
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
  }

  .news-featured__media {
    border-radius: 1.5rem;
    margin: 0;
    min-height: clamp(20rem, 45vw, 30rem);
    overflow: hidden;
  }

  .news-featured__media :global(img) {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .news-featured__content {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.08);
    border-radius: 1.25rem;
    display: grid;
    gap: 1rem;
    padding: clamp(1.35rem, 3vw, 2.2rem);
  }

  .news-featured__content :global(.news-featured__heading) {
    gap: 0.6rem;
  }

  .news-featured__content :global(.section-heading__title) {
    font-size: clamp(1.85rem, 3vw, 2.5rem);
    line-height: 1.12;
  }

  .news-featured__chip {
    border: 1px solid rgba(196, 156, 110, 0.35);
    border-radius: 999px;
    color: color-mix(in srgb, var(--color-accent) 78%, black);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    margin: 0;
    padding: 0.35rem 0.8rem;
    text-transform: uppercase;
    width: fit-content;
  }

  .news-featured__excerpt {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  .news-featured__meta {
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.72rem;
    gap: 0.6rem;
    letter-spacing: 0.14em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-featured__meta span + span::before {
    content: "·";
    margin-right: 0.6rem;
  }

  @media (max-width: 63.9375em) {
    .news-featured__layout {
      grid-template-columns: 1fr;
    }

    .news-featured__media {
      min-height: 0;
    }

    .news-featured__media :global(img) {
      aspect-ratio: 16 / 10;
      height: auto;
    }
  }
</style>

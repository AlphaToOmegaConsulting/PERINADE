---
import type { NewsPageData } from "../../types/news";

interface Props {
  hero: NewsPageData["hero"];
}

const { hero } = Astro.props;
---

<section class="news-hero section">
  <div class="shell news-hero__shell">
    <div class="news-hero__line" aria-hidden="true"></div>
    <p class="news-hero__eyebrow" data-reveal="up">{hero.eyebrow}</p>
    <h1 class="news-hero__title" data-reveal="up">
      <span>{hero.titleLines[0]}</span>
      <span class="is-accent">{hero.titleLines[1]}</span>
    </h1>
    <p class="news-hero__lead" data-reveal="up">{hero.lead}</p>

    <div class="news-hero__stats" aria-label="News key metrics" data-reveal="up">
      {hero.stats.map((stat) => (
        <div class="news-hero__stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
      <p class="news-hero__updated">{hero.updatedLabel}</p>
    </div>

    <p class="news-hero__year" aria-hidden="true">{hero.watermarkYear}</p>
  </div>
</section>

<style>
  .news-hero {
    background: #1a1a1a;
    color: #f5f0e8;
    min-height: 49.890625rem;
    overflow: hidden;
    padding-bottom: 9rem;
    padding-top: calc(var(--header-height) + 8.25rem);
    position: relative;
  }

  .news-hero__shell {
    margin-inline: auto;
    max-width: 55.625rem;
    position: relative;
    width: min(100%, calc(100vw - 12rem));
  }

  .news-hero__line {
    background: linear-gradient(180deg, rgba(196, 156, 110, 0.6), rgba(196, 156, 110, 0));
    height: 5rem;
    left: 0;
    position: absolute;
    top: -6rem;
    width: 1px;
  }

  .news-hero__eyebrow {
    color: #c49c6e;
    font-size: 0.6875rem;
    letter-spacing: 0.26em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-hero__title {
    color: #f5f0e8;
    display: grid;
    font-size: clamp(2.8rem, 7.2vw, 4.8rem);
    line-height: 1.04;
    margin: 2.6rem 0 1.75rem;
  }

  .news-hero__title .is-accent {
    color: #c49c6e;
    font-style: italic;
  }

  .news-hero__lead {
    color: rgba(245, 240, 232, 0.6);
    font-size: clamp(1rem, 1.55vw, 1.125rem);
    line-height: 1.625;
    margin: 0;
    max-width: 36rem;
  }

  .news-hero__stats {
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    gap: 2rem;
    margin-top: 4rem;
    padding-top: 2rem;
  }

  .news-hero__stat {
    align-items: baseline;
    display: inline-flex;
    gap: 0.7rem;
    position: relative;
  }

  .news-hero__stat + .news-hero__stat::before {
    background: rgba(255, 255, 255, 0.18);
    content: "";
    height: 1.5rem;
    left: -1rem;
    position: absolute;
    top: 0.25rem;
    width: 1px;
  }

  .news-hero__stat strong {
    color: #c49c6e;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
  }

  .news-hero__stat span {
    color: rgba(255, 255, 255, 0.32);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .news-hero__updated {
    color: rgba(255, 255, 255, 0.22);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    margin: 0 0 0 0.2rem;
    text-transform: uppercase;
  }

  .news-hero__year {
    color: rgba(255, 255, 255, 0.03);
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 15rem);
    line-height: 1;
    margin: 0;
    position: absolute;
    right: -8rem;
    top: 2.5rem;
  }

  @media (max-width: 63.9375em) {
    .news-hero {
      min-height: auto;
      padding-bottom: 6rem;
      padding-top: calc(var(--header-height) + 6rem);
    }

    .news-hero__shell {
      width: min(100%, calc(100vw - 4rem));
    }

    .news-hero__year {
      right: -2rem;
      top: 6rem;
    }
  }

  @media (max-width: 47.9375em) {
    .news-hero {
      padding-bottom: 4.25rem;
      padding-top: calc(var(--header-height) + 4.2rem);
    }

    .news-hero__shell {
      width: min(100%, calc(100vw - 2.5rem));
    }

    .news-hero__stats {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 1rem 1.4rem;
      margin-top: 2.4rem;
      padding-top: 1.4rem;
    }

    .news-hero__stat + .news-hero__stat::before {
      display: none;
    }

    .news-hero__year {
      display: none;
    }
  }
</style>

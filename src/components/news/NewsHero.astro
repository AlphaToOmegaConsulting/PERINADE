---
import { Image } from "astro:assets";
import type { NewsPageData } from "../../types/news";
import ActionLink from "../ui/actions/ActionLink.astro";

interface Props {
  hero: NewsPageData["hero"];
}

const { hero } = Astro.props;
---

<section class="news-hero section" aria-labelledby="news-hero-title">
  <div class="shell news-hero__shell">
    <div class="news-hero__content" data-reveal-group data-reveal-stagger="85">
      <p class="news-hero__eyebrow" data-reveal="up">{hero.eyebrow}</p>
      <h1 id="news-hero-title" data-reveal="up">
        {hero.titleLines[0]}
        <span>{hero.titleLines[1]}</span>
      </h1>
      <p class="news-hero__lead" data-reveal="up">{hero.lead}</p>

      <div class="news-hero__actions" data-reveal="up">
        <ActionLink
          href={hero.primaryCta.href}
          label={hero.primaryCta.label}
          variant="primary"
          size="lg"
          interaction="emphasis"
        />
      </div>

      <ul class="news-hero__meta" data-reveal-group data-reveal-stagger="55">
        {hero.metaItems.map((item) => (
          <li data-reveal="up">{item}</li>
        ))}
      </ul>
    </div>

    <figure class="news-hero__media ui-hover-media" data-reveal="zoom">
      <Image src={hero.image} alt={hero.imageAlt} loading="eager" />
    </figure>
  </div>
</section>

<style>
  .news-hero {
    background: radial-gradient(circle at 75% 25%, rgba(196, 156, 110, 0.13), transparent 45%), #1a1a1a;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--color-white);
    padding-top: calc(var(--header-height) + clamp(1rem, 4vw, 2rem));
  }

  .news-hero__shell {
    align-items: center;
    display: grid;
    gap: clamp(1.8rem, 5vw, 3.75rem);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .news-hero__content {
    max-width: 34rem;
  }

  .news-hero__eyebrow {
    color: var(--color-accent-text);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-hero__content h1 {
    color: var(--color-white);
    font-size: clamp(2.8rem, 6vw, 4.6rem);
    line-height: 0.98;
    margin: 0.9rem 0 0;
  }

  .news-hero__content h1 span {
    color: var(--color-accent-text);
    display: block;
  }

  .news-hero__lead {
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.06rem;
    line-height: 1.62;
    margin: 1.3rem 0 0;
  }

  .news-hero__actions {
    margin-top: 1.9rem;
  }

  .news-hero__actions :global(.ui-action--primary) {
    --action-primary-bg: var(--color-accent);
    --action-primary-bg-hover: color-mix(in srgb, var(--color-accent) 82%, black);
    --action-primary-border: var(--color-accent);
    --action-primary-shadow: none;
  }

  .news-hero__meta {
    color: rgba(255, 255, 255, 0.54);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.2rem;
    list-style: none;
    margin: 1.4rem 0 0;
    padding: 0;
  }

  .news-hero__meta li {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .news-hero__meta li::before {
    content: "•";
    margin-right: 0.45rem;
  }

  .news-hero__media {
    border-radius: 1.75rem;
    box-shadow: 0 1.875rem 4.5rem rgba(0, 0, 0, 0.35);
    margin: 0;
    overflow: hidden;
  }

  .news-hero__media :global(img) {
    aspect-ratio: 4 / 5;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  @media (max-width: 63.9375em) {
    .news-hero {
      padding-top: calc(var(--header-height) + clamp(0.9rem, 3vw, 1.5rem));
    }

    .news-hero__shell {
      grid-template-columns: 1fr;
    }

    .news-hero__content {
      max-width: 100%;
    }

    .news-hero__media {
      max-width: clamp(24rem, 80vw, 38rem);
      width: 100%;
    }
  }

  @media (max-width: 47.9375em) {
    .news-hero__lead {
      font-size: 1rem;
    }

    .news-hero__actions :global(.ui-action) {
      width: 100%;
    }

    .news-hero__meta {
      gap: 0.45rem 0.85rem;
    }

    .news-hero__meta li {
      font-size: 0.72rem;
    }
  }
</style>

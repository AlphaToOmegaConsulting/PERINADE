---
import type { NewsPageData } from "../../types/news";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  agenda: NewsPageData["agenda"];
}

const { agenda } = Astro.props;
---

<section class="news-agenda section">
  <div class="shell news-agenda__shell">
    <header class="news-agenda__header">
      <SectionHeading eyebrow={agenda.eyebrow} title={agenda.title} class="news-agenda__heading" />
      <a href={agenda.viewAllHref} class="news-agenda__view-all" data-reveal="up">{agenda.viewAllLabel}</a>
    </header>

    <div class="news-agenda__list" data-reveal-group data-reveal-stagger="60">
      {agenda.events.map((event) => (
        <article class="news-agenda__event" data-reveal="up">
          <div class="news-agenda__date">
            <strong>{event.day}</strong>
            <span>{event.month}</span>
          </div>
          <div class="news-agenda__content">
            <p class="news-agenda__type">{event.type}</p>
            <h3>
              <a href={event.href}>{event.title}</a>
            </h3>
            <p class="news-agenda__details">
              <span>{event.time}</span>
              <span>{event.location}</span>
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .news-agenda {
    background: #1a1a1a;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: #f5f0e8;
  }

  .news-agenda__shell {
    max-width: 74rem;
  }

  .news-agenda__header {
    align-items: end;
    display: flex;
    justify-content: space-between;
    margin-bottom: 2.2rem;
  }

  .news-agenda__heading :global(.section-heading__title) {
    color: var(--color-white);
    font-size: clamp(1.95rem, 3.6vw, 2.85rem);
  }

  .news-agenda__heading :global(.section-heading__eyebrow) {
    color: var(--color-accent-text);
  }

  .news-agenda__view-all {
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--motion-duration-sm) var(--motion-ease-standard);
  }

  .news-agenda__view-all::after {
    content: "  →";
  }

  .news-agenda__view-all:hover,
  .news-agenda__view-all:focus-visible {
    color: var(--color-accent-text);
  }

  .news-agenda__list {
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }

  .news-agenda__event {
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    display: grid;
    gap: 1.4rem;
    grid-template-columns: 6.5rem 1fr;
    padding: 1.4rem 0;
  }

  .news-agenda__date {
    display: grid;
    gap: 0.25rem;
  }

  .news-agenda__date strong {
    color: var(--color-accent-text);
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 500;
    line-height: 1;
  }

  .news-agenda__date span {
    color: rgba(255, 255, 255, 0.38);
    font-size: 0.67rem;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .news-agenda__content {
    display: grid;
    gap: 0.55rem;
  }

  .news-agenda__type {
    color: rgba(196, 156, 110, 0.84);
    font-size: 0.67rem;
    letter-spacing: 0.21em;
    margin: 0;
    text-transform: uppercase;
  }

  .news-agenda__content h3 {
    color: var(--color-white);
    font-size: 1.16rem;
    line-height: 1.35;
    margin: 0;
  }

  .news-agenda__content h3 a {
    color: inherit;
    text-decoration: none;
  }

  .news-agenda__details {
    color: rgba(255, 255, 255, 0.52);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.78rem;
    gap: 0.75rem;
    margin: 0;
  }

  .news-agenda__details span + span::before {
    content: "·";
    margin-right: 0.75rem;
  }

  @media (max-width: 63.9375em) {
    .news-agenda__header {
      align-items: start;
      flex-direction: column;
      gap: 1rem;
    }

    .news-agenda__event {
      grid-template-columns: 1fr;
    }
  }
</style>

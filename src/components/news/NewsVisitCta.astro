---
import type { NewsPageData } from "../../types/news";
import CtaBandSection from "../patterns/CtaBandSection.astro";

interface Props {
  visitCta: NewsPageData["visitCta"];
}

const { visitCta } = Astro.props;
---

<section class="news-visit-cta section">
  <div class="shell news-visit-cta__shell" data-reveal-group data-reveal-stagger="70">
    <CtaBandSection
      class="news-visit-cta__panel"
      tone="inverse"
      eyebrow={visitCta.eyebrow}
      title={visitCta.titleLines[0]}
      titleHighlight={visitCta.titleLines[1]}
      body={visitCta.body}
      actions={[{ label: visitCta.ctaLabel, href: visitCta.ctaHref, variant: "primary" }]}
      image={visitCta.backgroundImage}
      imageAlt={visitCta.backgroundAlt}
    />
  </div>
</section>

<style>
  .news-visit-cta {
    background: #1a1a1a;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .news-visit-cta__shell {
    max-width: 74rem;
  }

  .news-visit-cta :global(.news-visit-cta__panel) {
    align-items: stretch;
    gap: clamp(1.1rem, 2.8vw, 2rem);
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-pattern-cta-band__media) {
    border-radius: 1.25rem;
    margin: 0;
    min-height: clamp(14rem, 27vw, 20rem);
    overflow: hidden;
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-pattern-cta-band__media img) {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-pattern-cta-band__content) {
    align-content: center;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1.25rem;
    padding: clamp(1.2rem, 3vw, 2rem);
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-pattern-cta-band__eyebrow) {
    color: var(--color-accent-text);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-pattern-cta-band__title) {
    color: var(--color-white);
    font-size: clamp(1.8rem, 3.2vw, 2.75rem);
    line-height: 1.08;
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-pattern-cta-band__title span) {
    color: var(--color-accent-text);
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-pattern-cta-band__body) {
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.7;
    max-width: 32rem;
  }

  .news-visit-cta :global(.news-visit-cta__panel .ui-action--primary) {
    --action-primary-bg: var(--color-accent);
    --action-primary-bg-hover: color-mix(in srgb, var(--color-accent) 82%, black);
    --action-primary-border: var(--color-accent);
    --action-primary-shadow: none;

    min-height: 3rem;
    padding-inline: 1.6rem;
  }

  @media (max-width: 47.9375em) {
    .news-visit-cta :global(.news-visit-cta__panel .ui-action) {
      width: 100%;
    }
  }
</style>

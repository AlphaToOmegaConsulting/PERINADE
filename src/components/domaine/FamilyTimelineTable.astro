---
import { Image } from "astro:assets";
import type { DomaineTimelineData } from "../../types/domaine";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  timeline: DomaineTimelineData;
}

const { timeline } = Astro.props;
---

<section class="timeline section section--white">
  <div class="shell">
    <SectionHeading eyebrow={timeline.eyebrow} title={timeline.title} class="timeline__heading" />

    <div class="timeline-tabs" data-tabs data-tabs-activation="manual" data-reveal="up">
      <div class="timeline-tabs__left" role="tablist" aria-label="Chronologie du domaine">
        {timeline.tabs.map((tab) => {
          const isActive = tab.id === timeline.defaultTabId;
          return (
            <button
              type="button"
              class:list={["timeline-tab", isActive && "is-active"]}
              role="tab"
              aria-selected={isActive ? "true" : "false"}
              aria-controls={`timeline-panel-${tab.id}`}
              id={`timeline-tab-${tab.id}`}
              tabindex={isActive ? "0" : "-1"}
              data-tab-id={tab.id}
            >
              {tab.tabLabel}
            </button>
          );
        })}
      </div>

      <div class="timeline-tabs__right">
        {timeline.tabs.map((tab) => {
          const isActive = tab.id === timeline.defaultTabId;
          return (
            <article
              class:list={["timeline-panel", isActive && "is-active"]}
              id={`timeline-panel-${tab.id}`}
              role="tabpanel"
              aria-labelledby={`timeline-tab-${tab.id}`}
              data-panel-id={tab.id}
              hidden={!isActive}
              data-reveal="up"
            >
              <header class="timeline-panel__head">
                <h3>{tab.title}</h3>
                <p>{tab.detail}</p>
              </header>

              <div class="timeline-panel__media-grid">
                {tab.images.map((image) => (
                  <figure>
                    <Image src={image.src} alt={image.alt} loading="lazy" />
                  </figure>
                ))}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .timeline__heading {
    margin-bottom: clamp(0.9rem, 2.8vw, 1.35rem);
  }

  .timeline-tabs {
    background: var(--color-soft);
    border: 1px solid rgba(44, 44, 44, 0.09);
    border-radius: clamp(0.75rem, 1.8vw, 0.9rem);
    display: grid;
    grid-template-columns: clamp(4.8rem, 9vw, 5.8rem) minmax(0, 1fr);
    overflow: hidden;
  }

  .timeline-tabs__left {
    background: rgba(255, 255, 255, 0.35);
    border-right: 1px solid rgba(44, 44, 44, 0.09);
    display: grid;
    grid-auto-rows: minmax(clamp(2.8rem, 6vw, 3.4rem), auto);
  }

  .timeline-tab {
    background: transparent;
    border: 0;
    border-left: 0.125rem solid transparent;
    color: #a2a2a2;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: clamp(0.84rem, 2vw, 0.95rem);
    padding: clamp(0.72rem, 2vw, 1rem) clamp(0.45rem, 1.4vw, 0.65rem);
    text-align: left;
  }

  .timeline-tab:hover,
  .timeline-tab:focus-visible {
    color: var(--color-text-strong);
  }

  .timeline-tab:active {
    transform: scale(0.99);
  }

  .timeline-tab.is-active {
    background: #ece8e2;
    border-left-color: var(--color-accent);
    color: var(--color-text-strong);
    font-weight: 600;
  }

  .timeline-tabs__right {
    min-block-size: clamp(18rem, 40vw, 26rem);
  }

  .timeline-panel {
    display: grid;
    gap: var(--space-xs);
    padding: clamp(0.8rem, 2.6vw, 1.2rem);
  }

  .timeline-panel[hidden] {
    display: none;
  }

  .timeline-panel__head h3 {
    margin: 0;
  }

  .timeline-panel__head p {
    color: var(--color-muted);
    margin: clamp(0.24rem, 1vw, 0.45rem) 0 0;
    max-inline-size: clamp(20rem, 70vw, 44rem);
  }

  .timeline-panel__media-grid {
    display: grid;
    gap: var(--space-xs);
    grid-template-columns: 1.08fr 0.92fr;
  }

  .timeline-panel__media-grid figure {
    border-radius: 0.7rem;
    margin: 0;
    overflow: hidden;
  }

  .timeline-panel__media-grid img {
    aspect-ratio: 3/2;
    object-fit: cover;
    width: 100%;
  }

  @media (max-width: 63.9375em) {
    .timeline-tabs {
      grid-template-columns: 1fr;
    }

    .timeline-tabs__left {
      border-bottom: 1px solid rgba(44, 44, 44, 0.09);
      border-right: 0;
      display: flex;
      overflow-x: auto;
    }

    .timeline-tab {
      min-inline-size: clamp(4.2rem, 11vw, 5.2rem);
      text-align: center;
      white-space: nowrap;
    }

    .timeline-tab.is-active {
      border-bottom: 0.125rem solid var(--color-accent);
      border-left-color: transparent;
    }

    .timeline-tabs__right {
      min-height: 0;
    }
  }

  @media (max-width: 47.9375em) {
    .timeline-panel {
      padding: clamp(0.75rem, 3vw, 1rem);
    }

    .timeline-panel__media-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import ButtonLink from "../ui/ButtonLink.astro";
import type { DomaineContactData } from "../../types/domaine";
import { isPlaceholderLink } from "../../utils/link";

interface Props {
  contact: DomaineContactData;
}

const { contact } = Astro.props;
---

<section class="domain-contact section section--soft" id="domaine-contact">
  <div class="shell">
    <header class="domain-contact__head" data-reveal="up">
      <p>{contact.eyebrow}</p>
      <h2>{contact.title}</h2>
      <p class="domain-contact__body">{contact.body}</p>
    </header>

    <div class="domain-contact__cards" data-reveal-group data-reveal-stagger="70">
      {contact.cards.map((card) => (
        <article class="domain-contact__card" data-reveal="up">
          <span class="domain-contact__icon" aria-hidden="true"></span>
          <p class="domain-contact__label">{card.label}</p>
          {
            card.href ? (
              <ButtonLink
                class="domain-contact__value-link"
                href={card.href}
                label={card.value}
                variant="text"
                disabled={isPlaceholderLink(card.href)}
              />
            ) : (
              <p class="domain-contact__value">{card.value}</p>
            )
          }
        </article>
      ))}
    </div>

    <div class="domain-contact__cta" data-reveal="up">
      <ButtonLink href={contact.cta.href} label={contact.cta.label} variant="primary" size="lg" interaction="emphasis" />
    </div>
  </div>
</section>

<style>
  .domain-contact {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0%, rgba(255, 255, 255, 0.16) 100%);
    border-block: 1px solid rgba(44, 44, 44, 0.06);
  }

  .domain-contact__head {
    display: grid;
    gap: 0.75rem;
    margin-inline: auto;
    max-width: 44rem;
    text-align: center;
  }

  .domain-contact__head > p:first-child {
    color: var(--color-accent-text);
    font-size: 0.82rem;
    letter-spacing: 0.2em;
    margin: 0;
    text-transform: uppercase;
  }

  .domain-contact__head h2 {
    margin: 0;
  }

  .domain-contact__body {
    color: var(--color-muted);
    font-size: 1.02rem;
    line-height: 1.7;
    margin: 0 auto;
    max-width: 40rem;
  }

  .domain-contact__cards {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 2rem;
  }

  .domain-contact__card {
    align-items: start;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 0.9rem;
    display: grid;
    gap: 0.5rem;
    justify-items: start;
    padding: 1.5rem 1.25rem;
    text-align: left;
    transition:
      border-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms ease;
  }

  .domain-contact__card:hover,
  .domain-contact__card:focus-within {
    border-color: rgba(196, 156, 110, 0.45);
    box-shadow: 0 10px 24px rgba(18, 18, 18, 0.04);
    transform: translateY(-1px);
  }

  .domain-contact__icon {
    background: rgba(196, 156, 110, 0.22);
    border-radius: 999px;
    display: inline-flex;
    height: 0.7rem;
    margin-bottom: 0.3rem;
    place-items: center;
    width: 0.7rem;
  }

  .domain-contact__label {
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    margin: 0;
    text-transform: uppercase;
  }

  .domain-contact__value {
    color: var(--color-text-strong);
    font-size: 1rem;
    line-height: 1.5;
    margin: 0.5rem 0 0;
  }

  :global(.domain-contact__value-link) {
    --action-text-color: var(--color-text-strong);
    --action-text-color-hover: var(--color-text-strong);
    --action-text-underline: rgba(196, 156, 110, 0.4);

    font-size: 0.98rem;
    letter-spacing: 0;
    margin-top: 0.5rem;
    min-height: 2rem;
    text-transform: none;
  }

  .domain-contact__cta {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  @media (max-width: 1023px) {
    .domain-contact__cards {
      grid-template-columns: 1fr;
      margin-top: 1.4rem;
    }
  }
</style>

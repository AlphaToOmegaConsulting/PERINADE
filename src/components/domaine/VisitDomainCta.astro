---
import ButtonLink from "../ui/ButtonLink.astro";
import { Image } from "astro:assets";
import type { DomaineVisitCtaData } from "../../types/domaine";

interface Props {
  visitCta: DomaineVisitCtaData;
}

const { visitCta } = Astro.props;
---

<section class="visit-cta section">
  <div class="shell visit-cta__inner">
    <figure class="visit-cta__media ui-hover-media" data-reveal="left">
      <Image src={visitCta.image} alt={visitCta.imageAlt} loading="lazy" />
    </figure>

    <div class="visit-cta__content" data-reveal-group data-reveal-stagger="85">
      <p class="visit-cta__eyebrow" data-reveal="up">{visitCta.eyebrow}</p>
      <h2 class="visit-cta__title" data-reveal="up">
        <span class="visit-cta__title-main">{visitCta.title}</span>
        <span class="visit-cta__title-highlight">{visitCta.titleHighlight}</span>
      </h2>
      <p class="visit-cta__body" data-reveal="up">{visitCta.body}</p>

      <ul class="visit-cta__details" data-reveal-group data-reveal-stagger="55">
        {visitCta.details.map((detail) => (
          <li data-reveal="up">{detail}</li>
        ))}
      </ul>

      <div class="visit-cta__actions" data-reveal="up">
        <ButtonLink class="visit-cta__primary" href={visitCta.primaryCta.href} label={visitCta.primaryCta.label} variant="primary" size="lg" interaction="emphasis" />
        <ButtonLink
          class="visit-cta__ghost"
          href={visitCta.secondaryCta.href}
          label={visitCta.secondaryCta.label}
          variant="secondary"
          tone="inverse"
          size="lg"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .visit-cta {
    background: radial-gradient(circle at 15% 15%, rgba(255, 255, 255, 0.06), transparent 38%), #161616;
    color: var(--color-white);
  }

  .visit-cta__inner {
    align-items: center;
    display: grid;
    gap: 2.6rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  }

  .visit-cta__media {
    aspect-ratio: 3 / 2;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.9rem;
    margin: 0;
    overflow: hidden;
  }

  .visit-cta__media :global(picture) {
    display: block;
    height: 100%;
  }

  .visit-cta__media :global(img) {
    display: block;
    height: 100%;
    object-fit: cover;
    object-position: center;
    width: 100%;
  }

  .visit-cta__content {
    display: grid;
    gap: 0.85rem;
  }

  .visit-cta__eyebrow {
    color: var(--color-accent-text);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    margin: 0;
    text-transform: uppercase;
  }

  .visit-cta__title {
    display: grid;
    font-size: clamp(1.9rem, 3.2vw, 2.7rem);
    font-weight: 500;
    line-height: 1.05;
    margin: 0;
    text-wrap: balance;
  }

  .visit-cta__title-main {
    color: #f7f2ea;
    display: block;
  }

  .visit-cta__title-highlight {
    color: var(--color-cta);
    display: block;
  }

  .visit-cta__body {
    color: rgba(255, 255, 255, 0.84);
    margin: 0;
    max-width: 33rem;
  }

  .visit-cta__details {
    display: grid;
    gap: 0.55rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    list-style: none;
    margin: 0.35rem 0 0;
    padding: 0;
  }

  .visit-cta__details li {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.55rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.79rem;
    padding: 0.6rem 0.72rem;
  }

  .visit-cta__actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.35rem;
  }

  :global(.visit-cta__primary),
  :global(.visit-cta__ghost) {
    min-height: 3.4rem;
    padding-inline: 1.35rem;
  }

  :global(.visit-cta__primary) {
    --action-primary-shadow: none;
  }

  :global(.visit-cta__ghost) {
    --action-secondary-bg: transparent;
    --action-secondary-bg-hover: rgba(255, 255, 255, 0.1);
    --action-secondary-border: rgba(255, 255, 255, 0.3);
    --action-secondary-color: var(--color-white);
  }

  @media (max-width: 1023px) {
    .visit-cta__inner {
      grid-template-columns: 1fr;
    }

    .visit-cta__media {
      max-width: 32rem;
    }
  }

  @media (max-width: 767px) {
    .visit-cta__details {
      grid-template-columns: 1fr;
    }

    .visit-cta__actions {
      display: grid;
      width: 100%;
    }

    :global(.visit-cta__primary),
    :global(.visit-cta__ghost) {
      justify-content: center;
      width: 100%;
    }
  }
</style>

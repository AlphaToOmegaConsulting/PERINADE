---
import { Image } from "astro:assets";
import type { DomaineHeroData } from "../../types/domaine";
import { isPlaceholderLink } from "../../utils/link";

interface Props {
  hero: DomaineHeroData;
}

const { hero } = Astro.props;
---

<section class="domaine-hero section">
  <div class="shell domaine-hero__inner">
    <div class="domaine-hero__content">
      <p class="domaine-hero__eyebrow">{hero.eyebrow}</p>
      <h1 class="domaine-hero__title">
        <span>{hero.titleLines[0]}</span>
        <span class="is-accent">{hero.titleLines[1]}</span>
      </h1>
      <p class="domaine-hero__body">{hero.body}</p>

      <div class="domaine-hero__cta-row">
        {
          isPlaceholderLink(hero.primaryCta.href) ? (
            <span class="domaine-hero__cta-primary" data-todo={hero.primaryCta.href}>
              <span>{hero.primaryCta.label}</span>
            </span>
          ) : (
            <a class="domaine-hero__cta-primary" href={hero.primaryCta.href}>
              <span>{hero.primaryCta.label}</span>
            </a>
          )
        }
        {
          isPlaceholderLink(hero.secondaryCta.href) ? (
            <span class="domaine-hero__cta-secondary" data-todo={hero.secondaryCta.href}>{hero.secondaryCta.label}</span>
          ) : (
            <a class="domaine-hero__cta-secondary" href={hero.secondaryCta.href}>{hero.secondaryCta.label}</a>
          )
        }
      </div>

      <ul class="domaine-hero__badges" aria-label="Axes clés du domaine">
        {hero.badges.map((badge) => (
          <li>{badge}</li>
        ))}
      </ul>

      <ul class="domaine-hero__highlights" aria-label="Chiffres et repères clés">
        {hero.highlights.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <div class="domaine-hero__media">
      <Image src={hero.image} alt={hero.imageAlt} loading="eager" />
    </div>
  </div>
</section>

<style>
  .domaine-hero {
    background: radial-gradient(circle at 78% 26%, rgba(255, 255, 255, 0.06), transparent 42%), #161616;
    color: var(--color-white);
    padding-top: calc(var(--header-height) + clamp(3rem, 8vw, 5.6rem));
  }

  .domaine-hero__inner {
    align-items: center;
    display: grid;
    gap: var(--content-gap-lg);
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.82fr);
  }

  .domaine-hero__eyebrow {
    color: var(--color-accent);
    font-size: clamp(0.74rem, 1.9vw, 0.84rem);
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .domaine-hero__title {
    display: grid;
    font-size: clamp(2.2rem, 4.6vw, 3.85rem);
    letter-spacing: -0.025em;
    line-height: 0.95;
    margin: clamp(0.5rem, 1.8vw, 0.85rem) 0 clamp(0.8rem, 2.2vw, 1.15rem);
  }

  .domaine-hero__title .is-accent {
    color: var(--color-cta);
  }

  .domaine-hero__body {
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(0.94rem, 2vw, 1.04rem);
    line-height: 1.64;
    margin: 0;
    max-inline-size: clamp(20rem, 48vw, 36rem);
  }

  .domaine-hero__cta-row {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: clamp(1rem, 2.8vw, 1.7rem);
  }

  .domaine-hero__cta-primary {
    align-items: center;
    background: var(--color-cta);
    border-radius: 100vmax;
    color: var(--color-white);
    display: inline-flex;
    font-size: clamp(0.72rem, 1.8vw, 0.78rem);
    font-weight: 600;
    justify-content: center;
    line-height: 1;
    letter-spacing: 0.14em;
    box-shadow: 0 0.5rem 1.1rem rgba(214, 116, 0, 0.24);
    min-block-size: var(--control-height-md);
    padding-inline: clamp(1rem, 3.3vw, 1.55rem);
    text-decoration: none;
    text-transform: uppercase;
  }

  .domaine-hero__cta-secondary {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100vmax;
    color: var(--color-white);
    display: inline-flex;
    font-size: clamp(0.72rem, 1.8vw, 0.78rem);
    line-height: 1;
    letter-spacing: 0.12em;
    min-block-size: var(--control-height-md);
    padding-inline: clamp(0.95rem, 3vw, 1.45rem);
    text-transform: uppercase;
  }

  .domaine-hero__badges,
  .domaine-hero__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    list-style: none;
    margin: clamp(0.7rem, 2vw, 1.05rem) 0 0;
    padding: 0;
  }

  .domaine-hero__badges li,
  .domaine-hero__highlights li {
    border-radius: 100vmax;
    font-size: clamp(0.62rem, 1.5vw, 0.69rem);
    letter-spacing: 0.12em;
    padding: clamp(0.38rem, 1.3vw, 0.53rem) clamp(0.65rem, 2.2vw, 0.85rem);
    text-transform: uppercase;
  }

  .domaine-hero__badges li {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.84);
  }

  .domaine-hero__highlights li {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.72);
  }

  .domaine-hero__media {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    box-shadow: 0 1.5rem 3.25rem rgba(0, 0, 0, 0.32);
    overflow: hidden;
  }

  .domaine-hero__media img {
    aspect-ratio: 4/5;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  [data-todo] {
    cursor: not-allowed;
  }

  @media (max-width: 63.9375em) {
    .domaine-hero__inner {
      gap: clamp(1.4rem, 4vw, 2.4rem);
      grid-template-columns: 1fr;
    }

    .domaine-hero__media {
      max-inline-size: clamp(22rem, 72vw, 33rem);
    }
  }

  @media (max-width: 47.9375em) {
    .domaine-hero {
      padding-top: calc(var(--header-height) + clamp(2rem, 8vw, 4rem));
    }

    .domaine-hero__body {
      font-size: clamp(0.92rem, 3.8vw, 1rem);
    }

    .domaine-hero__cta-primary,
    .domaine-hero__cta-secondary {
      min-block-size: clamp(3rem, 10vw, 3.45rem);
      width: 100%;
    }
  }
</style>

---
import ActionLink from "../ui/actions/ActionLink.astro";
import { Image } from "astro:assets";
import type { DomaineWinesData } from "../../types/domaine";
import { isPlaceholderLink } from "../../utils/link";

interface Props {
  wines: DomaineWinesData;
}

const { wines } = Astro.props;
---

<section class="domain-wines section section--white">
  <div class="shell">
    <div class="domain-wines__head" data-reveal="up">
      <div>
        <p class="domain-wines__eyebrow">{wines.eyebrow}</p>
        <h2>{wines.title}</h2>
      </div>
      <ActionLink href={wines.allHref} label={wines.allLabel} variant="text" />
    </div>

    <div class="domain-wines__grid" data-reveal-group data-reveal-stagger="70">
      {wines.items.map((item) => (
        <article class="domain-wines__card ui-hover-lift" data-reveal="up">
          {isPlaceholderLink(item.ctaHref) ? (
            <div class="domain-wines__media ui-hover-media" aria-disabled="true">
              <Image src={item.image} alt={item.alt} loading="lazy" />
            </div>
          ) : (
            <a class="domain-wines__media ui-hover-media" href={item.ctaHref}>
              <Image src={item.image} alt={item.alt} loading="lazy" />
            </a>
          )}
          <div class="domain-wines__meta">{item.meta}</div>
          {isPlaceholderLink(item.ctaHref) ? <h3>{item.title}</h3> : <h3><a href={item.ctaHref}>{item.title}</a></h3>}
          <p>{item.body}</p>
          <div class="domain-wines__bottom">
            <strong>{item.price}</strong>
            <ActionLink href={item.ctaHref} label={item.ctaLabel} variant="primary" disabled={isPlaceholderLink(item.ctaHref)} />
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .domain-wines__head {
    align-items: end;
    display: flex;
    gap: 0.9rem;
    justify-content: space-between;
  }

  .domain-wines__eyebrow {
    color: var(--color-accent-text);
    font-size: 0.82rem;
    letter-spacing: 0.2em;
    margin: 0;
    text-transform: uppercase;
  }

  .domain-wines__head h2 {
    margin: 0.6rem 0 0;
  }

  .domain-wines__grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 1.2rem;
  }

  .domain-wines__card {
    background: #f8f6f3;
    border: 1px solid rgba(44, 44, 44, 0.08);
    border-radius: 0.8rem;
    display: grid;
    gap: 0.7rem;
    padding: 0.8rem 0.8rem 1rem;
  }

  .domain-wines__media {
    aspect-ratio: 1/1;
    border-radius: 0.7rem;
    display: block;
    overflow: hidden;
  }

  .domain-wines__card figure,
  .domain-wines__card a {
    border-radius: 0.7rem;
    margin: 0;
    overflow: hidden;
  }

  .domain-wines__card img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .domain-wines__meta {
    color: var(--color-muted);
    font-size: 0.67rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .domain-wines__card h3 {
    font-size: 1.08rem;
    margin: 0;
  }

  .domain-wines__card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .domain-wines__card p {
    color: var(--color-muted);
    font-size: 0.94rem;
    margin: 0;
  }

  .domain-wines__bottom {
    align-items: center;
    display: flex;
    justify-content: space-between;
  }

  .domain-wines__bottom strong {
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 500;
  }

  @media (max-width: 1023px) {
    .domain-wines__grid {
      grid-template-columns: 1fr;
    }

    .domain-wines__card img {
      height: auto;
    }

    .domain-wines__media {
      aspect-ratio: 16/10;
    }
  }

  @media (max-width: 767px) {
    .domain-wines__head {
      align-items: start;
      flex-direction: column;
    }
  }

</style>

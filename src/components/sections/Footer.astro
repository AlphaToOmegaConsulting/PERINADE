---
import type { SiteData } from "../../types/site";

interface Props {
  footer: SiteData["footer"];
}

const { footer } = Astro.props;

function isPlaceholder(href: string) {
  return href.startsWith("TODO_");
}

function socialSvg(label: string) {
  if (label === "Instagram") {
    return `<svg viewBox="0 0 24 24" fill="none"><rect x="4.5" y="4.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.7"></rect><circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.7"></circle><circle cx="17" cy="7.3" r="1" fill="currentColor"></circle></svg>`;
  }
  return `<svg viewBox="0 0 24 24" fill="none"><path d="M14.3 8H16V5.2c-.3 0-.9-.2-2-.2-2.1 0-3.5 1.3-3.5 3.8V11H8v3h2.5v5H14v-5h2.6l.4-3H14V9.2c0-.9.2-1.2 1.3-1.2Z" fill="currentColor"></path></svg>`;
}
---

<footer class="footer">
  <div class="shell shell--narrow footer__top">
    <div class="footer__brand">
      <h2>{footer.brandTitle}</h2>
      <p>{footer.about}</p>
    </div>

    {footer.groups.map((group) => (
      <div class="footer__group">
        <h3>{group.title}</h3>
        <ul>
          {group.links.map((link) => (
            <li>
              {isPlaceholder(link.href) ? (
                <span data-todo={link.href}>{link.label}</span>
              ) : (
                <a href={link.href}>{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="footer__newsletter">
      <h3>{footer.newsletterTitle}</h3>
      <p>{footer.newsletterBody}</p>
      <form data-ui-form>
        <input type="email" placeholder={footer.newsletterPlaceholder} />
        <button type="submit">OK</button>
      </form>
      <div class="footer__social">
        {footer.social.map((item) => (
          isPlaceholder(item.href) ? (
            <span class="footer__social-link" data-todo={item.href} aria-label={item.label} set:html={socialSvg(item.label)}></span>
          ) : (
            <a class="footer__social-link" href={item.href} aria-label={item.label} set:html={socialSvg(item.label)}></a>
          )
        ))}
      </div>
    </div>
  </div>

  <div class="shell shell--narrow footer__bottom">
    <p>{footer.copyright}</p>
    <p>{footer.legalLine}</p>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll("[data-ui-form]").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
    });
  });
</script>

<style>
  .footer {
    background: #1a1a1a;
    color: rgba(255, 255, 255, 0.6);
    padding: 5.4rem 0 2rem;
  }

  .footer__top {
    display: grid;
    gap: 3.5rem;
    grid-template-columns: 1.1fr 1fr 1fr 1fr;
  }

  .footer__brand h2 {
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.15em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .footer__brand p,
  .footer__newsletter p {
    line-height: 1.65;
    margin: 0;
  }

  .footer__group h3,
  .footer__newsletter h3 {
    color: var(--color-white);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    margin: 0 0 1.35rem;
    text-transform: uppercase;
  }

  .footer__group ul {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__group a,
  .footer__group span[data-todo] {
    color: rgba(255, 255, 255, 0.62);
  }

  .footer__newsletter form {
    display: grid;
    grid-template-columns: 1fr auto;
    margin-top: 1.15rem;
  }

  .footer__newsletter input {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem 0 0 0.5rem;
    color: var(--color-white);
    font: inherit;
    min-height: 2.95rem;
    padding: 0 1rem;
  }

  .footer__newsletter button {
    background: var(--color-accent);
    border: 0;
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-white);
    font: inherit;
    min-width: 3.25rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .footer__social-link {
    color: var(--color-white);
    display: inline-flex;
    height: 1.4rem;
    width: 1.4rem;
  }

  .footer__bottom {
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    font-size: 0.875rem;
    gap: 1rem;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 1.5rem;
  }

  .footer__bottom p {
    margin: 0;
  }

  [data-todo] {
    cursor: not-allowed;
  }

  @media (max-width: 1023px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }

    .footer__bottom {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 767px) {
    .footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>

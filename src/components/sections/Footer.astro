---
import type { SiteData } from "../../types/site";
import Icon from "../ui/Icon.astro";
import { isPlaceholderLink } from "../../utils/link";
import ActionLink from "../ui/actions/ActionLink.astro";
import SubmitButton from "../ui/actions/SubmitButton.astro";
import NavLink from "../ui/navigation/NavLink.astro";

interface Props {
  footer: SiteData["footer"];
}

const { footer } = Astro.props;
---

<footer class="footer">
  <div class="shell shell--narrow footer__top">
    <div class="footer__brand">
      <h2>{footer.brandTitle}</h2>
      <p>{footer.about}</p>
    </div>

    {footer.groups.map((group) => (
      <div class="footer__group">
        <h3>{group.title}</h3>
        <ul>
          {group.links.map((link) => (
            <li>
              {isPlaceholderLink(link.href) ? (
                <ActionLink label={link.label} href={link.href} variant="text" disabled class="footer__group-link" />
              ) : (
                <NavLink href={link.href} label={link.label} navKind="footer" tone="inverse" class="footer__group-link" />
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="footer__newsletter">
      <h3>{footer.newsletterTitle}</h3>
      <p>{footer.newsletterBody}</p>
      <p class="footer__newsletter-adult">{footer.newsletterAdultNotice}</p>
      <form data-ui-form>
        <input type="email" name="email" inputmode="email" autocomplete="email" placeholder={footer.newsletterPlaceholder} required />
        <SubmitButton class="footer__newsletter-submit" label="OK" variant="primary" size="sm" />
      </form>
      <div class="footer__social">
        {footer.social.map((item) => (
          isPlaceholderLink(item.href) ? (
            <button class="footer__social-link" type="button" aria-label={item.label} disabled>
              <span class="footer__social-icon">
                <Icon name={item.label.toLowerCase() === "instagram" ? "instagram" : "facebook"} />
              </span>
            </button>
          ) : (
            <a class="footer__social-link" href={item.href} aria-label={item.label} target="_blank" rel="noreferrer">
              <span class="footer__social-icon">
                <Icon name={item.label.toLowerCase() === "instagram" ? "instagram" : "facebook"} />
              </span>
            </a>
          )
        ))}
      </div>
    </div>
  </div>

  <div class="shell shell--narrow footer__bottom">
    <p>{footer.copyright}</p>
    <p>{footer.legalLine}</p>
  </div>
</footer>

<style>
  .footer {
    background: #1a1a1a;
    color: rgba(255, 255, 255, 0.6);
    padding: 5.4rem 0 2rem;
  }

  .footer__top {
    display: grid;
    gap: 4rem;
    grid-template-columns: 1.1fr 1fr 1fr 1fr;
  }

  .footer__brand h2 {
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.15em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .footer__brand p,
  .footer__newsletter p {
    line-height: 1.75;
    margin: 0;
  }

  .footer__newsletter-adult {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.84rem;
    margin-top: 0.55rem;
  }

  .footer__group h3,
  .footer__newsletter h3 {
    color: var(--color-white);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    margin: 0 0 1.35rem;
    text-transform: uppercase;
  }

  .footer__group ul {
    display: grid;
    gap: 0.9rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__group :global(.footer__group-link) {
    --action-text-color: rgba(255, 255, 255, 0.62);
    --action-text-color-hover: rgba(255, 255, 255, 0.9);
    --action-text-underline: rgba(255, 255, 255, 0.24);

    font-size: 0.95rem;
    letter-spacing: 0;
    padding-bottom: 0.1rem;
    text-transform: none;
  }

  .footer__group :global(.footer__group-link):disabled {
    color: rgba(255, 255, 255, 0.62);
  }

  .footer__newsletter form {
    display: grid;
    grid-template-columns: 1fr auto;
    margin-top: 1.15rem;
  }

  .footer__newsletter input {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem 0 0 0.5rem;
    color: var(--color-white);
    font: inherit;
    min-height: 3rem;
    padding: 0 1rem;
  }

  .footer__newsletter :global(.footer__newsletter-submit) {
    --action-primary-bg: var(--color-accent);
    --action-primary-bg-hover: color-mix(in srgb, var(--color-accent) 82%, black);
    --action-primary-border: var(--color-accent);
    --action-primary-shadow: none;

    border-radius: 0 0.5rem 0.5rem 0;
    min-height: 3rem;
    min-width: 3.25rem;
    padding-inline: 0.8rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .footer__social-link {
    background: transparent;
    border: 0;
    color: var(--color-white);
    display: inline-flex;
    min-height: 2.75rem;
    min-width: 2.75rem;
    justify-content: center;
    align-items: center;
    padding: 0;
  }

  .footer__social-link:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .footer__social-icon :global(svg) {
    width: 1.4rem;
    height: 1.4rem;
  }

  .footer__bottom {
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    font-size: 0.875rem;
    gap: 1rem;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 1.5rem;
  }

  .footer__bottom p {
    margin: 0;
  }

  @media (max-width: 1023px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }

    .footer__bottom {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 767px) {
    .footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import type { SiteData } from "../../types/site";
import Icon from "../ui/Icon.astro";
import { isPlaceholderLink } from "../../utils/link";

interface Props {
  footer: SiteData["footer"];
}

const { footer } = Astro.props;
---

<footer class="footer">
  <div class="shell shell--narrow footer__top">
    <div class="footer__brand">
      <h2>{footer.brandTitle}</h2>
      <p>{footer.about}</p>
    </div>

    {footer.groups.map((group) => (
      <div class="footer__group">
        <h3>{group.title}</h3>
        <ul>
          {group.links.map((link) => (
            <li>
              {isPlaceholderLink(link.href) ? (
                <span data-todo={link.href}>{link.label}</span>
              ) : (
                <a href={link.href}>{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="footer__newsletter">
      <h3>{footer.newsletterTitle}</h3>
      <p>{footer.newsletterBody}</p>
      <form data-ui-form>
        <input type="email" placeholder={footer.newsletterPlaceholder} />
        <button type="submit">OK</button>
      </form>
      <div class="footer__social">
        {footer.social.map((item) => (
          isPlaceholderLink(item.href) ? (
            <span class="footer__social-link" data-todo={item.href} aria-label={item.label}>
              <Icon name={item.label.toLowerCase() === "instagram" ? "instagram" : "facebook"} class="footer__social-icon" />
            </span>
          ) : (
            <a class="footer__social-link" href={item.href} aria-label={item.label}>
              <Icon name={item.label.toLowerCase() === "instagram" ? "instagram" : "facebook"} class="footer__social-icon" />
            </a>
          )
        ))}
      </div>
    </div>
  </div>

  <div class="shell shell--narrow footer__bottom">
    <p>{footer.copyright}</p>
    <p>{footer.legalLine}</p>
  </div>
</footer>

<style>
  .footer {
    background: #1a1a1a;
    color: rgba(255, 255, 255, 0.6);
    padding: 5.4rem 0 2rem;
  }

  .footer__top {
    display: grid;
    gap: 3.5rem;
    grid-template-columns: 1.1fr 1fr 1fr 1fr;
  }

  .footer__brand h2 {
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.15em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .footer__brand p,
  .footer__newsletter p {
    line-height: 1.65;
    margin: 0;
  }

  .footer__group h3,
  .footer__newsletter h3 {
    color: var(--color-white);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    margin: 0 0 1.35rem;
    text-transform: uppercase;
  }

  .footer__group ul {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__group a,
  .footer__group span[data-todo] {
    color: rgba(255, 255, 255, 0.62);
  }

  .footer__newsletter form {
    display: grid;
    grid-template-columns: 1fr auto;
    margin-top: 1.15rem;
  }

  .footer__newsletter input {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem 0 0 0.5rem;
    color: var(--color-white);
    font: inherit;
    min-height: 2.95rem;
    padding: 0 1rem;
  }

  .footer__newsletter button {
    background: var(--color-accent);
    border: 0;
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-white);
    font: inherit;
    min-width: 3.25rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .footer__social-link {
    color: var(--color-white);
    display: inline-flex;
    height: 1.4rem;
    justify-content: center;
    align-items: center;
    width: 1.4rem;
  }

  .footer__social-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .footer__bottom {
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    font-size: 0.875rem;
    gap: 1rem;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 1.5rem;
  }

  .footer__bottom p {
    margin: 0;
  }

  [data-todo] {
    cursor: not-allowed;
  }

  @media (max-width: 1023px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }

    .footer__bottom {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 767px) {
    .footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>

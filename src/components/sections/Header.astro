---
import type { NavItem } from "../../types/site";
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
  nav: NavItem[];
  ctaLabel: string;
  ctaHref: string;
}

const { nav, ctaLabel, ctaHref } = Astro.props;

const leftNav = nav.filter((item) => item.desktopSlot === "left");
const rightNav = nav.filter((item) => item.desktopSlot === "right");
const mobileNav = nav.filter((item) => item.mobile !== false);
---

<header class="site-header" data-header>
  <div class="site-header__fade" aria-hidden="true"></div>
  <nav class="shell site-header__nav" aria-label="Navigation principale">
    <div class="site-header__group site-header__group--left">
      {leftNav.map((item) => (
        <a class="site-header__link" href={item.href}>
          {item.desktopLabel ?? item.label}
        </a>
      ))}
    </div>

    <a class="site-header__brand" href="/" aria-label="Accueil">
      <img src="/assets/perinade/logo.png" alt="" width="80" height="80" loading="eager" />
    </a>

    <div class="site-header__group site-header__group--right">
      {rightNav.map((item) => (
        <a class="site-header__link" href={item.href}>
          {item.desktopLabel ?? item.label}
        </a>
      ))}
      <ButtonLink href={ctaHref} label={ctaLabel} class="site-header__cta" />
    </div>

    <button class="site-header__toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" data-menu-toggle>
      <span></span>
      <span></span>
      <span></span>
      <span class="sr-only">Ouvrir le menu</span>
    </button>
  </nav>

  <div class="site-header__mobile" id="mobile-nav" data-mobile-nav hidden>
    <div class="shell site-header__mobile-inner">
      {mobileNav.map((item) => (
        <a class="site-header__mobile-link" href={item.href}>{item.label}</a>
      ))}
      <ButtonLink href={ctaHref} label={ctaLabel} class="site-header__mobile-cta" />
    </div>
  </div>
</header>

<script is:inline>
  const header = document.querySelector("[data-header]");
  const toggle = document.querySelector("[data-menu-toggle]");
  const mobileNav = document.querySelector("[data-mobile-nav]");

  const syncHeader = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 48);
  };

  syncHeader();
  window.addEventListener("scroll", syncHeader, { passive: true });

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    mobileNav.hidden = isOpen;
    header?.classList.toggle("is-open", !isOpen);
  });

  mobileNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.setAttribute("aria-expanded", "false");
      mobileNav.hidden = true;
      header?.classList.remove("is-open");
    });
  });
</script>

<style>
  .site-header {
    left: 0;
    position: fixed;
    right: 0;
    top: 0;
    transition: background 180ms ease, box-shadow 180ms ease, backdrop-filter 180ms ease;
    z-index: 50;
  }

  .site-header.is-scrolled,
  .site-header.is-open {
    backdrop-filter: blur(14px);
    background: rgba(15, 15, 15, 0.9);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
  }

  .site-header__fade {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 100%);
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .site-header.is-scrolled .site-header__fade,
  .site-header.is-open .site-header__fade {
    opacity: 0;
  }

  .site-header__nav {
    align-items: center;
    display: grid;
    grid-template-columns:
      minmax(0, 1fr)
      auto
      clamp(4.2rem, 8vw, 8.2rem)
      auto
      clamp(4.2rem, 8vw, 8.2rem)
      auto
      minmax(0, 1fr);
    height: var(--header-height);
    position: relative;
  }

  .site-header__group {
    align-items: center;
    display: flex;
    white-space: nowrap;
  }

  .site-header__group--left {
    grid-column: 2;
    gap: clamp(3rem, 5.2vw, 5.2rem);
    justify-self: end;
  }

  .site-header__group--right {
    align-items: center;
    gap: clamp(2.6rem, 4.4vw, 4.2rem);
    grid-column: 6;
    justify-self: start;
  }

  .site-header__link {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .site-header__link:hover {
    color: var(--color-white);
  }

  .site-header__brand {
    align-items: center;
    color: var(--color-white);
    display: inline-flex;
    grid-column: 4;
    height: 5rem;
    justify-items: center;
    justify-self: center;
    overflow: hidden;
    text-align: center;
    width: 5rem;
  }

  .site-header__brand img {
    height: 5rem;
    object-fit: contain;
    transform: scale(1.3);
    transform-origin: center;
    width: 5rem;
  }

  .site-header__cta {
    min-height: 2.6rem;
    padding-inline: 1rem;
  }

  .site-header__toggle,
  .site-header__mobile {
    display: none;
  }

  .site-header__toggle {
    background: transparent;
    border: 0;
    justify-self: end;
    padding: 0.5rem;
  }

  .site-header__toggle span:not(.sr-only) {
    background: var(--color-white);
    display: block;
    height: 2px;
    margin-block: 5px;
    transition: transform 160ms ease, opacity 160ms ease;
    width: 1.6rem;
  }

  .site-header__mobile {
    background: rgba(15, 15, 15, 0.96);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .site-header__mobile[hidden] {
    display: none;
  }

  .site-header__mobile-inner {
    display: grid;
    gap: 0.8rem;
    padding-block: 1.1rem 1.4rem;
  }

  .site-header__mobile-link {
    color: rgba(255, 255, 255, 0.86);
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding-block: 0.5rem;
    text-transform: uppercase;
  }

  .site-header__mobile-cta {
    justify-self: start;
    margin-top: 0.6rem;
    min-height: 3rem;
  }

  @media (max-width: 1023px) {
    .site-header__nav {
      grid-template-columns: auto 1fr auto;
      height: var(--header-height);
    }

    .site-header__group {
      display: none;
    }

    .site-header__brand {
      height: 4.2rem;
      justify-self: center;
      width: 4.2rem;
    }

    .site-header__toggle,
    .site-header__mobile:not([hidden]) {
      display: block;
    }

    .site-header__brand img {
      height: 4.2rem;
      transform: scale(1.24);
      width: 4.2rem;
    }
  }
</style>

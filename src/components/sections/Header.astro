---
import type { MobileQuickAction, NavItem } from "../../types/site";
import type { Locale } from "../../i18n/locales";
import { locales, localeLabels, defaultLocale } from "../../i18n/locales";
import { getUiStrings } from "../../i18n/ui";
import ActionLink from "../ui/actions/ActionLink.astro";
import NavLink from "../ui/navigation/NavLink.astro";

interface Props {
  nav: NavItem[];
  quickActions?: MobileQuickAction[];
  ctaLabel: string;
  ctaHref: string;
  locale?: Locale;
  alternateUrls?: Record<Locale, string>;
}

const { nav, quickActions = [], ctaLabel, ctaHref, locale = defaultLocale, alternateUrls } = Astro.props;
const ui = await getUiStrings(locale);

const leftNav = nav.filter((item) => item.desktopSlot === "left");
const rightNav = nav.filter((item) => item.desktopSlot === "right");
const mobileNav = nav.filter((item) => item.mobile !== false);
const homeHref = locale === defaultLocale ? "/" : `/${locale}`;
const currentPath = Astro.url.pathname;

const normalizePath = (value: string) => {
  if (value === "/") return "/";
  return value.replace(/\/+$/, "");
};

const isCurrentLink = (href: string) => {
  if (href.startsWith("tel:")) return false;
  const normalizedHref = normalizePath(href.split("#")[0] || href);
  const normalizedPath = normalizePath(currentPath);
  return normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);
};

const langLinks = alternateUrls
  ? locales.map((loc) => ({ locale: loc, href: alternateUrls[loc], label: localeLabels[loc], active: loc === locale }))
  : [];
---

<header class="site-header" data-header transition:persist>
  <div class="site-header__fade" aria-hidden="true"></div>
  <nav class="shell site-header__nav" aria-label={ui.navLabel}>
    <div class="site-header__group site-header__group--left">
      {leftNav.map((item) => (
        <NavLink class="site-header__link" href={item.href} label={item.desktopLabel ?? item.label} isActive={isCurrentLink(item.href)} navKind="primary" />
      ))}
    </div>

    <a class="site-header__brand" href={homeHref} aria-label={ui.homeLabel}>
      <img src="/assets/perinade/logo.webp" alt="" width="80" height="80" loading="eager" />
    </a>

    <div class="site-header__group site-header__group--right">
      {rightNav.map((item) => (
        <NavLink class="site-header__link" href={item.href} label={item.desktopLabel ?? item.label} isActive={isCurrentLink(item.href)} navKind="primary" />
      ))}
      {langLinks.length > 0 && (
        <div class="site-header__lang" aria-label={ui.languageLabel}>
          {langLinks.map((l) => (
            <NavLink class="site-header__lang-item" href={l.href} label={l.locale.toUpperCase()} isActive={l.active} navKind="language" />
          ))}
        </div>
      )}
      <ActionLink href={ctaHref} label={ctaLabel} class="site-header__cta" variant="primary" size="sm" interaction="emphasis" />
    </div>

    <button
      class="site-header__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label={ui.menuOpen}
      data-menu-toggle
      data-label-open={ui.menuOpen}
      data-label-close={ui.menuClose}
    >
      <span></span>
      <span></span>
      <span></span>
      <span class="sr-only" data-menu-label>{ui.menuOpen}</span>
    </button>
  </nav>

  <div class="site-header__backdrop" data-menu-backdrop hidden></div>

  <div class="site-header__mobile" id="mobile-nav" data-mobile-nav hidden>
    <div class="shell site-header__mobile-inner">
      {mobileNav.map((item) => (
        <NavLink class="site-header__mobile-link" href={item.href} label={item.label} isActive={isCurrentLink(item.href)} navKind="primary" />
      ))}
      {langLinks.length > 0 && (
        <div class="site-header__lang site-header__lang--mobile" aria-label={ui.languageLabel}>
          {langLinks.map((l) => (
            <NavLink class="site-header__lang-item" href={l.href} label={l.locale.toUpperCase()} isActive={l.active} navKind="language" />
          ))}
        </div>
      )}
      <ActionLink href={ctaHref} label={ctaLabel} class="site-header__mobile-cta" variant="primary" size="md" interaction="emphasis" fullWidth />
    </div>
  </div>
</header>

{
  quickActions.length > 0 && (
    <nav class="mobile-quick-actions" aria-label={ui.mobileNavLabel} data-mobile-quick-actions>
      {quickActions.map((action) => (
        <NavLink
          class={["mobile-quick-actions__item", action.priority === "primary" && "mobile-quick-actions__item--primary"].filter(Boolean).join(" ")}
          href={action.href}
          label={action.label}
          navKind="quick"
          isActive={isCurrentLink(action.href)}
          data-quick-action={action.id}
        >
          <span class="mobile-quick-actions__icon" aria-hidden="true">
            {
              action.icon === "calendar" ? (
                <svg viewBox="0 0 24 24" fill="none">
                  <rect x="4" y="5.5" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.8"></rect>
                  <path d="M8 3.5v4M16 3.5v4M4 9h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                </svg>
              ) : action.icon === "bag" ? (
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6.5 8.5h11l-1 10h-9l-1-10Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
                  <path d="M9 9V7.8A3 3 0 0 1 12 5a3 3 0 0 1 3 2.8V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M7.5 5.5c.4-.4 1-.5 1.5-.2l2 1c.6.3.8 1 .5 1.6l-.7 1.4c1 1.9 2.5 3.4 4.4 4.4l1.4-.7c.6-.3 1.3-.1 1.6.5l1 2c.3.5.2 1.1-.2 1.5l-1.2 1.2c-.7.7-1.7.9-2.6.6A17.6 17.6 0 0 1 4.4 8.1c-.3-.9-.1-1.9.6-2.6l1.2-1.2Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              )
            }
          </span>
          <span>{action.label}</span>
        </NavLink>
      ))}
    </nav>
  )
}

<style>
  .site-header {
    left: 0;
    position: fixed;
    right: 0;
    top: 0;
    transition:
      background var(--motion-duration-sm) var(--motion-ease-standard),
      box-shadow var(--motion-duration-md) var(--motion-ease-standard),
      backdrop-filter var(--motion-duration-md) var(--motion-ease-standard);
    z-index: 50;
  }

  .site-header.is-scrolled,
  .site-header.is-open {
    backdrop-filter: blur(1rem);
    background: rgba(15, 15, 15, 0.92);
    box-shadow: 0 1rem 2.4rem rgba(0, 0, 0, 0.22);
  }

  .site-header.is-open {
    bottom: 0;
  }

  .site-header__fade {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 100%);
    inset: 0;
    opacity: 1;
    pointer-events: none;
    position: absolute;
    transition: opacity var(--motion-duration-sm) var(--motion-ease-standard);
  }

  .site-header.is-scrolled .site-header__fade,
  .site-header.is-open .site-header__fade {
    opacity: 0;
  }

  .site-header__nav {
    align-items: center;
    display: grid;
    grid-template-columns:
      minmax(0, 1fr)
      auto
      clamp(4.2rem, 8vw, 8.2rem)
      auto
      clamp(4.2rem, 8vw, 8.2rem)
      auto
      minmax(0, 1fr);
    height: var(--header-height);
    position: relative;
    transition: height var(--motion-duration-sm) var(--motion-ease-standard);
    z-index: 52;
  }

  .site-header.is-scrolled .site-header__nav {
    height: calc(var(--header-height) - 0.3rem);
  }

  .site-header__group {
    align-items: center;
    display: flex;
    white-space: nowrap;
  }

  .site-header__group--left {
    grid-column: 2;
    gap: clamp(3rem, 5.2vw, 5.2rem);
    justify-self: end;
  }

  .site-header__group--right {
    align-items: center;
    gap: clamp(2.6rem, 4.4vw, 4.2rem);
    grid-column: 6;
    justify-self: start;
  }

  .site-header__link {
    --ui-nav-color: rgba(255, 255, 255, 0.8);
  }

  .site-header__brand {
    align-items: center;
    color: var(--color-white);
    display: inline-flex;
    grid-column: 4;
    block-size: clamp(3.6rem, 7vw, 5rem);
    justify-items: center;
    justify-self: center;
    overflow: hidden;
    text-align: center;
    inline-size: clamp(3.6rem, 7vw, 5rem);
  }

  .site-header__brand img {
    block-size: clamp(3.6rem, 7vw, 5rem);
    object-fit: contain;
    transform: scale(1.3);
    transform-origin: center;
    transition: transform var(--motion-duration-md) var(--motion-ease-standard);
    inline-size: clamp(3.6rem, 7vw, 5rem);
  }

  .site-header.is-scrolled .site-header__brand img {
    transform: scale(1.18);
  }

  .site-header__group--right :global(.site-header__cta) {
    --action-primary-bg: linear-gradient(180deg, #dc7f0a 0%, #c86d00 100%);
    --action-primary-bg-hover: linear-gradient(180deg, #e08a1b 0%, #cf7608 100%);
    --action-primary-border: rgba(255, 255, 255, 0.16);
    --action-primary-shadow: 0 0.5rem 1.25rem rgba(196, 106, 0, 0.25);

    border-radius: 0.5rem;
    letter-spacing: 0.11em;
    min-block-size: var(--control-height-sm);
    overflow: hidden;
    padding-inline: clamp(0.8rem, 2.4vw, 1rem);
    position: relative;
  }

  /* Language switcher */
  .site-header__lang {
    align-items: center;
    display: flex;
    gap: 0.2rem;
  }

  .site-header__lang-item {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.35rem 0.3rem;
  }

  .site-header__lang-item:global(.ui-nav-link)::after {
    background: var(--color-accent);
    height: 0.1rem;
    inset-inline: 0.35rem;
    top: calc(100% + 0.12rem);
    transform-origin: center;
  }

  .site-header__lang-item:global(.ui-nav-link:hover),
  .site-header__lang-item:global(.ui-nav-link:focus-visible) {
    color: var(--color-white);
  }

  .site-header__lang-item:global(.is-active) {
    color: var(--color-white);
  }

  .site-header__lang-item:global(.ui-nav-link.is-active)::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .site-header__lang--mobile {
    padding-block: var(--space-2xs);
  }

  .site-header__toggle,
  .site-header__mobile,
  .site-header__backdrop {
    display: none;
  }

  .site-header__toggle {
    background: transparent;
    border: 0;
    justify-self: end;
    min-block-size: 2.75rem;
    min-inline-size: 2.75rem;
    padding: 0.5rem;
  }

  .site-header__toggle span:not(.sr-only) {
    background: var(--color-white);
    display: block;
    block-size: 0.125rem;
    margin-block: clamp(0.2rem, 0.8vw, 0.3125rem);
    transition:
      transform var(--motion-duration-sm) var(--motion-ease-standard),
      opacity var(--motion-duration-sm) var(--motion-ease-standard);
    inline-size: clamp(1.2rem, 4vw, 1.6rem);
  }

  .site-header.is-open .site-header__toggle span:nth-child(1) {
    transform: translateY(0.45rem) rotate(45deg);
  }

  .site-header.is-open .site-header__toggle span:nth-child(2) {
    opacity: 0;
  }

  .site-header.is-open .site-header__toggle span:nth-child(3) {
    transform: translateY(-0.45rem) rotate(-45deg);
  }

  .site-header__backdrop {
    backdrop-filter: blur(0.375rem);
    background: linear-gradient(180deg, rgba(6, 6, 6, 0.18), rgba(6, 6, 6, 0.58));
    bottom: 0;
    left: 0;
    opacity: 0;
    position: absolute;
    right: 0;
    top: var(--header-height);
    transition: opacity var(--motion-duration-sm) var(--motion-ease-standard);
    z-index: 48;
  }

  .site-header__backdrop.is-open {
    opacity: 1;
  }

  .site-header__mobile {
    background:
      linear-gradient(180deg, rgba(12, 12, 12, 0.985) 0%, rgba(5, 5, 5, 0.985) 100%),
      radial-gradient(circle at top left, rgba(207, 118, 8, 0.16), transparent 34%),
      radial-gradient(circle at bottom center, rgba(255, 255, 255, 0.03), transparent 46%);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    bottom: 0;
    box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.35);
    left: 0;
    opacity: 0;
    overflow-y: auto;
    position: absolute;
    right: 0;
    top: var(--header-height);
    transform: translateY(-0.75rem);
    transition:
      opacity var(--motion-duration-sm) var(--motion-ease-standard),
      transform var(--motion-duration-md) var(--motion-ease-standard);
    width: 100vw;
    z-index: 49;
  }

  .site-header__mobile.is-open {
    opacity: 1;
    transform: translateY(0);
  }

  .site-header__mobile::before {
    background: linear-gradient(90deg, rgba(207, 118, 8, 0.9), rgba(207, 118, 8, 0.2));
    border-radius: 999px;
    content: "";
    height: 0.18rem;
    left: clamp(1rem, 4vw, 1.5rem);
    position: absolute;
    top: 1rem;
    width: 3rem;
  }

  .site-header__mobile[hidden] {
    display: none;
  }

  .site-header__mobile-inner {
    align-content: start;
    display: grid;
    gap: 0.7rem;
    grid-auto-rows: max-content;
    min-block-size: 100%;
    padding-block: clamp(2rem, 6vw, 2.4rem) calc(var(--space-xl) + env(safe-area-inset-bottom));
    padding-inline: clamp(1rem, 4vw, 1.5rem);
  }

  .site-header__mobile-link {
    --ui-nav-color: rgba(255, 255, 255, 0.84);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: clamp(0.92rem, 3.4vw, 1.05rem);
    font-weight: 600;
    letter-spacing: 0.14em;
    min-block-size: 3.5rem;
    padding-block: 0.9rem;
    text-transform: uppercase;
  }

  .site-header__mobile-link:global(.is-active) {
    --ui-nav-color: var(--color-white);
    border-bottom-color: rgba(255, 255, 255, 0.72);
  }

  .site-header__mobile-inner :global(.site-header__mobile-cta) {
    --action-primary-shadow: 0 1rem 2rem rgba(196, 106, 0, 0.24);

    border-radius: 999px;
    justify-self: stretch;
    margin-top: auto;
    min-block-size: var(--control-height-md);
  }

  .site-header__lang--mobile {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding-block: 0.9rem 1.1rem;
  }

  .mobile-quick-actions {
    align-items: center;
    background: rgba(15, 15, 15, 0.95);
    backdrop-filter: blur(0.75rem);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    bottom: 0;
    display: none;
    gap: 0.5rem;
    inset-inline: 0;
    padding: 0.5rem max(0.75rem, env(safe-area-inset-left)) calc(0.5rem + env(safe-area-inset-bottom))
      max(0.75rem, env(safe-area-inset-right));
    position: fixed;
    z-index: 70;
  }

  .mobile-quick-actions__item {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 0.875rem;
    display: inline-flex;
    flex: 1 1 0;
    font-size: 0.72rem;
    font-weight: 600;
    gap: 0.35rem;
    justify-content: center;
    min-block-size: 2.75rem;
    padding: 0 0.65rem;
    text-transform: uppercase;
  }

  .mobile-quick-actions__item--primary {
    background: var(--color-cta);
    border-color: var(--color-cta);
    color: var(--color-white);
  }

  .mobile-quick-actions__item:global(.is-active) {
    box-shadow: 0 0 0 0.125rem rgba(255, 255, 255, 0.2);
  }

  .mobile-quick-actions__icon {
    display: inline-flex;
    block-size: 1rem;
    inline-size: 1rem;
  }

  .mobile-quick-actions__icon svg {
    block-size: 100%;
    inline-size: 100%;
  }

  :global(body[data-menu-open="true"]) {
    overflow: hidden;
    touch-action: none;
  }

  .site-header.is-open + .mobile-quick-actions {
    opacity: 0;
    pointer-events: none;
    transform: translateY(1rem);
    visibility: hidden;
  }

  @media (max-width: 63.9375em) {
    .site-header__nav {
      grid-template-columns: auto 1fr auto;
      height: var(--header-height);
    }

    .site-header__group {
      display: none;
    }

    .site-header__brand {
      block-size: clamp(3.2rem, 12vw, 4.2rem);
      justify-self: center;
      inline-size: clamp(3.2rem, 12vw, 4.2rem);
    }

    .site-header__toggle,
    .site-header__mobile:not([hidden]),
    .site-header__backdrop:not([hidden]) {
      display: block;
    }

    .site-header__brand img {
      block-size: clamp(3.2rem, 12vw, 4.2rem);
      transform: scale(1.24);
      inline-size: clamp(3.2rem, 12vw, 4.2rem);
    }
  }

  @media (max-width: 47.9375em) {
    .mobile-quick-actions {
      display: flex;
    }

    :global(body) {
      padding-bottom: calc(4.4rem + env(safe-area-inset-bottom));
    }
  }
</style>

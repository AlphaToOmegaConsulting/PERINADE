---
import type { ReasonItem } from "../../types/site";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  reasons: ReasonItem[];
}

const { reasons } = Astro.props;

function iconSvg(icon: string) {
  const icons: Record<string, string> = {
    leaf: `<svg viewBox="0 0 24 24" fill="none"><path d="M18 3c-6 1-10 4.5-11.4 10.3-.2.8-.4 1.7-.6 2.7 1.1-.7 2.2-1.1 3.2-1.4C15 13 18.5 9.1 20 4.5c.1-.5.2-1 .3-1.5H18Zm-6 10.5c-2.5 0-4.6.9-6.5 3.1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    terrain: `<svg viewBox="0 0 24 24" fill="none"><path d="M3 16c1.8-2.3 3.6-3.4 5.4-3.4S12 13.7 13.7 16c1.8-2 3.5-3 5.3-3 1 0 2 .4 3 1.1M3 20h18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    glass: `<svg viewBox="0 0 24 24" fill="none"><path d="M8 4h8l-1.2 7.2A4 4 0 0 1 11 14.5V20m0 0h2m-2 0H9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  };
  return icons[icon] ?? icons.leaf;
}
---

<section class="reasons section section--soft">
  <div class="shell shell--narrow">
    <SectionHeading eyebrow="Pourquoi nous visiter" title="Trois raisons de venir" centered />

    <div class="reasons__grid">
      {reasons.map((reason) => (
        <article class="reasons__card">
          <span class="reasons__icon" set:html={iconSvg(reason.icon)}></span>
          <h3>{reason.title}</h3>
          <p>{reason.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reasons__grid {
    display: grid;
    gap: 2.75rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 2.35rem;
  }

  .reasons__card {
    display: grid;
    justify-items: center;
    max-width: 17rem;
    margin-inline: auto;
    text-align: center;
  }

  .reasons__icon {
    align-items: center;
    background: rgba(25, 43, 23, 0.1);
    border-radius: 999px;
    color: var(--color-deep-green);
    display: inline-flex;
    height: 4.2rem;
    justify-content: center;
    margin-bottom: 1.05rem;
    width: 4.2rem;
  }

  .reasons__icon :global(svg) {
    height: 1.7rem;
    width: 1.7rem;
  }

  .reasons h3 {
    font-size: 1.42rem;
    margin: 0 0 0.85rem;
  }

  .reasons p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
    max-width: 18.5rem;
  }

  @media (max-width: 1023px) {
    .reasons__grid {
      gap: 2rem;
      grid-template-columns: 1fr;
      margin-top: 3rem;
    }
  }
</style>

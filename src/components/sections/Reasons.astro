---
import type { ReasonItem } from "../../types/site";
import Icon from "../ui/Icon.astro";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  reasons: ReasonItem[];
}

const { reasons } = Astro.props;
---

<section class="reasons section section--soft">
  <div class="shell shell--narrow">
    <SectionHeading eyebrow="Pourquoi nous visiter" title="Trois raisons de venir" centered />

    <div class="reasons__grid">
      {reasons.map((reason) => (
        <article class="reasons__card">
          <span class="reasons__icon"><Icon name={reason.icon} /></span>
          <h3>{reason.title}</h3>
          <p>{reason.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reasons__grid {
    display: grid;
    gap: 2.75rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 2.35rem;
  }

  .reasons__card {
    display: grid;
    justify-items: center;
    max-width: 17rem;
    margin-inline: auto;
    text-align: center;
  }

  .reasons__icon {
    align-items: center;
    background: rgba(25, 43, 23, 0.1);
    border-radius: 999px;
    color: var(--color-deep-green);
    display: inline-flex;
    height: 4.2rem;
    justify-content: center;
    margin-bottom: 1.05rem;
    width: 4.2rem;
  }

  .reasons__icon :global(svg) {
    height: 1.7rem;
    width: 1.7rem;
  }

  .reasons h3 {
    font-size: 1.42rem;
    margin: 0 0 0.85rem;
  }

  .reasons p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
    max-width: 18.5rem;
  }

  @media (max-width: 1023px) {
    .reasons__grid {
      gap: 2rem;
      grid-template-columns: 1fr;
      margin-top: 3rem;
    }
  }
</style>

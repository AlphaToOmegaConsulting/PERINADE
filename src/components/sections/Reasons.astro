---
import type { SiteData } from "../../types/site";
import Icon from "../ui/Icon.astro";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  reasons: SiteData["reasons"];
}

const { reasons } = Astro.props;
---

<section class="reasons section section--soft">
  <div class="shell shell--narrow">
    <SectionHeading eyebrow={reasons.eyebrow} title={reasons.title} centered />

    <div class="reasons__grid" data-reveal-group data-reveal-stagger="90">
      {reasons.items.map((reason, i) => (
        <article class="reasons__card" data-reveal="up">
          <span class="reasons__number" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
          <span class="reasons__icon"><Icon name={reason.icon} /></span>
          <h3>{reason.title}</h3>
          <p>{reason.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reasons__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 2.35rem;
  }

  .reasons__card {
    background: white;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    padding: 1.85rem 1.65rem 1.65rem;
    position: relative;
    text-align: left;
  }

  .reasons__card::before {
    background: var(--color-accent);
    border-radius: 999px;
    content: "";
    height: 2px;
    left: 1.65rem;
    position: absolute;
    top: 0;
    width: 2.5rem;
  }

  .reasons__number {
    color: rgba(196, 156, 110, 0.18);
    display: block;
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.75rem;
    pointer-events: none;
    user-select: none;
  }

  .reasons__icon {
    align-items: center;
    background: var(--color-soft-strong);
    border-radius: 0.4rem;
    color: var(--color-deep-green);
    display: inline-flex;
    height: 3rem;
    justify-content: center;
    margin-bottom: 1rem;
    width: 3rem;
  }

  .reasons__icon :global(svg) {
    height: 1.4rem;
    width: 1.4rem;
  }

  .reasons h3 {
    font-size: 1.2rem;
    margin: 0 0 0.65rem;
  }

  .reasons p {
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 1023px) {
    .reasons__grid {
      gap: 1.25rem;
      grid-template-columns: 1fr;
      margin-top: 3rem;
    }
  }
</style>

---
import type { SiteData } from "../../types/site";
import Icon from "../ui/Icon.astro";
import SubmitButton from "../ui/actions/SubmitButton.astro";
import ContactBlockSection from "../patterns/ContactBlockSection.astro";

interface Props {
  contact: SiteData["contact"];
}

const { contact } = Astro.props;
---

<ContactBlockSection class="contact section" id="contact">
  <div class="shell shell--narrow contact__inner">
    <div class="contact__content" data-reveal="left">
      <p class="contact__eyebrow">{contact.eyebrow}</p>
      <h2>{contact.titleHtml}</h2>
      <p class="contact__body">{contact.body}</p>

      <ul class="contact__list" data-reveal-group data-reveal-stagger="65">
        {contact.info.map((item) => (
          <li data-reveal="up">
            <span class="contact__icon"><Icon name={item.icon} /></span>
            <div class="contact__details">
              <strong>{item.label}</strong>
              <span>{item.value}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <form
      class="contact__form ui-hover-lift"
      data-ui-form
      data-contact-form
      data-reveal="right"
      data-success-message={contact.formSuccessMessage ?? "Message envoye."}
      data-error-message={contact.formErrorMessage ?? "Erreur d'envoi."}
      data-required-message={contact.validation.required}
      data-invalid-email-message={contact.validation.invalidEmail}
      data-fix-errors-message={contact.validation.fixErrors}
      data-default-subject={contact.mail.defaultSubject}
      data-mail-first-name={contact.mail.fieldFirstName}
      data-mail-last-name={contact.mail.fieldLastName}
      data-mail-email={contact.mail.fieldEmail}
      data-mail-phone={contact.mail.fieldPhone}
      data-mail-message={contact.mail.fieldMessage}
      action={contact.formAction}
      method="post"
      novalidate
    >
      <div class="contact__grid">
        <div class="contact__field" data-field-state data-reveal="up">
          <label for="contact-first-name">{contact.labels.firstName}</label>
          <input id="contact-first-name" type="text" name="firstName" autocomplete="given-name" required />
          <small class="contact__error" data-error-for="contact-first-name"></small>
        </div>

        <div class="contact__field" data-field-state data-reveal="up">
          <label for="contact-last-name">{contact.labels.lastName}</label>
          <input id="contact-last-name" type="text" name="lastName" autocomplete="family-name" required />
          <small class="contact__error" data-error-for="contact-last-name"></small>
        </div>

        <div class="contact__field" data-field-state data-reveal="up">
          <label for="contact-email">{contact.labels.email}</label>
          <input id="contact-email" type="email" name="email" inputmode="email" autocomplete="email" required />
          <small class="contact__error" data-error-for="contact-email"></small>
        </div>

        <div class="contact__field" data-field-state data-reveal="up">
          <label for="contact-phone">{contact.labels.phone}</label>
          <input id="contact-phone" type="tel" name="phone" inputmode="tel" autocomplete="tel" required />
          <small class="contact__error" data-error-for="contact-phone"></small>
        </div>
      </div>

      <div class="contact__field" data-field-state data-reveal="up">
        <label for="contact-subject">{contact.labels.subject}</label>
        <input id="contact-subject" type="text" name="subject" required />
        <small class="contact__error" data-error-for="contact-subject"></small>
      </div>

      <div class="contact__field" data-field-state data-reveal="up">
        <label for="contact-message">{contact.labels.message}</label>
        <textarea id="contact-message" name="message" rows="6" required></textarea>
        <small class="contact__error" data-error-for="contact-message"></small>
      </div>

      <div class="contact__cta" data-reveal="up">
        <span class="contact__ornament" aria-hidden="true"></span>
        <SubmitButton label={contact.labels.submit} variant="primary" size="lg" class="contact__submit" />
      </div>
      <p class="contact__status ui-status-animate" data-contact-status aria-live="polite"></p>
    </form>
  </div>
</ContactBlockSection>

<style>
  .contact {
    background: var(--color-soft-strong);
  }

  .contact__inner {
    display: grid;
    gap: 2.1rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
  }

  .contact__eyebrow {
    color: var(--color-text);
    font-size: 1rem;
    margin: 0 0 1.25rem;
  }

  .contact h2 {
    font-size: clamp(2.75rem, 4.1vw, 3.9rem);
    line-height: 0.95;
    margin: 0;
  }

  .contact h2 :global(span) {
    color: var(--color-cta);
    font-style: italic;
  }

  .contact__body {
    color: var(--color-muted);
    line-height: 1.65;
    margin: 1.1rem 0 0;
    max-width: 22rem;
  }

  .contact__list {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 1.35rem 0 0;
    padding: 0;
  }

  .contact__list li {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: auto 1fr;
  }

  .contact__icon {
    align-items: center;
    color: var(--color-accent);
    display: flex;
    flex-shrink: 0;
    height: 1.35rem;
    justify-content: center;
    line-height: 0;
    margin-top: 0.2rem;
    width: 1.35rem;
  }

  .contact__icon :global(svg) {
    display: block;
    flex: none;
    height: 1.2rem;
    width: 1.2rem;
  }

  .contact__details strong,
  .contact__details span {
    display: block;
  }

  .contact__details strong {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.15rem;
    text-transform: uppercase;
  }

  .contact__details span {
    color: var(--color-text);
    font-size: 0.98rem;
  }

  .contact__form {
    align-self: start;
    display: grid;
    gap: 0.75rem;
    padding-top: 0.4rem;
  }

  .contact__grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact__field {
    display: grid;
    gap: 0.35rem;
  }

  .contact__field label {
    font-size: 0.79rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .contact__form input,
  .contact__form textarea {
    background: rgba(250, 250, 250, 0.5);
    border: 1px solid #f5f5f5;
    border-radius: var(--radius-card);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    color: var(--color-text);
    font: inherit;
    min-height: 3rem;
    padding: 0.8rem 1rem;
  }

  .contact__form textarea {
    min-height: 8rem;
    resize: vertical;
  }

  .contact__form input[aria-invalid="true"],
  .contact__form textarea[aria-invalid="true"] {
    border-color: #9f2517;
  }

  .contact__field.is-invalid input,
  .contact__field.is-invalid textarea {
    border-color: #9f2517;
    box-shadow: 0 0 0 0.18rem rgba(159, 37, 23, 0.08);
  }

  .contact__field.is-valid input,
  .contact__field.is-valid textarea {
    border-color: rgba(31, 111, 74, 0.4);
    box-shadow: 0 0 0 0.18rem rgba(31, 111, 74, 0.08);
  }

  .contact__error {
    color: #9f2517;
    font-size: 0.82rem;
    min-block-size: 1.1rem;
    opacity: 0;
    transform: translateY(-0.1rem);
    transition:
      opacity var(--motion-duration-sm) var(--motion-ease-standard),
      transform var(--motion-duration-sm) var(--motion-ease-standard);
  }

  .contact__error.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .contact__cta {
    align-items: center;
    display: grid;
    justify-items: start;
    margin-top: 0.2rem;
    position: relative;
  }

  .contact__ornament {
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.22), rgba(0, 0, 0, 0));
    height: 0.28rem;
    left: 0;
    position: absolute;
    top: -0.85rem;
    width: 3rem;
  }

  .contact__cta :global(.contact__submit) {
    --btn-primary-shadow: var(--shadow-card);

    min-height: 3.2rem;
    min-width: 18rem;
    padding: 0 1.8rem;
  }

  .contact__status {
    font-size: 0.9rem;
    margin: 0;
    min-block-size: 1.3rem;
  }

  .contact__status.is-success {
    color: #1f5b31;
  }

  .contact__status.is-error {
    color: #9f2517;
  }

  @media (max-width: 1023px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }

    .contact__body {
      max-width: 34rem;
    }
  }

  @media (max-width: 767px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }

    .contact__cta :global(.contact__submit) {
      min-width: 100%;
    }
  }
</style>

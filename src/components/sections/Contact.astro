---
import type { SiteData } from "../../types/site";
import Icon from "../ui/Icon.astro";

interface Props {
  contact: SiteData["contact"];
}

const { contact } = Astro.props;
---

<section class="contact section" id="contact">
  <div class="shell shell--narrow contact__inner">
    <div class="contact__content">
      <p class="contact__eyebrow">{contact.eyebrow}</p>
      <h2 set:html={contact.titleHtml}></h2>
      <p class="contact__body">{contact.body}</p>

      <ul class="contact__list">
        {contact.info.map((item) => (
          <li>
            <Icon name={item.icon} class="contact__icon" />
            <div class="contact__details">
              <strong>{item.label}</strong>
              <span>{item.value}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <form class="contact__form" data-ui-form data-placeholder={contact.formAction}>
      <div class="contact__grid">
        <label class="sr-only" for="contact-first-name">Prénom</label>
        <input id="contact-first-name" type="text" name="firstName" placeholder="Prénom *" required />
        <label class="sr-only" for="contact-last-name">Nom</label>
        <input id="contact-last-name" type="text" name="lastName" placeholder="Nom *" required />
        <label class="sr-only" for="contact-email">Email</label>
        <input id="contact-email" type="email" name="email" placeholder="Email *" required />
        <label class="sr-only" for="contact-phone">Téléphone</label>
        <input id="contact-phone" type="tel" name="phone" placeholder="Téléphone *" required />
      </div>
      <label class="sr-only" for="contact-subject">Sujet</label>
      <input id="contact-subject" type="text" name="subject" placeholder="Sujet *" required />
      <label class="sr-only" for="contact-message">Message</label>
      <textarea id="contact-message" name="message" rows="6" placeholder="Message *" required></textarea>
      <div class="contact__cta">
        <span class="contact__ornament" aria-hidden="true"></span>
        <button type="submit" class="contact__submit">
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
          Envoyer le message
        </button>
      </div>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--color-soft-strong);
  }

  .contact__inner {
    display: grid;
    gap: 2.1rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
  }

  .contact__eyebrow {
    color: var(--color-text);
    font-size: 1rem;
    margin: 0 0 1.25rem;
  }

  .contact h2 {
    font-size: clamp(2.75rem, 4.1vw, 3.9rem);
    line-height: 0.95;
    margin: 0;
  }

  .contact h2 :global(span) {
    color: var(--color-cta);
    font-style: italic;
  }

  .contact__body {
    color: var(--color-muted);
    line-height: 1.65;
    margin: 1.1rem 0 0;
    max-width: 22rem;
  }

  .contact__list {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 1.35rem 0 0;
    padding: 0;
  }

  .contact__list li {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: auto 1fr;
  }

  .contact__icon {
    align-items: center;
    color: var(--color-accent);
    display: flex;
    flex-shrink: 0;
    height: 1.35rem;
    justify-content: center;
    line-height: 0;
    margin-top: 0.2rem;
    width: 1.35rem;
  }

  .contact__icon :global(svg) {
    display: block;
    flex: none;
    height: 1.2rem;
    width: 1.2rem;
  }

  .contact__details strong,
  .contact__details span {
    display: block;
  }

  .contact__details strong {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.15rem;
    text-transform: uppercase;
  }

  .contact__details span {
    color: var(--color-text);
    font-size: 0.98rem;
  }

  .contact__form {
    align-self: start;
    display: grid;
    gap: 0.85rem;
    padding-top: 0.4rem;
  }

  .contact__grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact__form input,
  .contact__form textarea {
    background: rgba(250, 250, 250, 0.5);
    border: 1px solid #f5f5f5;
    border-radius: var(--radius-card);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    color: var(--color-text);
    font: inherit;
    min-height: 3.2rem;
    padding: 0.9rem 1.15rem;
  }

  .contact__form textarea {
    min-height: 8rem;
    resize: vertical;
  }

  .contact__form input::placeholder,
  .contact__form textarea::placeholder {
    color: #9b9b9b;
  }

  .contact__cta {
    align-items: center;
    display: grid;
    justify-items: start;
    margin-top: 0.4rem;
    position: relative;
  }

  .contact__ornament {
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.22), rgba(0, 0, 0, 0));
    height: 0.28rem;
    left: 0;
    position: absolute;
    top: -0.85rem;
    width: 3rem;
  }

  .contact__submit {
    align-items: center;
    background: var(--color-cta);
    border: 0;
    border-radius: 999px;
    box-shadow: var(--shadow-card);
    color: var(--color-white);
    cursor: pointer;
    display: inline-flex;
    gap: 0.9rem;
    justify-content: center;
    min-height: 3.75rem;
    min-width: 18rem;
    padding: 0 1.8rem;
    text-transform: uppercase;
  }

  .contact__submit span {
    align-items: center;
    background: rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    display: inline-flex;
    height: 2rem;
    justify-content: center;
    width: 2rem;
  }

  .contact__submit svg {
    height: 1rem;
    width: 1rem;
  }

  @media (max-width: 1023px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }

    .contact__body {
      max-width: 34rem;
    }
  }

  @media (max-width: 767px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

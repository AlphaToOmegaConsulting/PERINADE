---
import type { SiteData } from "../../types/site";
import Icon from "../ui/Icon.astro";

interface Props {
  contact: SiteData["contact"];
}

const { contact } = Astro.props;
---

<section class="contact section" id="contact">
  <div class="shell shell--narrow contact__inner">
    <div class="contact__content">
      <p class="contact__eyebrow">{contact.eyebrow}</p>
      <h2 set:html={contact.titleHtml}></h2>
      <p class="contact__body">{contact.body}</p>

      <ul class="contact__list">
        {contact.info.map((item) => (
          <li>
            <span class="contact__icon"><Icon name={item.icon} /></span>
            <div class="contact__details">
              <strong>{item.label}</strong>
              <span>{item.value}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <form
      class="contact__form"
      data-ui-form
      data-contact-form
      data-success-message={contact.formSuccessMessage ?? "Message envoye."}
      data-error-message={contact.formErrorMessage ?? "Erreur d'envoi."}
      action={contact.formAction}
      method="post"
      novalidate
    >
      <div class="contact__grid">
        <div class="contact__field">
          <label for="contact-first-name">Prenom *</label>
          <input id="contact-first-name" type="text" name="firstName" autocomplete="given-name" required />
          <small class="contact__error" data-error-for="contact-first-name"></small>
        </div>

        <div class="contact__field">
          <label for="contact-last-name">Nom *</label>
          <input id="contact-last-name" type="text" name="lastName" autocomplete="family-name" required />
          <small class="contact__error" data-error-for="contact-last-name"></small>
        </div>

        <div class="contact__field">
          <label for="contact-email">Email *</label>
          <input id="contact-email" type="email" name="email" inputmode="email" autocomplete="email" required />
          <small class="contact__error" data-error-for="contact-email"></small>
        </div>

        <div class="contact__field">
          <label for="contact-phone">Telephone *</label>
          <input id="contact-phone" type="tel" name="phone" inputmode="tel" autocomplete="tel" required />
          <small class="contact__error" data-error-for="contact-phone"></small>
        </div>
      </div>

      <div class="contact__field">
        <label for="contact-subject">Sujet *</label>
        <input id="contact-subject" type="text" name="subject" required />
        <small class="contact__error" data-error-for="contact-subject"></small>
      </div>

      <div class="contact__field">
        <label for="contact-message">Message *</label>
        <textarea id="contact-message" name="message" rows="6" required></textarea>
        <small class="contact__error" data-error-for="contact-message"></small>
      </div>

      <div class="contact__cta">
        <span class="contact__ornament" aria-hidden="true"></span>
        <button type="submit" class="contact__submit">
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
          Envoyer le message
        </button>
      </div>
      <p class="contact__status" data-contact-status aria-live="polite"></p>
    </form>
  </div>
</section>

<script is:inline>
  const contactForm = document.querySelector("[data-contact-form]");

  const trackUiEvent = (event, context, meta = {}) => {
    const payload = { event, context, meta };
    window.dataLayer = window.dataLayer ?? [];
    window.dataLayer.push(payload);
    window.dispatchEvent(new CustomEvent("ui:track", { detail: payload }));
  };

  if (contactForm instanceof HTMLFormElement) {
    const statusEl = contactForm.querySelector("[data-contact-status]");
    const fields = Array.from(contactForm.querySelectorAll("input, textarea"));

    const setFieldError = (field, message) => {
      const errorEl = contactForm.querySelector(`[data-error-for="${field.id}"]`);
      if (!(errorEl instanceof HTMLElement)) return;
      errorEl.textContent = message;
      field.setAttribute("aria-invalid", message ? "true" : "false");
    };

    const validateField = (field) => {
      if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) return true;
      if (field.validity.valid) {
        setFieldError(field, "");
        return true;
      }

      let message = "Ce champ est requis.";
      if (field.validity.typeMismatch && field.type === "email") {
        message = "Merci de saisir un email valide.";
      }

      setFieldError(field, message);
      return false;
    };

    fields.forEach((field) => {
      field.addEventListener("blur", () => {
        validateField(field);
      });

      field.addEventListener("input", () => {
        if (field.getAttribute("aria-invalid") === "true") {
          validateField(field);
        }
      });
    });

    contactForm.addEventListener("submit", (event) => {
      event.preventDefault();
      const valid = fields.every((field) => validateField(field));
      if (!valid) {
        if (statusEl instanceof HTMLElement) {
          statusEl.textContent = "Veuillez corriger les champs en erreur.";
          statusEl.classList.remove("is-success");
          statusEl.classList.add("is-error");
        }
        return;
      }

      const formData = new FormData(contactForm);
      const payload = Object.fromEntries(formData.entries());
      const action = contactForm.getAttribute("action") || "";
      const successMessage = contactForm.dataset.successMessage || "Message envoye.";
      const errorMessage = contactForm.dataset.errorMessage || "Erreur d'envoi.";

      try {
        if (action.startsWith("mailto:")) {
          const subject = encodeURIComponent(String(payload.subject || "Demande de contact"));
          const body = encodeURIComponent(
            `Prenom: ${payload.firstName}\nNom: ${payload.lastName}\nEmail: ${payload.email}\nTelephone: ${payload.phone}\n\nMessage:\n${payload.message}`
          );
          window.location.href = `${action}?subject=${subject}&body=${body}`;
          if (statusEl instanceof HTMLElement) {
            statusEl.textContent = successMessage;
            statusEl.classList.remove("is-error");
            statusEl.classList.add("is-success");
          }
          contactForm.reset();
          trackUiEvent("cta_click", "contact_form_submit", payload);
          return;
        }

        if (statusEl instanceof HTMLElement) {
          statusEl.textContent = errorMessage;
          statusEl.classList.remove("is-success");
          statusEl.classList.add("is-error");
        }
      } catch {
        if (statusEl instanceof HTMLElement) {
          statusEl.textContent = errorMessage;
          statusEl.classList.remove("is-success");
          statusEl.classList.add("is-error");
        }
      }
    });

    let dirty = false;
    fields.forEach((field) => {
      field.addEventListener("change", () => {
        dirty = true;
      });
    });

    window.addEventListener("beforeunload", () => {
      if (dirty) {
        trackUiEvent("form_abandon", "contact_form");
      }
    });
  }
</script>

<style>
  .contact {
    background: var(--color-soft-strong);
  }

  .contact__inner {
    display: grid;
    gap: 2.1rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
  }

  .contact__eyebrow {
    color: var(--color-text);
    font-size: 1rem;
    margin: 0 0 1.25rem;
  }

  .contact h2 {
    font-size: clamp(2.75rem, 4.1vw, 3.9rem);
    line-height: 0.95;
    margin: 0;
  }

  .contact h2 :global(span) {
    color: var(--color-cta);
    font-style: italic;
  }

  .contact__body {
    color: var(--color-muted);
    line-height: 1.65;
    margin: 1.1rem 0 0;
    max-width: 22rem;
  }

  .contact__list {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 1.35rem 0 0;
    padding: 0;
  }

  .contact__list li {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: auto 1fr;
  }

  .contact__icon {
    align-items: center;
    color: var(--color-accent);
    display: flex;
    flex-shrink: 0;
    height: 1.35rem;
    justify-content: center;
    line-height: 0;
    margin-top: 0.2rem;
    width: 1.35rem;
  }

  .contact__icon :global(svg) {
    display: block;
    flex: none;
    height: 1.2rem;
    width: 1.2rem;
  }

  .contact__details strong,
  .contact__details span {
    display: block;
  }

  .contact__details strong {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.15rem;
    text-transform: uppercase;
  }

  .contact__details span {
    color: var(--color-text);
    font-size: 0.98rem;
  }

  .contact__form {
    align-self: start;
    display: grid;
    gap: 0.75rem;
    padding-top: 0.4rem;
  }

  .contact__grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact__field {
    display: grid;
    gap: 0.35rem;
  }

  .contact__field label {
    font-size: 0.79rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .contact__form input,
  .contact__form textarea {
    background: rgba(250, 250, 250, 0.5);
    border: 1px solid #f5f5f5;
    border-radius: var(--radius-card);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    color: var(--color-text);
    font: inherit;
    min-height: 3rem;
    padding: 0.8rem 1rem;
  }

  .contact__form textarea {
    min-height: 8rem;
    resize: vertical;
  }

  .contact__form input[aria-invalid="true"],
  .contact__form textarea[aria-invalid="true"] {
    border-color: #9f2517;
  }

  .contact__error {
    color: #9f2517;
    font-size: 0.82rem;
    min-block-size: 1.1rem;
  }

  .contact__cta {
    align-items: center;
    display: grid;
    justify-items: start;
    margin-top: 0.2rem;
    position: relative;
  }

  .contact__ornament {
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.22), rgba(0, 0, 0, 0));
    height: 0.28rem;
    left: 0;
    position: absolute;
    top: -0.85rem;
    width: 3rem;
  }

  .contact__submit {
    align-items: center;
    background: var(--color-cta);
    border: 0;
    border-radius: 999px;
    box-shadow: var(--shadow-card);
    color: var(--color-white);
    cursor: pointer;
    display: inline-flex;
    gap: 0.9rem;
    justify-content: center;
    min-height: 3.2rem;
    min-width: 18rem;
    padding: 0 1.8rem;
    text-transform: uppercase;
  }

  .contact__submit span {
    align-items: center;
    background: rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    display: inline-flex;
    height: 2rem;
    justify-content: center;
    width: 2rem;
  }

  .contact__submit svg {
    height: 1rem;
    width: 1rem;
  }

  .contact__status {
    font-size: 0.9rem;
    margin: 0;
    min-block-size: 1.3rem;
  }

  .contact__status.is-success {
    color: #1f5b31;
  }

  .contact__status.is-error {
    color: #9f2517;
  }

  @media (max-width: 1023px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }

    .contact__body {
      max-width: 34rem;
    }
  }

  @media (max-width: 767px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }

    .contact__submit {
      min-width: 100%;
    }
  }
</style>

---
import type { HeroFeatureCard } from "../../types/site";
import { Image } from "astro:assets";
import { isPlaceholderLink } from "../../utils/link";

interface Props {
  cards: HeroFeatureCard[];
}

const { cards } = Astro.props;
const visibleCards = cards.slice(0, 3);
---

{
  visibleCards.length === 3 && (
    <div class="hero-deck" data-hero-deck data-reveal-group data-reveal-stagger="95">
      <div class="hero-deck__stage">
        {visibleCards.map((card, index) => {
          const slot = index === 0 ? "left" : index === 1 ? "center" : "right";
          const isPlaceholder = isPlaceholderLink(card.href);

          const content = (
            <>
              <Image class="hero-deck__image" src={card.image} alt={card.alt} loading={index === 1 ? "eager" : "lazy"} />
              <div class="hero-deck__overlay" aria-hidden="true"></div>
              <div class="hero-deck__copy">
                <p class="hero-deck__kicker">{card.kicker}</p>
                <h2 class="hero-deck__title">{card.title}</h2>
              </div>
            </>
          );

          return isPlaceholder ? (
            <article class={`hero-deck__card hero-deck__card--${slot}`} data-reveal="zoom">
              {content}
            </article>
          ) : (
            <a class={`hero-deck__card hero-deck__card--${slot}`} href={card.href} data-reveal="zoom">
              {content}
            </a>
          );
        })}

        <span class="hero-deck__nav hero-deck__nav--prev" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M14.5 6.5L9 12l5.5 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </span>
        <span class="hero-deck__nav hero-deck__nav--next" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M9.5 6.5L15 12l-5.5 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </span>
      </div>
    </div>
  )
}

<style>
  .hero-deck {
    --deck-width: clamp(18.5rem, 36vw, 29.5rem);
    --deck-scale: clamp(0.627, 2vw + 0.45, 1);
    --deck-stage-height: calc(16.8rem * var(--deck-scale));
    --deck-card-width: calc(9.91rem * var(--deck-scale));
    --deck-card-height: calc(13.22rem * var(--deck-scale));
    --deck-nav-size: calc(2.07rem * var(--deck-scale));
    --deck-title-max: calc(8rem * var(--deck-scale));
    pointer-events: auto;
    position: relative;
    width: min(100%, var(--deck-width));
  }

  .hero-deck__stage {
    block-size: var(--deck-stage-height);
    position: relative;
    width: 100%;
  }

  .hero-deck__card {
    border-radius: 0.83rem;
    box-shadow: 0 0.25rem 0.25rem rgba(0, 0, 0, 0.25);
    color: var(--color-white);
    display: block;
    block-size: var(--deck-card-height);
    overflow: hidden;
    position: absolute;
    text-decoration: none;
    transition:
      transform 280ms ease,
      left 280ms ease,
      top 280ms ease,
      box-shadow 280ms ease;
    inline-size: var(--deck-card-width);
  }

  .hero-deck__card--left {
    left: 7%;
    top: 8.6%;
    transform: rotate(-15.16deg);
  }

  .hero-deck__card--center {
    left: 32.5%;
    top: 0;
    z-index: 2;
  }

  .hero-deck__card--right {
    left: 49.3%;
    top: 3.4%;
    transform: rotate(14.25deg);
    z-index: 3;
  }

  .hero-deck:hover .hero-deck__card--left,
  .hero-deck:focus-within .hero-deck__card--left {
    left: -1.6%;
    top: 5.6%;
  }

  .hero-deck:hover .hero-deck__card--center,
  .hero-deck:focus-within .hero-deck__card--center {
    left: 30.8%;
    top: -12.2%;
  }

  .hero-deck:hover .hero-deck__card--right,
  .hero-deck:focus-within .hero-deck__card--right {
    left: 56.3%;
    top: -2.5%;
  }

  .hero-deck:hover .hero-deck__card,
  .hero-deck:focus-within .hero-deck__card {
    box-shadow: 0 0.875rem 2rem rgba(0, 0, 0, 0.28);
  }

  .hero-deck__image,
  .hero-deck__overlay {
    inset: 0;
    position: absolute;
  }

  .hero-deck__image {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .hero-deck__overlay {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.2) 50%, rgba(0, 0, 0, 0.7) 100%);
  }

  .hero-deck__copy {
    bottom: 0;
    left: 0;
    padding: clamp(0.72rem, 2vw, 1.15rem) clamp(0.55rem, 1.8vw, 0.82rem) clamp(0.55rem, 1.8vw, 0.82rem);
    position: absolute;
    right: 0;
    z-index: 1;
  }

  .hero-deck__kicker {
    color: rgba(255, 255, 255, 0.6);
    font-size: clamp(0.42rem, 0.9vw, 0.455rem);
    letter-spacing: 0.15em;
    line-height: 1.5;
    margin: 0 0 clamp(0.28rem, 1vw, 0.45rem);
    text-transform: uppercase;
  }

  .hero-deck__title {
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: clamp(0.88rem, 2.2vw, 1.05rem);
    font-weight: 400;
    letter-spacing: 0.03em;
    line-height: 0.99;
    margin: 0;
    max-inline-size: var(--deck-title-max);
    text-transform: uppercase;
  }

  .hero-deck__nav {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 100vmax;
    color: rgba(255, 255, 255, 0.8);
    display: inline-flex;
    block-size: var(--deck-nav-size);
    justify-content: center;
    position: absolute;
    top: 48.9%;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
    inline-size: var(--deck-nav-size);
  }

  .hero-deck__nav--prev {
    left: 0;
  }

  .hero-deck__nav--next {
    background: rgba(255, 255, 255, 0.35);
    left: calc(100% - var(--deck-nav-size));
  }

  .hero-deck:hover .hero-deck__nav--prev,
  .hero-deck:focus-within .hero-deck__nav--prev {
    background: rgba(214, 116, 0, 0.55);
    border-color: rgba(214, 116, 0, 0.58);
    color: var(--color-white);
  }

  .hero-deck:hover .hero-deck__nav--next,
  .hero-deck:focus-within .hero-deck__nav--next {
    background: rgba(255, 255, 255, 0.2);
  }

  .hero-deck__nav svg {
    block-size: clamp(0.68rem, 1.8vw, 0.82rem);
    inline-size: clamp(0.68rem, 1.8vw, 0.82rem);
  }

  @media (max-width: 63.9375em) {
    .hero-deck {
      --deck-width: clamp(18.5rem, 48vw, 25rem);
    }
  }

  @media (max-width: 47.9375em) {
    .hero-deck {
      margin-inline: auto;
      --deck-width: clamp(16.5rem, 78vw, 18.5rem);
    }
  }
</style>

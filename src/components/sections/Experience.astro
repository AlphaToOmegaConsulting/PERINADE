---
import type { SiteData } from "../../types/site";
import ButtonLink from "../ui/ButtonLink.astro";
import Icon from "../ui/Icon.astro";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  experience: SiteData["experience"];
}

const { experience } = Astro.props;
---

<section class="experience section" id="experience" style={`--experience-image: url('${experience.backgroundImage.src}')`}>
  <div class="experience__bg" aria-hidden="true"></div>
  <div class="shell shell--narrow experience__inner">
    <SectionHeading
      eyebrow={experience.eyebrow}
      title={experience.title}
      body={experience.body}
      centered
      light
    />

    <div class="experience__grid">
      {experience.details.map((detail) => (
        <article class="experience__card">
          <Icon name={detail.icon} class="experience__icon" />
          <p class="experience__label">{detail.label}</p>
          <p class="experience__value">{detail.value}</p>
        </article>
      ))}
    </div>

    <div class="experience__cta">
      <ButtonLink href={experience.ctaHref} label={experience.ctaLabel} />
      <p>Sur rendez-vous uniquement · Parking gratuit · Accès facile depuis Carcassonne</p>
    </div>
  </div>
</section>

<style>
  .experience {
    overflow: clip;
    position: relative;
  }

  .experience__bg {
    background-image:
      linear-gradient(180deg, rgba(25, 43, 23, 0.9) 0%, rgba(25, 43, 23, 0.94) 100%),
      var(--experience-image);
    background-position: center 52%;
    background-size: cover;
    inset: 0;
    opacity: 1;
    position: absolute;
  }

  .experience__inner {
    position: relative;
  }

  .experience__grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    margin-top: 2.5rem;
  }

  .experience__card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-card);
    min-height: 8.5rem;
    padding: 1.2rem 0.85rem 1.3rem;
    text-align: center;
  }

  .experience__icon {
    color: var(--color-accent);
    display: inline-flex;
    height: 1.6rem;
    justify-content: center;
    margin-bottom: 0.75rem;
    width: 1.6rem;
  }

  .experience__icon :global(svg) {
    height: 100%;
    width: 100%;
  }

  .experience__label,
  .experience__value {
    margin: 0;
  }

  .experience__label {
    color: rgba(255, 255, 255, 0.56);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  .experience__value {
    color: var(--color-white);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .experience__cta {
    display: grid;
    gap: 1.2rem;
    justify-items: center;
    margin-top: 2rem;
    text-align: center;
  }

  .experience__cta p {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.875rem;
    margin: 0;
  }

  @media (max-width: 1023px) {
    .experience__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .experience__grid {
      grid-template-columns: 1fr;
      margin-top: 2.5rem;
    }
  }
</style>

---
import type { HeroData } from "../../types/site";
import ButtonLink from "../ui/ButtonLink.astro";
import HeroFeatureDeck from "./HeroFeatureDeck.astro";

interface Props {
  hero: HeroData;
}

const { hero } = Astro.props;
---

<section class="hero" id="hero" style={`--hero-image: url('${hero.backgroundImage.src}')`}>
  <div class="hero__background" aria-hidden="true"></div>
  <div class="shell hero__shell">
    <div class="hero__content">
      <div class="hero__eyebrow-wrap">
        <span class="hero__eyebrow-line"></span>
        <p class="hero__eyebrow">{hero.eyebrow}</p>
      </div>

      <h1 class="hero__title">
        {hero.title.map((line) => <span>{line}</span>)}
      </h1>

      <p class="hero__body">{hero.body}</p>

      <ButtonLink href={hero.ctaHref} label={hero.ctaLabel} variant="hero" />

      <ul class="hero__meta" aria-label="Informations principales">
        {hero.meta.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="hero__media">
      <HeroFeatureDeck cards={hero.featuredCards} />
    </div>
  </div>
</section>

<style>
  .hero {
    background: #1b1d17;
    color: var(--color-white);
    min-height: calc(100svh - var(--header-height) - var(--hero-fold-offset));
    overflow: clip;
    position: relative;
  }

  .hero__background {
    background-image:
      var(--overlay-hero-left),
      var(--overlay-hero-bottom),
      var(--hero-image);
    background-position: center 40%;
    background-size: cover;
    inset: 0;
    position: absolute;
  }

  .hero__shell {
    align-items: end;
    display: flex;
    min-height: calc(100svh - var(--header-height) - var(--hero-fold-offset));
    padding-bottom: 3.75rem;
    padding-top: calc(var(--header-height) + 1.1rem);
    position: relative;
  }

  .hero__content {
    display: grid;
    gap: 1.85rem;
    max-width: 30rem;
  }

  .hero__eyebrow-wrap {
    align-items: center;
    display: flex;
    gap: 0.75rem;
  }

  .hero__eyebrow-line {
    background: var(--color-accent);
    display: inline-block;
    height: 2px;
    width: 2.5rem;
  }

  .hero__eyebrow {
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.8125rem;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .hero__title {
    color: var(--color-white);
    display: grid;
    font-size: var(--display-hero);
    letter-spacing: 0.025em;
    line-height: 0.94;
    margin: 0;
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
    text-transform: uppercase;
  }

  .hero__body {
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.08rem;
    line-height: 1.6;
    margin: 0;
    max-width: 24rem;
    text-shadow: 0 6px 18px rgba(0, 0, 0, 0.16);
  }

  .hero__meta {
    color: rgba(255, 255, 255, 0.4);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.6875rem;
    gap: 0.75rem 2rem;
    letter-spacing: 0.15em;
    list-style: none;
    margin: 0.8rem 0 0;
    padding: 0;
    text-transform: uppercase;
  }

  .hero__media {
    bottom: 2rem;
    pointer-events: none;
    position: absolute;
    right: var(--page-padding);
    width: min(100%, 29.5rem);
  }

  @media (max-width: 1023px) {
    .hero__shell {
      align-items: center;
      display: grid;
      grid-template-columns: 1fr;
      padding-bottom: 3.25rem;
      padding-top: calc(var(--header-height) + 0.9rem);
    }

    .hero__media {
      bottom: auto;
      pointer-events: auto;
      position: static;
      justify-content: center;
      margin-top: 0.6rem;
      padding-bottom: 0;
      right: auto;
      width: 100%;
    }
  }

  @media (max-width: 767px) {
    .hero__shell {
      min-height: max(32rem, calc(100svh - var(--header-height) - var(--hero-fold-offset)));
      padding-bottom: 2.75rem;
      padding-top: calc(var(--header-height) + 0.7rem);
    }

    .hero__content {
      gap: 1.5rem;
      max-width: 20rem;
    }

    .hero__title {
      font-size: clamp(3rem, 12vw, 4.25rem);
    }

    .hero__body {
      font-size: 1rem;
    }

    .hero__meta {
      gap: 0.5rem 1.25rem;
      margin-top: 0.25rem;
    }

    .hero__media {
      margin-top: 0.35rem;
    }
  }
</style>

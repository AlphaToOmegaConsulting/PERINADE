---
import type { HeroData } from "../../types/site";
import ActionLink from "../ui/actions/ActionLink.astro";
import HeroFeatureDeck from "./HeroFeatureDeck.astro";

interface Props {
  hero: HeroData;
}

const { hero } = Astro.props;
---

<section class="hero" id="hero" style={`--hero-image: url('${hero.backgroundImage.src}')`}>
  <div class="hero__background" aria-hidden="true"></div>
  <div class="shell hero__shell">
    <div class="hero__content" data-reveal-group data-reveal-stagger="95">
      <div class="hero__eyebrow-wrap" data-reveal="up">
        <span class="hero__eyebrow-line"></span>
        <p class="hero__eyebrow">{hero.eyebrow}</p>
      </div>

      <h1 class="hero__title" data-reveal="up">
        {hero.title.map((line) => <span>{line}</span>)}
      </h1>

      <p class="hero__body" data-reveal="up">{hero.body}</p>

      <ActionLink href={hero.ctaHref} label={hero.ctaLabel} variant="primary" size="lg" interaction="emphasis" class="hero-cta" data-reveal="up" />

      <ul class="hero__meta" aria-label="Informations principales" data-reveal-group data-reveal-stagger="60">
        {hero.meta.map((item) => <li data-reveal="up">{item}</li>)}
      </ul>
    </div>

    <div class="hero__media" data-reveal="zoom">
      <HeroFeatureDeck cards={hero.featuredCards} />
    </div>
  </div>
</section>

<style>
  .hero {
    background: #1b1d17;
    color: var(--color-white);
    min-height: calc(100svh - var(--header-height) - var(--hero-fold-offset));
    overflow: clip;
    position: relative;
  }

  .hero__background {
    background-image:
      var(--overlay-hero-left),
      var(--overlay-hero-bottom),
      var(--hero-image);
    background-position: center 40%;
    background-size: cover;
    inset: 0;
    position: absolute;
  }

  .hero__shell {
    align-items: end;
    display: flex;
    min-height: calc(100svh - var(--header-height) - var(--hero-fold-offset));
    padding-bottom: clamp(2rem, 6vw, 3.75rem);
    padding-top: calc(var(--header-height) + clamp(0.6rem, 1.8vw, 1.1rem));
    position: relative;
  }

  .hero__content {
    display: grid;
    gap: clamp(1.1rem, 3.2vw, 1.85rem);
    max-inline-size: clamp(18rem, 42vw, 30rem);
  }

  .hero__eyebrow-wrap {
    align-items: center;
    display: flex;
    gap: var(--space-xs);
  }

  .hero__eyebrow-line {
    background: var(--color-accent);
    display: inline-block;
    block-size: 0.125rem;
    inline-size: clamp(1.8rem, 6vw, 2.5rem);
  }

  .hero__eyebrow {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(0.72rem, 1.6vw, 0.8125rem);
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .hero__title {
    color: var(--color-white);
    display: grid;
    font-size: var(--display-hero);
    letter-spacing: 0.025em;
    line-height: 0.94;
    margin: 0;
    text-shadow: 0 0.625rem 1.875rem rgba(0, 0, 0, 0.28);
    text-transform: uppercase;
  }

  .hero__body {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(0.95rem, 2vw, 1.08rem);
    line-height: 1.6;
    margin: 0;
    max-inline-size: clamp(16rem, 33vw, 24rem);
    text-shadow: 0 0.375rem 1.125rem rgba(0, 0, 0, 0.16);
  }

  .hero__meta {
    color: rgba(255, 255, 255, 0.56);
    display: flex;
    flex-wrap: wrap;
    font-size: clamp(0.64rem, 1.5vw, 0.6875rem);
    gap: var(--space-xs) clamp(1rem, 3vw, 2rem);
    letter-spacing: 0.15em;
    list-style: none;
    margin: var(--space-xs) 0 0;
    padding: 0;
    text-transform: uppercase;
  }

  .hero__media {
    bottom: clamp(0.8rem, 2.8vw, 2rem);
    pointer-events: none;
    position: absolute;
    right: var(--page-padding);
    width: min(100%, 29.5rem);
  }

  @media (max-width: 63.9375em) {
    .hero__shell {
      align-items: center;
      display: grid;
      grid-template-columns: 1fr;
      padding-bottom: clamp(1.5rem, 5vw, 3.25rem);
      padding-top: calc(var(--header-height) + clamp(0.5rem, 1.8vw, 0.9rem));
    }

    .hero__media {
      bottom: auto;
      pointer-events: auto;
      position: static;
      justify-content: center;
      margin-top: var(--space-xs);
      padding-bottom: 0;
      right: auto;
      width: 100%;
    }
  }

  @media (max-width: 47.9375em) {
    .hero__shell {
      min-height: max(30rem, calc(100svh - var(--header-height) - var(--hero-fold-offset)));
      padding-bottom: clamp(1.6rem, 6vw, 2.75rem);
      padding-top: calc(var(--header-height) + clamp(0.45rem, 1.6vw, 0.7rem));
    }

    .hero__content {
      gap: clamp(1rem, 4vw, 1.5rem);
      max-inline-size: min(100%, 20rem);
    }

    .hero__title {
      font-size: clamp(3rem, 12vw, 4.25rem);
    }

    .hero__body {
      font-size: clamp(0.94rem, 3.8vw, 1rem);
    }

    .hero__meta {
      gap: var(--space-2xs) clamp(0.8rem, 4vw, 1.25rem);
      margin-top: var(--space-2xs);
    }

    .hero__media {
      margin-top: var(--space-2xs);
    }
  }
</style>

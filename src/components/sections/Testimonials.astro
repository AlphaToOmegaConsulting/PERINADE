---
import type { SiteData } from "../../types/site";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  testimonials: SiteData["testimonials"];
}

const { testimonials } = Astro.props;
---

<section class="testimonials section section--soft">
  <div class="shell shell--narrow">
    <SectionHeading eyebrow={testimonials.eyebrow} title={testimonials.title} centered />

    <div class="testimonials__grid" data-reveal-group data-reveal-stagger="75">
      {testimonials.items.map((item) => (
        <article class="testimonials__card ui-hover-lift" data-reveal="up">
          <div class="testimonials__stars" aria-hidden="true">
            {Array.from({ length: item.rating }).map(() => <span>★</span>)}
          </div>
          <p class="testimonials__quote">“{item.quote}”</p>
          <p class="testimonials__author">
            <strong>{item.author}</strong>
            <span> — {item.meta}</span>
          </p>
        </article>
      ))}
    </div>

    <div class="testimonials__press" data-reveal-group data-reveal-stagger="45">
      <p data-reveal="up">{testimonials.pressLabel}</p>
      <div data-reveal-group data-reveal-stagger="45">
        {testimonials.pressLogos.map((logo) => <span data-reveal="up">{logo}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials :global(.section-heading__title) {
    font-size: clamp(2.8rem, 4vw, 3.4rem);
  }

  .testimonials__grid {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 2.45rem;
  }

  .testimonials__card {
    background: var(--color-white);
    border: 1px solid var(--color-card-border-soft);
    border-radius: var(--radius-card);
    min-height: 13rem;
    padding: 1.55rem 1.45rem 1.4rem;
    position: relative;
  }

  .testimonials__card::after {
    color: rgba(196, 156, 110, 0.18);
    content: "99";
    font-family: var(--font-display);
    font-size: 2rem;
    position: absolute;
    right: 1rem;
    top: 1rem;
  }

  .testimonials__stars {
    color: var(--color-accent-text);
    display: flex;
    gap: 0.15rem;
    margin-bottom: 1rem;
  }

  .testimonials__quote {
    color: rgba(44, 44, 44, 0.82);
    font-style: italic;
    line-height: 1.68;
    margin: 0 0 1rem;
  }

  .testimonials__author {
    margin: 0;
  }

  .testimonials__author span {
    color: var(--color-muted);
  }

  .testimonials__press {
    border-top: 1px solid rgba(44, 44, 44, 0.12);
    display: grid;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.45rem;
    text-align: center;
  }

  .testimonials__press p {
    color: var(--color-muted);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    margin: 0;
    text-transform: uppercase;
  }

  .testimonials__press div {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    justify-content: center;
  }

  .testimonials__press span {
    color: rgba(44, 44, 44, 0.36);
    font-family: var(--font-display);
    font-size: 1.125rem;
  }

  @media (max-width: 1023px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Contact from "../components/sections/Contact.astro";
import Experience from "../components/sections/Experience.astro";
import Footer from "../components/sections/Footer.astro";
import Gallery from "../components/sections/Gallery.astro";
import Header from "../components/sections/Header.astro";
import Hero from "../components/sections/Hero.astro";
import History from "../components/sections/History.astro";
import Reasons from "../components/sections/Reasons.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import Wines from "../components/sections/Wines.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteData } from "../data/index";

const locale = "fr";
const site = await getSiteData(locale);
const alternates = [
  { locale: "fr", href: "/" },
  { locale: "en", href: "/en" },
  { locale: "es", href: "/es" }
];

const heroImageUrl = site.hero.backgroundImage.src;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Winery",
  "name": "Domaine de la Périnade",
  "url": "https://www.perinade.fr",
  "telephone": "+33 4 68 XX XX XX",
  "email": "contact@perinade.fr",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Carcassonne",
    "addressRegion": "Occitanie",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.2",
    "longitude": "2.35"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "09:00",
      "closes": "18:00"
    }
  ],
  "sameAs": [
    "https://www.instagram.com/",
    "https://www.facebook.com/"
  ],
  "description": "Domaine familial près de Carcassonne. Vins authentiques du Languedoc depuis 1830.",
  "foundingDate": "1830",
  "priceRange": "€€"
});
---

<BaseLayout locale={locale} canonicalPath="/" alternates={alternates} heroImageUrl={heroImageUrl} jsonLd={jsonLd}>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={{ fr: "/", en: "/en", es: "/es" }} />
  <main id="main-content">
    <Hero hero={site.hero} />
    <Reasons reasons={site.reasons} />
    <Experience experience={site.experience} />
    <Gallery gallery={site.gallery} />
    <Testimonials testimonials={site.testimonials} />
    <History history={site.history} />
    <Wines wines={site.wines} />
    <Contact contact={site.contact} />
  </main>
  <Footer footer={site.footer} />
</BaseLayout>

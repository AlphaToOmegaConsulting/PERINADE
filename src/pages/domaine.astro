---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import DomaineHero from "../components/domaine/DomaineHero.astro";
import TerroirSection from "../components/domaine/TerroirSection.astro";
import FamilyStorySection from "../components/domaine/FamilyStorySection.astro";
import DomainStatsBar from "../components/domaine/DomainStatsBar.astro";
import VisitDomainCta from "../components/domaine/VisitDomainCta.astro";
import DomainWinesShowcase from "../components/domaine/DomainWinesShowcase.astro";
import DomainContactSection from "../components/domaine/DomainContactSection.astro";
import { getSiteData, getDomaineData } from "../data/index";

const locale = "fr";
const site = await getSiteData(locale);
const domainePage = await getDomaineData(locale);

const themeVars = [
  `--domaine-section-space-desktop:${domainePage.theme.sectionDesktop}`,
  `--domaine-section-space-tablet:${domainePage.theme.sectionTablet}`,
  `--domaine-section-space-mobile:${domainePage.theme.sectionMobile}`
].join(";");

const alternates = [
  { locale: "fr", href: "/domaine" },
  { locale: "en", href: "/en/domaine" },
  { locale: "es", href: "/es/domaine" }
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["Winery", "LocalBusiness", "TouristAttraction"],
  "name": "Domaine de la Périnade",
  "url": "https://www.perinade.fr/domaine",
  "telephone": "+33468000000",
  "email": "contact@perinade.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Domaine de la Périnade",
    "addressLocality": "Carcassonne",
    "addressRegion": "Occitanie",
    "postalCode": "11000",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.2130",
    "longitude": "2.3536"
  },
  "hasMap": "https://maps.google.com/?q=Domaine+de+la+Perinade+Minervois+Languedoc",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "11:00",
      "closes": "16:00"
    }
  ],
  "sameAs": [
    "https://www.instagram.com/domaineperinade/",
    "https://www.facebook.com/domaineperinade/"
  ],
  "description": "Domaine viticole familial en Languedoc-Roussillon depuis 1830, situé dans l'Aude près de Carcassonne. 100 ha dont 40 ha de vignes AOP Minervois et IGP Pays d'Oc. Visite, dégustation et oenotourisme.",
  "foundingDate": "1830",
  "priceRange": "€–€€",
  "knowsLanguage": ["fr", "en", "es"],
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Languedoc-Roussillon, Occitanie, Aude"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "127",
    "bestRating": "5",
    "worstRating": "1"
  },
  "makesOffer": [
    {
      "@type": "Offer",
      "name": "Visite guidée du domaine viticole",
      "description": "Promenade dans le vignoble Minervois, visite du chai et dégustation de 5 cuvées AOP commentée par le vigneron.",
      "price": "15.00",
      "priceCurrency": "EUR",
      "url": "https://www.perinade.fr/visites"
    }
  ],
  "containsPlace": [
    {
      "@type": "Place",
      "name": "Vignoble AOP Minervois",
      "description": "40 hectares de vignes en AOP Minervois et IGP Pays d'Oc, entre Canal du Midi et rivière Fresquel."
    },
    {
      "@type": "Place",
      "name": "Chai du Domaine de la Périnade",
      "description": "Chai construit en 2020, dédié à la vinification des cuvées AOP Minervois."
    }
  ]
});
---

<BaseLayout title={domainePage.seo.title} description={domainePage.seo.description} locale={locale} canonicalPath="/domaine" alternates={alternates} jsonLd={jsonLd}>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={{ fr: "/domaine", en: "/en/domaine", es: "/es/domaine" }} />
  <main id="main-content" class="domaine-page" style={themeVars}>
    <DomaineHero hero={domainePage.hero} />
    <TerroirSection terroir={domainePage.terroir} />
    <FamilyStorySection family={domainePage.family} />
    <DomainStatsBar stats={domainePage.statsBar} />
    <VisitDomainCta visitCta={domainePage.visitCta} />
    <DomainWinesShowcase wines={domainePage.wines} />
    <DomainContactSection contact={domainePage.contact} />
  </main>
  <Footer footer={site.footer} />
</BaseLayout>

<style>
  .domaine-page {
    --domaine-soft: #f4f1ec;
  }

  .domaine-page :global(.shell) {
    max-width: 74rem;
  }

  .domaine-page :global(.section) {
    padding-block: var(--domaine-section-space-desktop);
  }

  .domaine-page :global(.section--soft),
  .domaine-page :global(.section--white) {
    border-top: 1px solid rgba(44, 44, 44, 0.04);
  }

  .domaine-page :global(.section--soft) {
    background: var(--domaine-soft);
  }

  @media (max-width: 63.9375em) {
    .domaine-page :global(.section) {
      padding-block: var(--domaine-section-space-tablet);
    }
  }

  @media (max-width: 47.9375em) {
    .domaine-page :global(.section) {
      padding-block: var(--domaine-section-space-mobile);
    }
  }
</style>

<script>
// Scroll spy
const sections = document.querySelectorAll('.ds-section');
const navLinks = document.querySelectorAll('nav a');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navLinks.forEach(l => l.classList.remove('active'));
      const target = document.querySelector('nav a[href="#' + e.target.id + '"]');
      if (target) target.classList.add('active');
    }
  });
}, { threshold: 0.2 });
sections.forEach(s => obs.observe(s));

function toggleAccordion(btn) {
  const expanded = btn.getAttribute('aria-expanded') === 'true';
  btn.setAttribute('aria-expanded', !expanded);
  const panel = btn.nextElementSibling;
  if (!expanded) panel.removeAttribute('hidden');
  else panel.setAttribute('hidden', '');
}

function toggleChip(btn) {
  const group = btn.closest('.chip-group');
  group.querySelectorAll('.ui-choice-chip').forEach(c => c.setAttribute('aria-pressed', 'false'));
  btn.setAttribute('aria-pressed', 'true');
}

function adjustCounter(btn, delta) {
  const val = btn.parentElement.querySelector('.ui-counter__value');
  val.textContent = Math.max(1, Math.min(10, parseInt(val.textContent) + delta));
}

function switchTab(btn, id) {
  const tabs = btn.closest('.ui-tabs');
  tabs.querySelectorAll('.ui-tabs__trigger').forEach(t => t.setAttribute('aria-selected', 'false'));
  tabs.querySelectorAll('.ui-tabs__panel').forEach(p => p.setAttribute('hidden', ''));
  btn.setAttribute('aria-selected', 'true');
  document.getElementById(id).removeAttribute('hidden');
}
</script>

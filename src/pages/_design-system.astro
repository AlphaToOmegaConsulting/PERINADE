---
// Design System — dev-only page, not linked from nav
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex,nofollow">
<title>Design System — Périnade</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --color-bg: #ffffff;
  --color-white: #ffffff;
  --color-text: #2c2c2c;
  --color-text-strong: #1a1a1a;
  --color-muted: #595959;
  --color-muted-light: #6b6b6b;
  --color-soft: #faf7f2;
  --color-soft-strong: #f0ebe3;
  --color-deep-green: #192b17;
  --color-accent: #c49c6e;
  --color-cta: #a85900;
  --color-cta-strong: #8f4b00;
  --color-ink-soft: rgba(18,18,18,0.72);
  --color-card-border-soft: rgba(44,44,44,0.1);
  --radius-card: 1rem;
  --radius-panel: 1.4rem;
  --shadow-soft: 0 0.625rem 1.5rem rgba(24,20,14,0.08);
  --shadow-card: 0 1.125rem 2.375rem rgba(28,22,17,0.08);
  --motion-shadow-hover: 0 1.3rem 2.2rem rgba(20,14,9,0.14);
  --motion-border-hover: rgba(196,156,110,0.48);
  --motion-duration-xs: 140ms;
  --motion-duration-sm: 180ms;
  --motion-duration-md: 240ms;
  --motion-duration-lg: 620ms;
  --motion-ease-standard: cubic-bezier(0.2,0,0,1);
  --motion-ease-emphasized: cubic-bezier(0.21,1,0.31,1);
  --motion-distance-sm: -0.125rem;
  --motion-distance-md: -0.2rem;
  --motion-scale-media: 1.045;
  --font-display: 'Playfair Display', Georgia, serif;
  --font-body: 'Inter', sans-serif;
  --control-accent: var(--color-accent);
}
*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: #f2ede6; color: var(--color-text); display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; font-size: 14px; line-height: 1.5; }
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }

/* ── SIDEBAR ── */
.sidebar {
  background: var(--color-deep-green);
  color: rgba(255,255,255,0.85);
  display: flex; flex-direction: column;
  height: 100vh; position: sticky; top: 0;
  overflow-y: auto; padding: 1.5rem 0;
}
.sidebar-brand { padding: 0 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
.sidebar-brand h1 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 500; color: #fff; line-height: 1.2; }
.sidebar-brand span { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.5; }
nav { padding: 1rem 0; flex: 1; }
nav a { display: flex; align-items: center; gap: 0.5rem; padding: 0.45rem 1.25rem; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.6); transition: color 150ms ease, background 150ms ease; }
nav a:hover, nav a.active { color: #fff; background: rgba(255,255,255,0.07); }
nav a .nav-num { font-size: 0.6rem; opacity: 0.4; width: 1rem; }
.sidebar-footer { padding: 1rem 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.65rem; opacity: 0.35; }

/* ── MAIN ── */
main { padding: 3rem 3rem 6rem; max-width: 1100px; }

/* ── SECTION HEADERS ── */
.ds-section { margin-bottom: 5rem; }
.ds-section-header { margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(44,44,44,0.12); }
.ds-section-header h2 { font-family: var(--font-display); font-size: 1.8rem; font-weight: 500; color: var(--color-text-strong); }
.ds-section-header p { font-size: 0.82rem; color: var(--color-muted); margin-top: 0.3rem; }
.ds-subsection { margin-bottom: 2rem; }
.ds-subsection h3 { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.13em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 1rem; }
.ds-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-start; }
.ds-label { font-size: 0.65rem; color: var(--color-muted); letter-spacing: 0.08em; margin-top: 0.4rem; text-align: center; }

/* ── 1. DESIGN TOKENS ── */
.color-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.75rem; }
.color-swatch { border-radius: 0.6rem; overflow: hidden; box-shadow: var(--shadow-soft); }
.color-swatch__block { height: 3.5rem; }
.color-swatch__info { background: #fff; padding: 0.45rem 0.6rem; }
.color-swatch__name { font-size: 0.62rem; font-weight: 600; color: var(--color-text); }
.color-swatch__val { font-size: 0.58rem; color: var(--color-muted); font-family: monospace; }
.type-scale-row { display: flex; align-items: baseline; gap: 1.5rem; padding: 0.75rem 0; border-bottom: 1px solid rgba(44,44,44,0.06); }
.type-scale-row:last-child { border: none; }
.type-meta { min-width: 120px; font-size: 0.65rem; color: var(--color-muted); font-family: monospace; }
.space-bar { display: flex; align-items: center; gap: 1rem; padding: 0.4rem 0; }
.space-bar__swatch { background: var(--color-accent); border-radius: 2px; height: 1rem; opacity: 0.8; }
.space-bar__label { font-size: 0.65rem; font-family: monospace; color: var(--color-muted); min-width: 90px; }
.token-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
.token-table th { text-align: left; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-muted); padding: 0.5rem 0.75rem; border-bottom: 2px solid rgba(44,44,44,0.1); }
.token-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid rgba(44,44,44,0.05); vertical-align: middle; }
.token-table tr:last-child td { border: none; }
.token-table code { background: rgba(44,44,44,0.06); padding: 0.1rem 0.35rem; border-radius: 0.25rem; font-size: 0.72rem; }
.ease-bar { height: 4px; border-radius: 2px; background: var(--color-accent); width: 100%; margin-top: 0.25rem; opacity: 0.6; }
.shadow-demo { background: #fff; border-radius: var(--radius-card); padding: 1.5rem 2rem; text-align: center; font-size: 0.8rem; color: var(--color-muted); min-width: 160px; }

/* ── 2. BUTTONS ── */
.ui-action {
  align-items: center; appearance: none;
  border: 1px solid transparent; border-radius: 999px;
  color: #fff; cursor: pointer;
  display: inline-flex; font-family: var(--font-body);
  font-size: 0.75rem; font-weight: 600; gap: 0.45rem;
  justify-content: center; letter-spacing: 0.14em;
  line-height: 1; padding-inline: 1.25rem;
  position: relative; text-align: center;
  text-decoration: none; text-transform: uppercase;
  transition: background-color var(--motion-duration-sm) var(--motion-ease-standard),
    border-color var(--motion-duration-sm) var(--motion-ease-standard),
    box-shadow var(--motion-duration-md) var(--motion-ease-standard),
    transform var(--motion-duration-md) var(--motion-ease-standard);
}
.ui-action:hover { box-shadow: var(--motion-shadow-hover); transform: translateY(var(--motion-distance-sm)); }
.ui-action:active { transform: translateY(0); }
.ui-action--sm { min-height: 2.6rem; font-size: 0.7rem; padding-inline: 1rem; }
.ui-action--md { min-height: 3.1rem; }
.ui-action--lg { min-height: 3.8rem; padding-inline: 1.75rem; font-size: 0.8rem; }
.ui-action--primary { background: var(--color-cta); border-color: var(--color-cta); box-shadow: var(--shadow-soft); }
.ui-action--primary:hover { background: var(--color-cta-strong); border-color: var(--color-cta-strong); }
.ui-action--secondary { background: #fff; border-color: var(--color-cta); color: var(--color-cta); }
.ui-action--secondary:hover { background: #f9f5f0; }
.ui-action--ghost { background: transparent; border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.9); }
.ui-action--ghost:hover { background: rgba(255,255,255,0.09); border-color: rgba(255,255,255,0.6); }
.ui-action--text {
  background: transparent; border: none; border-bottom: 1px solid rgba(196,156,110,0.35);
  border-radius: 0; color: var(--color-cta-strong); font-size: 0.8rem;
  min-height: auto; padding: 0 0 0.25rem; letter-spacing: 0.04em; text-transform: none;
  box-shadow: none;
}
.ui-action--text::after { content: " →"; display: inline; }
.ui-action--text:hover { color: var(--color-cta); box-shadow: none; transform: none; }
.ui-action--interaction-emphasis:hover { box-shadow: 0 1.5rem 2.5rem rgba(196,106,0,0.22); transform: translateY(var(--motion-distance-md)); }
.ui-action--tone-inverse.ui-action--secondary { background: transparent; border-color: rgba(255,255,255,0.28); color: #fff; }
.ui-action:disabled, .ui-action--disabled { opacity: 0.45; pointer-events: none; cursor: not-allowed; }
.ui-action--loading { opacity: 0.75; pointer-events: none; }
@keyframes spin { to { transform: rotate(360deg); } }
.spinner { display: inline-block; width: 0.85rem; height: 0.85rem; border: 2px solid currentColor; border-right-color: transparent; border-radius: 999px; animation: spin 900ms linear infinite; }
.dark-bg { background: var(--color-deep-green); border-radius: var(--radius-card); padding: 1.25rem 1.5rem; }

/* ── 3. CARDS ── */
.ui-card { background: var(--color-white); border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); overflow: clip; }
.ui-card--soft { background: var(--color-soft); }
.ui-card--inverse { background: #1a1a1a; border-color: rgba(255,255,255,0.1); color: #fff; }
.ui-card--elevation-soft { box-shadow: var(--shadow-soft); }
.ui-card--elevation-raised { box-shadow: var(--shadow-card); }
.ui-card__content { padding: 1.1rem 1.15rem; display: grid; gap: 0.5rem; }
.ui-card__eyebrow { font-size: 0.65rem; letter-spacing: 0.13em; text-transform: uppercase; color: var(--color-muted); }
.ui-card__title { font-size: 0.95rem; font-weight: 600; }
.ui-card__body { font-size: 0.8rem; color: var(--color-muted); line-height: 1.55; }
.ui-card--interactive {
  transition: transform var(--motion-duration-md) var(--motion-ease-standard),
    box-shadow var(--motion-duration-md) var(--motion-ease-standard),
    border-color var(--motion-duration-sm) var(--motion-ease-standard);
  cursor: pointer;
}
.ui-card--interactive:hover { border-color: var(--motion-border-hover); box-shadow: var(--motion-shadow-hover); transform: translateY(var(--motion-distance-md)); }

/* card grid */
.card-grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
.card-grid-4 { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; }
.card-grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }

/* MediaCard */
.media-card { background: var(--color-white); border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); overflow: hidden; cursor: pointer;
  box-shadow: var(--shadow-soft);
  transition: transform var(--motion-duration-md) var(--motion-ease-standard), box-shadow var(--motion-duration-md) var(--motion-ease-standard), border-color 200ms ease;
}
.media-card:hover { transform: translateY(-0.3125rem); box-shadow: 0 1.5rem 3rem rgba(20,14,9,0.13); border-color: var(--motion-border-hover); }
.media-card__img { height: 140px; overflow: hidden; background: var(--color-soft-strong); }
.media-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 500ms var(--motion-ease-emphasized); }
.media-card:hover .media-card__img img { transform: scale(1.05); }
.media-card__body { padding: 1rem 1.1rem; display: grid; gap: 0.35rem; }
.media-card__eye { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-muted); }
.media-card__title { font-family: var(--font-display); font-size: 1.05rem; font-weight: 500; line-height: 1.25; }

/* ProductCard */
.shop-card { background: #fff; border: 1px solid rgba(44,44,44,0.1); border-radius: 1.25rem; overflow: hidden; }
.shop-card__image { aspect-ratio: 1.2; background: var(--color-soft-strong); overflow: hidden; }
.shop-card__image img { width: 100%; height: 100%; object-fit: cover; }
.shop-card__body { padding: 0.85rem; display: grid; gap: 0.3rem; }
.shop-card__meta { font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: #6b6b6b; }
.shop-card__title { font-size: 0.95rem; font-weight: 600; color: #2c2c2c; }
.shop-card__price { font-size: 1.2rem; font-weight: 600; color: #2c2c2c; margin-top: 0.2rem; }
.shop-card--after {
  box-shadow: var(--shadow-soft);
  transition: transform 300ms var(--motion-ease-emphasized), box-shadow 300ms var(--motion-ease-emphasized), border-color 200ms ease;
  cursor: pointer;
}
.shop-card--after:hover { transform: translateY(-0.3125rem); box-shadow: 0 1.5rem 3rem rgba(20,14,9,0.13); border-color: var(--motion-border-hover); }
.shop-card--after .shop-card__image img { transition: transform 500ms var(--motion-ease-emphasized); }
.shop-card--after:hover .shop-card__image img { transform: scale(1.05); }

/* InfoCard */
.info-card { background: var(--color-soft); border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); padding: 1.25rem; display: grid; gap: 0.6rem; }
.info-card__tag { display: inline-block; background: rgba(196,156,110,0.15); color: var(--color-cta); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 0.3rem; }
.info-card__icon { width: 2.6rem; height: 2.6rem; background: rgba(25,43,23,0.08); border-radius: 999px; display: flex; align-items: center; justify-content: center; color: var(--color-deep-green); }
.info-card__title { font-size: 1rem; font-weight: 600; }
.info-card__list { display: grid; gap: 0.3rem; }
.info-card__list li { font-size: 0.78rem; color: var(--color-muted); list-style: none; display: flex; gap: 0.4rem; }
.info-card__list li::before { content: "·"; color: var(--color-accent); }
.info-card__cta { font-size: 0.78rem; color: var(--color-cta); font-weight: 600; }
.info-card__cta::after { content: " →"; }

/* PricingCard */
.plan { background: var(--color-white); border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); padding: 1.5rem; display: grid; gap: 0.7rem; box-shadow: var(--shadow-soft); position: relative; }
.plan--highlighted { background: var(--color-deep-green); color: #fff; border-color: transparent; }
.plan--highlighted .plan__subtitle, .plan--highlighted .plan__feature { color: rgba(255,255,255,0.7); }
.plan__badge { position: absolute; top: -0.6rem; right: 1rem; background: var(--color-accent); color: #fff; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.65rem; border-radius: 999px; }
.plan__name { font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.6; }
.plan__title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 500; }
.plan__price { font-size: 2rem; font-weight: 700; line-height: 1; }
.plan__price span { font-size: 0.8rem; font-weight: 400; opacity: 0.7; }
.plan__subtitle { font-size: 0.78rem; color: var(--color-muted); }
.plan__features { display: grid; gap: 0.4rem; }
.plan__feature { font-size: 0.78rem; color: var(--color-muted); display: flex; gap: 0.45rem; }
.plan__feature::before { content: "✓"; color: var(--color-accent); font-weight: 700; flex-shrink: 0; }
.plan__cta { margin-top: 0.5rem; }

/* CtaPanel */
.cta-panel { border-radius: var(--radius-panel); padding: 2rem 2.5rem; display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: center; }
.cta-panel--default { background: var(--color-soft); border: 1px solid var(--color-card-border-soft); }
.cta-panel--inverse { background: var(--color-deep-green); color: #fff; }
.cta-panel__eye { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.5rem; }
.cta-panel__title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; margin-bottom: 0.5rem; }
.cta-panel--inverse .cta-panel__title { color: #fff; }
.cta-panel__body { font-size: 0.82rem; color: var(--color-muted); }
.cta-panel--inverse .cta-panel__body { color: rgba(255,255,255,0.7); }
.cta-panel__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

/* ── 4. CONTROLS ── */
/* Accordion */
.ui-accordion { border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); overflow: hidden; background: #fff; }
.ui-accordion__item + .ui-accordion__item { border-top: 1px solid rgba(44,44,44,0.07); }
.ui-accordion__trigger {
  width: 100%; background: none; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 1.25rem; font-family: var(--font-body); font-size: 0.88rem; font-weight: 600;
  color: var(--color-text); text-align: left;
  transition: color 180ms ease, background 180ms ease;
}
.ui-accordion__trigger:hover { color: var(--color-accent); background: rgba(196,156,110,0.04); }
.ui-accordion__trigger[aria-expanded="true"] { color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 5%, white); }
.ui-accordion__chevron { font-size: 0.75rem; transition: transform 180ms ease; display: inline-block; opacity: 0.6; }
.ui-accordion__trigger[aria-expanded="true"] .ui-accordion__chevron { transform: rotate(180deg); }
.ui-accordion__panel { padding: 0 1.25rem 1rem; font-size: 0.82rem; color: var(--color-muted); line-height: 1.65; }
.ui-accordion__panel[hidden] { display: none; }

/* Tabs */
.ui-tabs { background: #fff; border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); overflow: hidden; }
.ui-tabs__list { display: flex; border-bottom: 1px solid rgba(44,44,44,0.08); padding: 0 0.5rem; }
.ui-tabs__trigger {
  background: none; border: none; border-bottom: 2px solid transparent;
  cursor: pointer; font-family: var(--font-body); font-size: 0.78rem; font-weight: 600;
  letter-spacing: 0.08em; padding: 0.85rem 1rem; color: var(--color-muted);
  transition: color 180ms ease, border-color 180ms ease;
}
.ui-tabs__trigger:hover { color: var(--color-text); }
.ui-tabs__trigger[aria-selected="true"] { color: var(--color-accent); border-bottom-color: var(--color-accent); }
.ui-tabs__panel { padding: 1.25rem; font-size: 0.82rem; color: var(--color-muted); line-height: 1.65; }
.ui-tabs__panel[hidden] { display: none; }

/* ChoiceChipGroup */
.chip-group { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.ui-choice-chip {
  background: #fff; border: 1px solid rgba(44,44,44,0.15); border-radius: 999px;
  cursor: pointer; font-family: var(--font-body); font-size: 0.75rem; font-weight: 500;
  padding: 0.45rem 1rem; color: var(--color-text);
  transition: border-color 180ms ease, color 180ms ease, background 180ms ease;
}
.ui-choice-chip:hover { border-color: var(--color-accent); color: var(--color-accent); }
.ui-choice-chip[aria-pressed="true"] { background: color-mix(in srgb, var(--color-accent) 8%, white); border-color: var(--color-accent); color: var(--color-cta); }

/* CounterField */
.ui-counter { display: inline-flex; align-items: center; gap: 0; border: 1px solid rgba(44,44,44,0.15); border-radius: 999px; overflow: hidden; background: #fff; }
.ui-counter__button { background: none; border: none; cursor: pointer; font-size: 1.1rem; width: 2.4rem; height: 2.4rem; display: flex; align-items: center; justify-content: center; color: var(--color-muted); transition: color 150ms ease, background 150ms ease; }
.ui-counter__button:hover { color: var(--color-cta); background: rgba(196,156,110,0.07); }
.ui-counter__value { font-size: 0.88rem; font-weight: 600; min-width: 2rem; text-align: center; }

/* ToggleField */
.ui-toggle { display: flex; align-items: center; gap: 0.65rem; cursor: pointer; font-size: 0.82rem; }
.ui-toggle input { accent-color: var(--color-accent); width: 1rem; height: 1rem; cursor: pointer; }

/* ── 5. NAVIGATION ── */
.ui-nav-link { display: inline-flex; letter-spacing: 0.01em; position: relative; text-decoration: none; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; transition: color 180ms ease; }
.ui-nav-link::after { background: currentColor; border-radius: 999px; content: ""; height: 0.125rem; inset-inline: 0; opacity: 0; position: absolute; top: calc(100% + 0.35rem); transform: scaleX(0.7); transform-origin: center; transition: opacity 180ms ease, transform 180ms ease; }
.ui-nav-link:hover::after, .ui-nav-link.is-active::after { opacity: 1; transform: scaleX(1); }
.ui-nav-link--default { color: rgba(255,255,255,0.8); }
.ui-nav-link--default:hover, .ui-nav-link--default.is-active { color: #fff; }
.ui-nav-link--quiet { color: rgba(44,44,44,0.7); }
.ui-nav-link--quiet:hover, .ui-nav-link--quiet.is-active { color: var(--color-text-strong); }
.ui-nav-link--footer { color: rgba(255,255,255,0.62); font-size: 0.82rem; letter-spacing: 0.04em; text-transform: none; }
.ui-nav-link--footer:hover { color: rgba(255,255,255,0.9); }
.ui-nav-link--language { font-size: 0.65rem; letter-spacing: 0.2em; }

/* ── 7. ICONS ── */
.icons-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 0.75rem; }
.icon-item { background: #fff; border: 1px solid var(--color-card-border-soft); border-radius: 0.75rem; padding: 1rem 0.75rem; display: flex; flex-direction: column; align-items: center; gap: 0.6rem; box-shadow: var(--shadow-soft); transition: border-color 180ms ease; }
.icon-item:hover { border-color: var(--motion-border-hover); }
.icon-item svg { width: 1.5rem; height: 1.5rem; }
.icon-item span { font-size: 0.58rem; letter-spacing: 0.06em; color: var(--color-muted); }

/* ── 8. MOTION ── */
.motion-demo { background: #fff; border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); padding: 1.5rem; }
.lift-demo { border-radius: var(--radius-card); background: var(--color-soft); border: 1px solid var(--color-card-border-soft); padding: 1rem 1.25rem; display: inline-block; cursor: pointer; box-shadow: var(--shadow-soft); will-change: transform; transition: transform var(--motion-duration-md) var(--motion-ease-standard), box-shadow var(--motion-duration-md) var(--motion-ease-standard), border-color var(--motion-duration-sm) var(--motion-ease-standard); }
.lift-demo:hover { transform: translateY(var(--motion-distance-md)); box-shadow: var(--motion-shadow-hover); border-color: var(--motion-border-hover); }
.lift-demo--spring { transition: transform 300ms var(--motion-ease-emphasized), box-shadow 300ms var(--motion-ease-emphasized), border-color 200ms ease; }
.lift-demo--spring:hover { transform: translateY(-0.3125rem); }
.media-demo { border-radius: var(--radius-card); overflow: hidden; cursor: pointer; display: inline-block; width: 200px; }
.media-demo img { width: 100%; height: 130px; object-fit: cover; display: block; transition: transform var(--motion-duration-lg) var(--motion-ease-emphasized); }
.media-demo:hover img { transform: scale(var(--motion-scale-media)); }
.underline-demo { display: inline-flex; font-size: 0.9rem; font-weight: 500; color: var(--color-cta-strong); position: relative; cursor: pointer; }
.underline-demo::after { background: currentColor; border-radius: 999px; content: ""; height: 0.08rem; inset-inline: 0; opacity: 0.8; position: absolute; bottom: -0.2rem; transform: scaleX(0.74); transform-origin: left; transition: transform 180ms var(--motion-ease-standard); }
.underline-demo:hover::after { transform: scaleX(1); }
.arrow-demo { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 600; color: var(--color-cta); cursor: pointer; }
.arrow-demo .arr { display: inline-block; transform: translateX(0); transition: transform 180ms var(--motion-ease-standard); }
.arrow-demo:hover .arr { transform: translateX(0.2rem); }

/* ── 9. SECTION PATTERNS ── */
.section-pattern { background: #e8e3db; border-radius: var(--radius-panel); overflow: hidden; }
.section-pattern__label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-muted); padding: 0.75rem 1rem 0; }
.pattern-wrap { padding: 1.25rem; transform-origin: top left; }

/* Hero mini */
.hero-mini { background: linear-gradient(135deg, #192b17 0%, #1a2a18 60%, #2a1a0a 100%); border-radius: 0.75rem; padding: 2rem; color: #fff; position: relative; overflow: hidden; }
.hero-mini::before { content: ''; position: absolute; inset: 0; background: url('https://images.unsplash.com/photo-1516594915697-87eb3b1c14ea?w=600&q=50') center/cover; opacity: 0.25; }
.hero-mini__content { position: relative; }
.hero-mini__eye { font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.6rem; }
.hero-mini__title { font-family: var(--font-display); font-size: 1.8rem; font-weight: 500; line-height: 1.15; margin-bottom: 0.75rem; }
.hero-mini__body { font-size: 0.78rem; color: rgba(255,255,255,0.75); margin-bottom: 1.25rem; max-width: 340px; }
.hero-mini__actions { display: flex; gap: 0.6rem; }

/* reasons mini */
.reasons-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
.reason-card { text-align: center; padding: 1.25rem 1rem; background: #fff; border: 1px solid var(--color-card-border-soft); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); }
.reason-icon { width: 3rem; height: 3rem; background: rgba(25,43,23,0.09); border-radius: 999px; display: flex; align-items: center; justify-content: center; color: var(--color-deep-green); margin: 0 auto 0.75rem; }
.reason-card h4 { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.35rem; }
.reason-card p { font-size: 0.75rem; color: var(--color-muted); line-height: 1.55; }

/* Testimonials card */
.test-card { border-radius: var(--radius-card); max-width: 260px; position: relative; }
.test-card__stars { color: var(--color-accent); font-size: 0.9rem; margin-bottom: 0.75rem; }
.test-card__quote { font-style: italic; color: rgba(44,44,44,0.82); font-size: 0.82rem; line-height: 1.65; margin-bottom: 0.75rem; }
.test-card__author { font-size: 0.78rem; color: var(--color-muted); }
.test-card__author strong { color: var(--color-text); }
.test-card::after { content: '"'; color: rgba(196,156,110,0.18); font-family: var(--font-display); font-size: 4rem; position: absolute; right: 0.8rem; top: 0.3rem; line-height: 1; }
.test-card--after { background: var(--color-white); border: 1px solid var(--color-card-border-soft); box-shadow: var(--shadow-soft); padding: 1.25rem;
  transition: transform 300ms var(--motion-ease-emphasized), box-shadow 300ms var(--motion-ease-emphasized), border-color 200ms ease; }
.test-card--after:hover { transform: translateY(-0.3125rem); box-shadow: 0 1.5rem 3rem rgba(20,14,9,0.13); border-color: var(--motion-border-hover); }

/* Misc */
.tag { display: inline-block; background: rgba(196,156,110,0.15); color: var(--color-cta); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.15rem 0.45rem; border-radius: 0.25rem; font-weight: 600; }
.badge-group { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
</style>
</head>

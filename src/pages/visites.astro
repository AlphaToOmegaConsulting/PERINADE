---
import FinalCta from "../components/visits/FinalCta.astro";
import PairingAddon from "../components/visits/PairingAddon.astro";
import PricingPlans from "../components/visits/PricingPlans.astro";
import BookingSection from "../components/visits/BookingSection.astro";
import ExperienceTimeline from "../components/visits/ExperienceTimeline.astro";
import VisitHero from "../components/visits/VisitHero.astro";
import WinesShowcase from "../components/visits/WinesShowcase.astro";
import AccessSection from "../components/visits/AccessSection.astro";
import TrustBar from "../components/visits/TrustBar.astro";
import ExtendedEscape from "../components/visits/ExtendedEscape.astro";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import { getSiteData, getVisitsData } from "../data/index";
import { buildVisitsThemeStyle } from "../utils/visits-theme";
import BaseLayout from "../layouts/BaseLayout.astro";

const locale = "fr";
const site = await getSiteData(locale);
const visitsPage = await getVisitsData(locale);
const visitsThemeStyle = buildVisitsThemeStyle(visitsPage.theme);

const alternates = [
  { locale: "fr", href: "/visites" },
  { locale: "en", href: "/en/visits" },
  { locale: "es", href: "/es/visitas" }

            "streetAddress": "Domaine de la Périnade",
            "addressLocality": "Carcassonne",
            "addressRegion": "Occitanie",
            "postalCode": "11000",
            "addressCountry": "FR"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": "43.2130",
            "longitude": "2.3536"
          }
        },
        "offers": {
          "@type": "Offer",
          "name": "Visite standard",
          "price": "15",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "validFrom": "2026-01-01",
          "url": "https://www.perinade.fr/visites#booking"
        },
        "organizer": {
          "@type": "Organization",
          "name": "Domaine de la Périnade",
          "url": "https://www.perinade.fr"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "127",
          "bestRating": "5",
          "worstRating": "1"
        },
        "inLanguage": ["fr", "en", "es"]
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Event",
        "name": "Visite Gourmande — Dégustation & Accord Fromages, Domaine de la Périnade",
        "description": "Visite guidée 1h30 avec planche fromages et charcuterie artisanale du Languedoc. Accord mets et vins AOP Minervois près de Carcassonne.",
        "url": "https://www.perinade.fr/visites",
        "startDate": "2026-03-01",
        "endDate": "2026-12-31",
        "eventSchedule": {
          "@type": "Schedule",
          "repeatFrequency": "P1D",
          "startTime": "11:00",
          "endTime": "16:00",
          "byDay": ["https://schema.org/Monday", "https://schema.org/Tuesday", "https://schema.org/Wednesday", "https://schema.org/Thursday", "https://schema.org/Friday", "https://schema.org/Saturday", "https://schema.org/Sunday"]
        },
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Domaine de la Périnade",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Domaine de la Périnade",
            "addressLocality": "Carcassonne",
            "addressRegion": "Occitanie",
            "postalCode": "11000",
            "addressCountry": "FR"
          }
        },
        "offers": {
          "@type": "Offer",
          "name": "Visite gourmande",
          "price": "25",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "validFrom": "2026-01-01",
          "url": "https://www.perinade.fr/visites#booking"

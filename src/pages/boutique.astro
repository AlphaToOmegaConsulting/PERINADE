            "url": "https://www.perinade.fr/boutique"
          }
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "Product",
          "name": "Rosé d'Été — IGP Pays d'Oc 2024",
          "description": "Rosé IGP Pays d'Oc 2024. Pêche blanche, fraise. Bouche vive et gourmande, idéal pour l'apéritif.",

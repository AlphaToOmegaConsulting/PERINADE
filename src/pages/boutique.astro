  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quels sont les délais de livraison ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Les commandes sont expédiées sous 24 h et livrées sous 48-72 h en France métropolitaine. Emballage isotherme inclus en période de chaleur."
        }
      },
      {
        "@type": "Question",
        "name": "La livraison est-elle gratuite ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La livraison est offerte dès 80 € d'achat, sinon les frais sont calculés selon votre zone de livraison."
        }
      },
      {
        "@type": "Question",
        "name": "Puis-je retourner ma commande ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, vous disposez de 14 jours après réception. Les bouteilles doivent rester intactes et non ouvertes."
        }
      },
      {
        "@type": "Question",
        "name": "Comment conserver les vins après réception ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Conservez les bouteilles couchées dans un endroit frais, sec et à l'abri de la lumière directe."
        }
      },
      {
        "@type": "Question",
        "name": "Livrez-vous à l'étranger ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, sur demande pour certaines destinations européennes. Contactez-nous avant validation de commande."
        }
      },
      {
        "@type": "Question",
        "name": "Comment contacter le domaine ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Par téléphone au +33 4 68 XX XX XX ou par e-mail via le formulaire de contact du site."
        }
      }
    ]
  }
]);
---

<BaseLayout
  title={shopPage.seo.title}
  description={shopPage.seo.description}
  locale={locale}
  canonicalPath="/boutique"
  alternates={alternates}
  jsonLd={jsonLd}
>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={{ fr: "/boutique", en: "/en/shop", es: "/es/tienda" }} />
  <main id="main-content" class="shop-page">
    <ShopHero hero={shopPage.hero} />
    <ShopProductGrid productGrid={shopPage.productGrid} />
    <ShopDomainSelection domainSelection={shopPage.domainSelection} />
    <ShopCaseComposer caseComposer={shopPage.caseComposer} />
    <ShopFinalCtaBand finalCta={shopPage.finalCta} />
    <ShopFaq faq={shopPage.faq} />
  </main>
  <Footer footer={site.footer} />
</BaseLayout>

<style>
  .shop-page {
    background: #fff;
    --shop-shell-max: 76rem;
    --shop-shell-narrow-max: 64rem;
  }

  .shop-page :global(.shop-shell) {
    margin-inline: auto;
    max-width: var(--shop-shell-max);
  }

  .shop-page :global(.shop-shell--narrow) {
    margin-inline: auto;
    max-width: var(--shop-shell-narrow-max);
  }

  .shop-page :global(.section) {
    padding-block: clamp(3.5rem, 6vw, 6rem);
  }

  @media (max-width: 63.9375em) {
    .shop-page :global(.section) {
      padding-block: clamp(3rem, 5vw, 4.8rem);
    }
  }

  @media (max-width: 47.9375em) {
    .shop-page {
      --shop-shell-max: 100%;
      --shop-shell-narrow-max: 100%;
    }

    .shop-page :global(.section) {
      padding-block: 2.8rem;
    }
  }
</style>

        "item": {
          "@type": "Product",
          "name": "Grande Réserve — AOP Minervois Rouge 2020",
          "description": "Rouge AOP Minervois 2020. Élevé en fûts de chêne. Puissant, complexe, tanins fondus.",
          "brand": { "@type": "Brand", "name": "Domaine de la Périnade" },

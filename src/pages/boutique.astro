---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";
import ShopHero from "../components/shop/ShopHero.astro";
import ShopComplianceBand from "../components/shop/ShopComplianceBand.astro";
import ShopProductGrid from "../components/shop/ShopProductGrid.astro";
import ShopDomainSelection from "../components/shop/ShopDomainSelection.astro";
import ShopCaseComposer from "../components/shop/ShopCaseComposer.astro";
import ShopFinalCtaBand from "../components/shop/ShopFinalCtaBand.astro";
import ShopFaq from "../components/shop/ShopFaq.astro";
import CartPopup from "../components/shop/CartPopup.astro";
import { getShopData, getSiteData, getVins, getCoffrets } from "../data/index";
import { getAlternates, getAlternateUrls, getPagePath } from "../i18n/routes";
import { getUiStrings } from "../i18n/ui";
import { parsePriceToDecimal } from "../utils/price";

const locale = "fr";
const pageId = "boutique";
const [site, shopPage, vins, coffretsCollection, ui] = await Promise.all([
  getSiteData(locale),
  getShopData(locale),
  getVins(locale),
  getCoffrets(locale),
  getUiStrings(locale),
]);
const vinProducts = vins.map((vin) => ({
  id: vin.id.replace(/\.(fr|en|es)$/, ""),
  name: vin.data.nom,
  meta: vin.data.millesime
    ? `${vin.data.millesime} · ${vin.data.volume} cl`
    : `Sans millésime · ${vin.data.volume} cl`,
  description: vin.data.description,
  price: `${vin.data.prix.toFixed(2).replace(".", ",")} € TTC`,
  image: vin.data.image,
  imageAlt: vin.data.imageAlt,
  badges: vin.data.badges,
  tone: vin.data.couleurTone,
  ctaLabel: ui.addToCartLabel,
  ctaHref: "/boutique#produits",
}));
const coffretProducts = coffretsCollection.map((c) => ({
  name: c.data.nom,
  meta: c.data.meta,
  description: c.data.description,
  price: c.data.prixLabel,
  image: c.data.image,
  imageAlt: c.data.imageAlt,
  badges: c.data.badges,
  tone: c.data.tone,
  ctaLabel: c.data.ctaLabel,
  ctaHref: c.data.ctaHref,
}));
const allProducts = [...vinProducts, ...coffretProducts];
const productGrid = { ...shopPage.productGrid, products: allProducts };

const alternates = getAlternates(pageId);
const alternateUrls = getAlternateUrls(pageId);

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Catalogue vins et coffrets — Domaine de la Périnade",
    "description": "Achetez nos cuvées et coffrets en ligne, directement depuis le domaine.",
    "url": "https://www.perinade.fr/boutique",
    "numberOfItems": allProducts.length,
    "itemListElement": allProducts.map((product, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Product",
        "name": product.name,
        "description": product.description,
        "brand": { "@type": "Brand", "name": "Domaine de la Périnade" },
        "category": product.meta,
        "offers": {
          "@type": "Offer",
          "price": parsePriceToDecimal(product.price),
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "priceValidUntil": "2026-12-31",
          "url": `https://www.perinade.fr${product.ctaHref || "/boutique"}`
        }
      }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": shopPage.faq.items.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
]);
---

<BaseLayout
  title={shopPage.seo.title}
  description={shopPage.seo.description}
  locale={locale}
  canonicalPath={getPagePath(pageId, locale)}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={alternateUrls} />
  <main id="main-content" class="shop-page">
    <ShopHero hero={shopPage.hero} />
    <ShopProductGrid productGrid={productGrid} />
    <ShopDomainSelection domainSelection={shopPage.domainSelection} />
    <ShopCaseComposer caseComposer={shopPage.caseComposer} />
    <ShopFinalCtaBand finalCta={shopPage.finalCta} />
    <ShopFaq faq={shopPage.faq} />
    <ShopComplianceBand compliance={shopPage.compliance} />
  </main>
  <CartPopup />
  <Footer footer={site.footer} />
</BaseLayout>

<style>
  .shop-page {
    background: #fff;
    --shop-shell-max: 76rem;
    --shop-shell-narrow-max: 64rem;
  }

  .shop-page :global(.shop-shell) {
    margin-inline: auto;
    max-width: var(--shop-shell-max);
  }

  .shop-page :global(.shop-shell--narrow) {
    margin-inline: auto;
    max-width: var(--shop-shell-narrow-max);
  }

  .shop-page :global(.section) {
    padding-block: clamp(3.5rem, 6vw, 6rem);
  }

  @media (max-width: 63.9375em) {
    .shop-page :global(.section) {
      padding-block: clamp(3rem, 5vw, 4.8rem);
    }
  }

  @media (max-width: 47.9375em) {
    .shop-page {
      --shop-shell-max: 100%;
      --shop-shell-narrow-max: 100%;
    }

    .shop-page :global(.section) {
      padding-block: 2.8rem;
    }
  }
</style>

      {
        "@type": "ListItem",
        "position": 5,
        "item": {
          "@type": "Product",
          "name": "Blanc Réserve — AOP Minervois 2022",
          "description": "Blanc AOP Minervois 2022. Fruits exotiques, vanille subtile. Bouche ample et élégante.",
          "brand": { "@type": "Brand", "name": "Domaine de la Périnade" },
          "category": "Vin blanc AOP Minervois",
          "offers": {
            "@type": "Offer",
            "price": "16.00",
            "priceCurrency": "EUR",

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteData } from "../data/index";
import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";

const locale = "fr";
const site = await getSiteData(locale);
---

<BaseLayout title="Page introuvable | Domaine de la Périnade" description="Cette page n'existe pas ou a été déplacée." locale={locale}>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={{ fr: "/", en: "/en", es: "/es" }} />
  <main id="main-content" class="not-found">
    <div class="shell not-found__shell">
      <p class="not-found__code" aria-hidden="true">404</p>
      <h1 class="not-found__title">Page introuvable</h1>
      <p class="not-found__body">
        Cette page n'existe pas ou a été déplacée. Revenez à l'accueil pour découvrir nos vins et nos visites.
      </p>
      <a href="/" class="not-found__cta">Retour à l'accueil</a>
    </div>
  </main>
  <Footer footer={site.footer} />
</BaseLayout>

<style>
  .not-found {
    align-items: center;
    display: flex;
    min-height: calc(100svh - var(--header-height) * 2);
    padding-block: clamp(4rem, 10vw, 8rem);
  }

  .not-found__shell {
    text-align: center;
  }

  .not-found__code {
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 10rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 0.25em;
    opacity: 0.35;
  }

  .not-found__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin: 0 0 1rem;
  }

  .not-found__body {
    color: var(--color-muted);
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.65;
    margin: 0 auto 2.5rem;
    max-width: 36rem;
  }

  .not-found__cta {
    background: var(--color-cta);
    border-radius: 0.5rem;
    color: #fff;
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    transition: background 180ms ease;
  }

  .not-found__cta:hover {
    background: var(--color-cta-strong);
  }
</style>

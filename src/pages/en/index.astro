---
import Contact from "../../components/sections/Contact.astro";
import Experience from "../../components/sections/Experience.astro";
import Footer from "../../components/sections/Footer.astro";
import Gallery from "../../components/sections/Gallery.astro";
import Header from "../../components/sections/Header.astro";
import Hero from "../../components/sections/Hero.astro";
import History from "../../components/sections/History.astro";
import Reasons from "../../components/sections/Reasons.astro";
import Testimonials from "../../components/sections/Testimonials.astro";
import Wines from "../../components/sections/Wines.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSiteData } from "../../data/index";
import { getAlternates, getAlternateUrls, getPagePath } from "../../i18n/routes";

const locale = "en";
const pageId = "home";
const site = await getSiteData(locale);
const alternates = getAlternates(pageId);
const alternateUrls = getAlternateUrls(pageId);
const seoTitle = "Domaine de la Périnade | AOP Minervois Wine near Carcassonne";
const seoDescription = "Family-run wine estate in Languedoc since 1830. AOP Minervois and IGP Pays d'Oc wines. Wine tasting, cellar tours and online shop. Near Carcassonne, Aude.";
---

<BaseLayout title={seoTitle} description={seoDescription} locale={locale} canonicalPath={getPagePath(pageId, locale)} alternates={alternates}>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={alternateUrls} />
  <main id="main-content">
    <Hero hero={site.hero} />
    <Reasons reasons={site.reasons} />
    <Experience experience={site.experience} />
    <Gallery gallery={site.gallery} />
    <Testimonials testimonials={site.testimonials} />
    <History history={site.history} />
    <Wines wines={site.wines} />
    <Contact contact={site.contact} />
  </main>
  <Footer footer={site.footer} />
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSiteData } from "../../data/index";
import Header from "../../components/sections/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import ActionLink from "../../components/ui/actions/ActionLink.astro";
import { getAlternateUrls } from "../../i18n/routes";

const locale = "en";
const site = await getSiteData(locale);
const alternateUrls = getAlternateUrls("home");
---

<BaseLayout title="Page not found | Domaine de la Périnade" description="This page does not exist or has been moved." locale={locale} noindex={true}>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={alternateUrls} />
  <main id="main-content" class="not-found">
    <div class="shell not-found__shell">
      <p class="not-found__code" aria-hidden="true">404</p>
      <h1 class="not-found__title">Page not found</h1>
      <div class="not-found__body">
        <p>This page does not exist or has been moved.</p>
      </div>
      <div class="not-found__actions">
        <ActionLink href="/" class="not-found__cta" label="FR" variant="primary" />
        <ActionLink href="/en" class="not-found__cta" label="EN" variant="primary" />
        <ActionLink href="/es" class="not-found__cta" label="ES" variant="primary" />
      </div>
    </div>
  </main>
  <Footer footer={site.footer} />
</BaseLayout>

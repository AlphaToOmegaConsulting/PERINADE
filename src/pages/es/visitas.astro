---
import FinalCta from "../../components/visits/FinalCta.astro";
import PairingAddon from "../../components/visits/PairingAddon.astro";
import PricingPlans from "../../components/visits/PricingPlans.astro";
import BookingSection from "../../components/visits/BookingSection.astro";
import ExperienceTimeline from "../../components/visits/ExperienceTimeline.astro";
import VisitHero from "../../components/visits/VisitHero.astro";
import WinesShowcase from "../../components/visits/WinesShowcase.astro";
import AccessSection from "../../components/visits/AccessSection.astro";
import TrustBar from "../../components/visits/TrustBar.astro";
import ExtendedEscape from "../../components/visits/ExtendedEscape.astro";
import Footer from "../../components/sections/Footer.astro";
import Header from "../../components/sections/Header.astro";
import { getSiteData, getVisitsData, getVisites } from "../../data/index";
import { buildVisitsThemeStyle } from "../../utils/visits-theme";
import { visitsTheme } from "../../config/visits-theme-config";
import BaseLayout from "../../layouts/BaseLayout.astro";

const locale = "es";
const [site, visitsPage, visites] = await Promise.all([
  getSiteData(locale),
  getVisitsData(locale),
  getVisites(locale),
]);
const visitsThemeStyle = buildVisitsThemeStyle(visitsTheme);
const mappedPlans = visites.map((visite) => ({
  title: visite.data.titre,
  subtitle: visite.data.sousTitre,
  price: `${visite.data.prix} €`,
  perLabel: visite.data.perLabel,
  features: visite.data.inclus,
  ctaLabel: visitsPage.booking.config.ctaLabel,
  ctaHref: visitsPage.booking.config.ctaHref,
  isHighlighted: visite.data.highlighted,
  badge: visite.data.badge,
}));
const pricing = { ...visitsPage.pricing, plans: mappedPlans };

const alternates = [
  { locale: "fr", href: "/visites" },
  { locale: "en", href: "/en/visits" },
  { locale: "es", href: "/es/visitas" }
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Visitas y Catas de Vino — Domaine de la Perinade, Minervois Languedoc",
  "url": "https://www.perinade.fr/es/visitas",
  "numberOfItems": 2,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "Event",
        "name": "Visita Estandar — Cata de Vino cerca de Carcassonne, Domaine de la Perinade",
        "description": "Visita guiada de 90 min: paseo por el vinedo de Minervois, visita a la bodega, cata comentada de 5 cuvees. Cerca de Carcassonne, Aude.",
        "url": "https://www.perinade.fr/es/visitas",
        "startDate": "2026-03-01",
        "endDate": "2026-12-31",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Domaine de la Perinade",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Domaine de la Perinade",
            "addressLocality": "Carcassonne",
            "addressRegion": "Occitanie",
            "postalCode": "11000",
            "addressCountry": "FR"
          }
        },
        "offers": {
          "@type": "Offer",
          "name": "Visita estandar",
          "price": "15",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "url": "https://www.perinade.fr/es/visitas#booking"
        },
        "organizer": {
          "@type": "Organization",
          "name": "Domaine de la Perinade",
          "url": "https://www.perinade.fr"
        },
        "inLanguage": ["fr", "en", "es"]
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Event",
        "name": "Visita Gastronomica — Cata y Maridaje con Quesos, Domaine de la Perinade",
        "description": "Visita guiada de 90 min con tabla de quesos y charcuteria artesanal del Languedoc. Maridaje gastronomo cerca de Carcassonne.",
        "url": "https://www.perinade.fr/es/visitas",
        "startDate": "2026-03-01",
        "endDate": "2026-12-31",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Domaine de la Perinade",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Domaine de la Perinade",
            "addressLocality": "Carcassonne",
            "addressRegion": "Occitanie",
            "postalCode": "11000",
            "addressCountry": "FR"
          }
        },
        "offers": {
          "@type": "Offer",
          "name": "Visita gastronomica",
          "price": "29",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "url": "https://www.perinade.fr/es/visitas#booking"
        },
        "organizer": {
          "@type": "Organization",
          "name": "Domaine de la Perinade",
          "url": "https://www.perinade.fr"
        },
        "inLanguage": ["fr", "en", "es"]
      }
    }
  ]
});
---

<BaseLayout title={visitsPage.seo.title} description={visitsPage.seo.description} locale={locale} canonicalPath="/es/visitas" alternates={alternates} disableCursorOrb jsonLd={jsonLd}>
  <Header nav={site.nav} quickActions={site.mobileQuickActions} ctaLabel={site.experience.ctaLabel} ctaHref={site.experience.ctaHref} locale={locale} alternateUrls={{ fr: "/visites", en: "/en/visits", es: "/es/visitas" }} />
  <main id="main-content" class="visits-page" style={visitsThemeStyle}>
    <VisitHero hero={visitsPage.hero} />
    <TrustBar items={visitsPage.trustBar} />
    <ExperienceTimeline timeline={visitsPage.timeline} />
    <WinesShowcase wines={visitsPage.wines} />
    <PairingAddon pairing={visitsPage.pairing} />
    <PricingPlans pricing={pricing} />
    <AccessSection access={visitsPage.access} />
    <ExtendedEscape escape={visitsPage.escape} />
    <BookingSection booking={visitsPage.booking} />
    <FinalCta finalCta={visitsPage.finalCta} />
  </main>
  <Footer footer={site.footer} />
</BaseLayout>

<style>
  .visits-page :global(.section) {
    padding-block: var(--visit-section-space-desktop);
  }

  @media (max-width: 63.9375em) {
    .visits-page :global(.section) {
      padding-block: var(--visit-section-space-tablet);
    }
  }

  @media (max-width: 47.9375em) {
    .visits-page :global(.section) {
      padding-block: var(--visit-section-space-mobile);
    }
  }
</style>

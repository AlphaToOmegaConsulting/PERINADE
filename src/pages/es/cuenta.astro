---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/sections/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import { getSiteData } from "../../data/index";
import { getAlternates, getAlternateUrls, getPagePath } from "../../i18n/routes";

const locale = "es";
const pageId = "compte";
const site = await getSiteData(locale);
const alternates = getAlternates(pageId);
const alternateUrls = getAlternateUrls(pageId);
---

<BaseLayout
  title="Mi cuenta | Domaine de la Périnade"
  description="Accede a tu historial de pedidos y tus puntos de fidelidad."
  locale={locale}
  canonicalPath={getPagePath(pageId, locale)}
  alternates={alternates}
  noindex={true}
>
  <Header
    nav={site.nav}
    quickActions={site.mobileQuickActions}
    ctaLabel={site.experience.ctaLabel}
    ctaHref={site.experience.ctaHref}
    locale={locale}
    alternateUrls={alternateUrls}
  />

  <main id="main-content" class="account-page">
    <section class="section">
      <div class="shell account-shell">
        <!-- Loading state (visible until JS runs) -->
        <div id="account-loading" class="account-loading">
          <p>Cargando…</p>
        </div>
        <!-- Login form (hidden initially) -->
        <div id="account-login" class="account-card" hidden>
          <h1>Mi cuenta</h1>
          <p>Introduce tu dirección de correo electrónico para recibir un enlace de acceso.</p>
          <form id="login-form" class="account-form">
            <label for="login-email">Correo electrónico</label>
            <input
              type="email"
              id="login-email"
              name="email"
              required
              autocomplete="email"
              placeholder="tu@ejemplo.com"
            />
            <button type="submit" id="login-submit">Recibir enlace de acceso</button>
          </form>
          <p id="login-message" class="account-message" hidden></p>
        </div>
        <!-- Dashboard (hidden initially) -->
        <div id="account-dashboard" class="account-dashboard" hidden>
          <header class="account-hero">
            <p class="account-hero__badge">Mi cuenta</p>
            <h1 id="account-greeting">Hola</h1>
            <p id="account-email" class="account-hero__email"></p>
          </header>
          <div class="account-stats">
            <div class="account-stat-card">
              <span class="account-stat-card__label">Pedidos</span>
              <strong id="account-order-count" class="account-stat-card__value">—</strong>
            </div>
            <div class="account-stat-card">
              <span class="account-stat-card__label">Total gastado</span>
              <strong id="account-total-spent" class="account-stat-card__value">—</strong>
            </div>
            <div class="account-stat-card">
              <span class="account-stat-card__label">Puntos de fidelidad</span>
              <strong id="account-loyalty-points" class="account-stat-card__value">—</strong>
            </div>
          </div>
          <nav class="account-nav">
            <a href="/es/cuenta/pedidos" class="account-nav__link">Mis pedidos</a>
            <a href="/es/cuenta/fidelidad" class="account-nav__link">Puntos de fidelidad</a>
          </nav>
          <button id="account-logout" class="account-logout">Cerrar sesión</button>
        </div>
      </div>
    </section>
  </main>

  <Footer footer={site.footer} />
</BaseLayout>

<script>
  import { getSession, sendMagicLink, signOut, fetchUserProfile } from "../../scripts/account";

  const loading = document.getElementById("account-loading")!;
  const loginDiv = document.getElementById("account-login")!;
  const dashboard = document.getElementById("account-dashboard")!;

  async function init() {
    const session = await getSession();
    loading.hidden = true;
    if (!session) {
      loginDiv.hidden = false;
      setupLoginForm();
    } else {
      dashboard.hidden = false;
      setupDashboard(session.access_token, session.user.email ?? "");
    }
  }

  function setupLoginForm() {
    const form = document.getElementById("login-form") as HTMLFormElement;
    const msg = document.getElementById("login-message") as HTMLElement;
    const submit = document.getElementById("login-submit") as HTMLButtonElement;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = (document.getElementById("login-email") as HTMLInputElement).value;
      submit.disabled = true;
      submit.textContent = "Enviando…";
      const { error } = await sendMagicLink(email);
      msg.hidden = false;
      if (error) {
        msg.textContent = "Error: " + error;
        msg.className = "account-message account-message--error";
      } else {
        msg.textContent = "¡Enlace enviado! Revisa tu bandeja de entrada.";
        msg.className = "account-message account-message--success";
        form.hidden = true;
      }
      submit.disabled = false;
      submit.textContent = "Recibir enlace de acceso";
    });
  }

  async function setupDashboard(token: string, email: string) {
    const greetingEl = document.getElementById("account-greeting")!;
    const emailEl = document.getElementById("account-email")!;
    const orderCountEl = document.getElementById("account-order-count")!;
    const totalSpentEl = document.getElementById("account-total-spent")!;
    const loyaltyEl = document.getElementById("account-loyalty-points")!;

    emailEl.textContent = email;
    greetingEl.textContent = "Hola";

    const profile = await fetchUserProfile(token);
    if (profile) {
      orderCountEl.textContent = String(profile.orderCount);
      totalSpentEl.textContent = `${(profile.totalSpentCents / 100).toFixed(2)} €`;
      loyaltyEl.textContent = "0 pts"; // Phase 2
    }

    document.getElementById("account-logout")!.addEventListener("click", async () => {
      await signOut();
      window.location.reload();
    });
  }

  init().catch(console.error);
</script>

<style>
  .account-page {
    background: radial-gradient(circle at 10% 5%, rgba(214, 116, 0, 0.08), transparent 28%), #f8f7f5;
    min-height: calc(100svh - var(--header-height) * 2);
  }

  .account-shell {
    margin-inline: auto;
    max-width: 52rem;
  }

  .account-card {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 1rem;
    box-shadow: 0 10px 26px rgba(16, 24, 40, 0.06);
    padding: 1.4rem;
  }

  .account-hero {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 1rem;
    box-shadow: 0 10px 26px rgba(16, 24, 40, 0.06);
    padding: 1.4rem;
    margin-bottom: 1rem;
  }

  .account-hero__badge {
    background: rgba(200, 109, 0, 0.12);
    border-radius: 99px;
    color: #8a4900;
    display: inline-flex;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0 0 0.7rem;
    padding: 0.28rem 0.64rem;
    text-transform: uppercase;
  }

  .account-hero h1 {
    color: #202227;
    font-size: clamp(2rem, 4vw, 2.8rem);
    letter-spacing: -0.02em;
    margin: 0 0 0.4rem;
  }

  .account-hero__email {
    color: #4f5257;
    margin: 0;
  }

  .account-stats {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    margin-bottom: 1rem;
  }

  .account-stat-card {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.1rem;
  }

  .account-stat-card__label {
    color: #5b616a;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .account-stat-card__value {
    color: #202227;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .account-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .account-nav__link {
    align-items: center;
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.16);
    border-radius: 0.72rem;
    color: #2f3338;
    display: inline-flex;
    flex: 1;
    font-size: 0.86rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.08em;
    min-height: 2.85rem;
    min-width: 12rem;
    padding: 0.5rem 1rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: filter 120ms ease;
  }

  .account-nav__link:hover,
  .account-nav__link:focus-visible {
    filter: brightness(0.97);
  }

  .account-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .account-form label {
    color: #2f3338;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .account-form input[type="email"] {
    border: 1px solid rgba(44, 44, 44, 0.2);
    border-radius: 0.7rem;
    font-size: 1rem;
    outline: none;
    padding: 0.75rem 1rem;
    width: 100%;
  }

  .account-form input[type="email"]:focus {
    border-color: #c86d00;
    box-shadow: 0 0 0 3px rgba(200, 109, 0, 0.12);
  }

  .account-form button {
    align-items: center;
    background: linear-gradient(180deg, #dc7f0a 0%, #c86d00 100%);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 0.7rem;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.08em;
    min-height: 2.85rem;
    padding: 0.5rem 1.5rem;
    text-transform: uppercase;
    transition: filter 120ms ease;
  }

  .account-form button:hover:not(:disabled),
  .account-form button:focus-visible {
    filter: brightness(1.05);
  }

  .account-form button:disabled {
    filter: saturate(0.15) brightness(1.08);
    cursor: not-allowed;
  }

  .account-message {
    border-radius: 0.65rem;
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
  }

  .account-message--success {
    background: #f0faf5;
    border: 1px solid #bef5d6;
    color: #1a6b40;
  }

  .account-message--error {
    background: #fff5f5;
    border: 1px solid #fec9c9;
    color: #9b1c1c;
  }

  .account-logout {
    background: transparent;
    border: 1px solid rgba(44, 44, 44, 0.16);
    border-radius: 0.7rem;
    color: #5b616a;
    cursor: pointer;
    font-size: 0.84rem;
    font-weight: 500;
    min-height: 2.5rem;
    padding: 0.5rem 1rem;
    transition: border-color 120ms ease, color 120ms ease;
  }

  .account-logout:hover {
    border-color: rgba(44, 44, 44, 0.3);
    color: #2f3338;
  }

  .account-loading {
    color: #5b616a;
    padding: 2rem 0;
    text-align: center;
  }
</style>

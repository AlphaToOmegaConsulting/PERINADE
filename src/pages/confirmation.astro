---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";
import { getShopData, getSiteData } from "../data/index";
import { getContactInfo } from "../i18n/contact";
import { getAlternates, getAlternateUrls, getPagePath } from "../i18n/routes";

const locale = "fr";
const pageId = "confirmation";
const [site, shopPage, contact] = await Promise.all([
  getSiteData(locale),
  getShopData(locale),
  getContactInfo(),
]);
const confirmation = shopPage.confirmationPage;
const sessionId = Astro.url.searchParams.get("session_id") ?? "";

const alternates = getAlternates(pageId);
const alternateUrls = getAlternateUrls(pageId);
---

<BaseLayout
  title={confirmation.seo.title}
  description={confirmation.seo.description}
  locale={locale}
  canonicalPath={getPagePath(pageId, locale)}
  alternates={alternates}
  noindex={true}
>
  <Header
    nav={site.nav}
    quickActions={site.mobileQuickActions}
    ctaLabel={site.experience.ctaLabel}
    ctaHref={site.experience.ctaHref}
    locale={locale}
    alternateUrls={alternateUrls}
  />

  <main id="main-content" class="confirmation-page">
    <section class="section">
      <div class="shell confirmation-shell">
        <header class="confirmation-hero">
          <p class="confirmation-hero__badge">{confirmation.status.labelPaid}</p>
          <h1>{confirmation.hero.title}</h1>
          <p>{confirmation.hero.body}</p>
          {sessionId && (
            <p class="confirmation-hero__ref">
              <span>{confirmation.status.labelRefPrefix}</span>
              <code>{sessionId}</code>
            </p>
          )}
        </header>

        <section class="confirmation-card" aria-labelledby="confirmation-next-steps">
          <h2 id="confirmation-next-steps">{confirmation.nextSteps.title}</h2>
          <ul>
            {confirmation.nextSteps.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="confirmation-card" aria-labelledby="confirmation-support">
          <h2 id="confirmation-support">{confirmation.support.title}</h2>
          <p>{confirmation.support.body}</p>
          <p>
            <strong>E-mail :</strong>{" "}
            <a href={`mailto:${confirmation.support.emailLabel}`}>{confirmation.support.emailLabel}</a>
          </p>
          <p>
            <strong>Téléphone :</strong>{" "}
            <a href={contact.phoneTel}>{confirmation.support.phoneLabel}</a>
          </p>
        </section>

        <nav class="confirmation-actions" aria-label="Actions confirmation">
          <a href="/boutique" class="confirmation-actions__primary">{confirmation.actions.backShopLabel}</a>
          <a href="/" class="confirmation-actions__secondary">{confirmation.actions.backHomeLabel}</a>
        </nav>

        <p class="confirmation-legal">{confirmation.legal.moderationNotice}</p>
      </div>
    </section>
  </main>

  <Footer footer={site.footer} />
</BaseLayout>

<style>
  .confirmation-page {
    background: radial-gradient(circle at 10% 5%, rgba(214, 116, 0, 0.08), transparent 28%), #f8f7f5;
    min-height: calc(100svh - var(--header-height) * 2);
  }

  .confirmation-shell {
    margin-inline: auto;
    max-width: 52rem;
  }

  .confirmation-hero,
  .confirmation-card {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 1rem;
    box-shadow: 0 10px 26px rgba(16, 24, 40, 0.06);
  }

  .confirmation-hero {
    margin: 0;
    padding: 1.4rem;
  }

  .confirmation-hero__badge {
    background: rgba(200, 109, 0, 0.12);
    border-radius: 99px;
    color: #8a4900;
    display: inline-flex;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0;
    padding: 0.28rem 0.64rem;
    text-transform: uppercase;
  }

  .confirmation-hero h1 {
    color: #202227;
    font-size: clamp(2rem, 4vw, 2.8rem);
    letter-spacing: -0.02em;
    margin: 0.7rem 0 0.5rem;
  }

  .confirmation-hero p {
    color: #4f5257;
    margin: 0;
  }

  .confirmation-hero__ref {
    align-items: center;
    background: #f7f7f6;
    border: 1px dashed rgba(44, 44, 44, 0.25);
    border-radius: 0.65rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1rem;
    padding: 0.65rem 0.8rem;
  }

  .confirmation-hero__ref span {
    color: #5b616a;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .confirmation-hero__ref code {
    color: #202227;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.84rem;
    word-break: break-all;
  }

  .confirmation-card {
    margin-top: 1rem;
    padding: 1.2rem 1.25rem;
  }

  .confirmation-card h2 {
    color: #202227;
    font-size: 1.2rem;
    margin: 0 0 0.55rem;
  }

  .confirmation-card p,
  .confirmation-card li {
    color: #4f5257;
    line-height: 1.55;
  }

  .confirmation-card ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .confirmation-card a {
    color: #8a4900;
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }

  .confirmation-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .confirmation-actions__primary,
  .confirmation-actions__secondary {
    align-items: center;
    border-radius: 0.72rem;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.08em;
    min-height: 2.85rem;
    padding: 0.5rem 1rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: filter 120ms ease, background-color 120ms ease, border-color 120ms ease;
  }

  .confirmation-actions__primary {
    background: linear-gradient(180deg, #dc7f0a 0%, #c86d00 100%);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: #fff;
    flex: 1;
    min-width: 14rem;
  }

  .confirmation-actions__secondary {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.16);
    color: #2f3338;
    flex: 1;
    min-width: 14rem;
  }

  .confirmation-actions__primary:hover,
  .confirmation-actions__primary:focus-visible,
  .confirmation-actions__secondary:hover,
  .confirmation-actions__secondary:focus-visible {
    filter: brightness(1.05);
    outline: none;
  }

  .confirmation-legal {
    color: #5b616a;
    font-size: 0.86rem;
    margin: 1rem 0 0;
    text-align: center;
  }

  @media (max-width: 47.9375em) {
    .confirmation-hero,
    .confirmation-card {
      padding: 1rem;
    }

    .confirmation-actions {
      flex-direction: column;
    }

    .confirmation-actions__primary,
    .confirmation-actions__secondary {
      min-width: 0;
      width: 100%;
    }
  }
</style>

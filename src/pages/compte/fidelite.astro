---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/sections/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import { getSiteData } from "../../data/index";
import { getAlternates, getAlternateUrls, getPagePath } from "../../i18n/routes";

const locale = "fr";
const pageId = "compteFidelite";
const site = await getSiteData(locale);
const alternates = getAlternates(pageId);
const alternateUrls = getAlternateUrls(pageId);
---

<BaseLayout
  title="Points de fidélité | Domaine de la Périnade"
  description="Consultez vos points de fidélité et vos avantages."
  locale={locale}
  canonicalPath={getPagePath(pageId, locale)}
  alternates={alternates}
  noindex={true}
>
  <Header
    nav={site.nav}
    quickActions={site.mobileQuickActions}
    ctaLabel={site.experience.ctaLabel}
    ctaHref={site.experience.ctaHref}
    locale={locale}
    alternateUrls={alternateUrls}
  />

  <main id="main-content" class="account-page">
    <section class="section">
      <div class="shell account-shell">
        <div id="loyalty-loading" class="account-loading">
          <p>Chargement…</p>
        </div>
        <div id="loyalty-content" hidden>
          <header class="account-hero">
            <p class="account-hero__badge">Mon espace</p>
            <h1>Points de fidélité</h1>
          </header>
          <div class="account-stats">
            <div class="account-stat-card">
              <span class="account-stat-card__label">Points disponibles</span>
              <strong class="account-stat-card__value">0 pts</strong>
            </div>
          </div>
          <div class="account-card">
            <p>Le programme de fidélité sera disponible prochainement. Vos achats sont déjà enregistrés !</p>
          </div>
          <nav class="account-nav" style="margin-top:1rem">
            <a href="/compte" class="account-nav__link">Retour à mon espace</a>
          </nav>
        </div>
      </div>
    </section>
  </main>

  <Footer footer={site.footer} />
</BaseLayout>

<script>
  import { getSession } from "../../scripts/account";

  const loading = document.getElementById("loyalty-loading")!;
  const content = document.getElementById("loyalty-content")!;

  async function init() {
    const session = await getSession();
    loading.hidden = true;
    if (!session) {
      window.location.assign("/compte");
      return;
    }
    content.hidden = false;
  }

  init().catch(console.error);
</script>

<style>
  .account-page {
    background: radial-gradient(circle at 10% 5%, rgba(214, 116, 0, 0.08), transparent 28%), #f8f7f5;
    min-height: calc(100svh - var(--header-height) * 2);
  }

  .account-shell {
    margin-inline: auto;
    max-width: 52rem;
  }

  .account-hero {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 1rem;
    box-shadow: 0 10px 26px rgba(16, 24, 40, 0.06);
    padding: 1.4rem;
    margin-bottom: 1rem;
  }

  .account-hero__badge {
    background: rgba(200, 109, 0, 0.12);
    border-radius: 99px;
    color: #8a4900;
    display: inline-flex;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0 0 0.7rem;
    padding: 0.28rem 0.64rem;
    text-transform: uppercase;
  }

  .account-hero h1 {
    color: #202227;
    font-size: clamp(2rem, 4vw, 2.8rem);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .account-stats {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    margin-bottom: 1rem;
  }

  .account-stat-card {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.1rem;
  }

  .account-stat-card__label {
    color: #5b616a;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .account-stat-card__value {
    color: #202227;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .account-card {
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.1);
    border-radius: 1rem;
    box-shadow: 0 10px 26px rgba(16, 24, 40, 0.06);
    padding: 1.4rem;
    color: #4f5257;
  }

  .account-loading {
    color: #5b616a;
    padding: 2rem 0;
    text-align: center;
  }

  .account-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .account-nav__link {
    align-items: center;
    background: #fff;
    border: 1px solid rgba(44, 44, 44, 0.16);
    border-radius: 0.72rem;
    color: #2f3338;
    display: inline-flex;
    flex: 1;
    font-size: 0.86rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.08em;
    min-height: 2.85rem;
    min-width: 12rem;
    padding: 0.5rem 1rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: filter 120ms ease;
  }

  .account-nav__link:hover,
  .account-nav__link:focus-visible {
    filter: brightness(0.97);
  }
</style>

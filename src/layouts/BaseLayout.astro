---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import type { Locale } from "../i18n/locales";
import { defaultLocale, locales } from "../i18n/locales";
import { getUiStrings } from "../i18n/ui";

interface Alternate {
  locale: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  canonicalPath?: string;
  alternates?: Alternate[];
  ogImage?: string;
  disableCursorOrb?: boolean;
  /** URL of the LCP hero image — enables early preload hint */
  heroImageUrl?: string;
  /** Serialised JSON-LD object (use JSON.stringify) */
  jsonLd?: string;
  /** Empêche l'indexation de la page (confirmation, 404, etc.) */
  noindex?: boolean;
}

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://www.perinade.fr";
const {
  title = "Domaine de la Périnade",
  description = "Domaine familial près de Carcassonne. Vins AOP Minervois et IGP Pays d'Oc depuis 1830.",
  locale = defaultLocale,
  canonicalPath,
  alternates = [],
  ogImage = "/assets/perinade/hero-vineyard.png",
  disableCursorOrb = false,
  heroImageUrl,
  jsonLd,
  noindex = false
} = Astro.props;

const lang = locale;
const ui = await getUiStrings(locale);
const canonical = canonicalPath ? `${siteUrl}${canonicalPath}` : undefined;

const hreflangLinks = alternates.map((a) => ({
  hreflang: a.locale,
  href: `${siteUrl}${a.href}`
}));

const xDefault = alternates.find((a) => a.locale === "fr");
const safeJsonLd = jsonLd?.replace(/<\/script>/gi, "<\\/script>");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {canonical && <link rel="canonical" href={canonical} />}
    {hreflangLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}
    {xDefault && <link rel="alternate" hreflang="x-default" href={`${siteUrl}${xDefault.href}`} />}

    <!-- LCP hero image preload -->
    {heroImageUrl && (
      <link rel="preload" as="image" href={heroImageUrl} fetchpriority="high" />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang} />
    {locales.filter((l) => l !== locale).map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="Domaine de la Périnade" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <link rel="icon" type="image/png" href="/assets/perinade/logo.png" />
    <link rel="apple-touch-icon" href="/assets/perinade/logo.png" />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Structured data -->
    {safeJsonLd && <script is:inline type="application/ld+json" set:html={safeJsonLd} />}

    <ClientRouter />
  </head>
  <body data-disable-cursor-orb={disableCursorOrb ? "true" : undefined}>
    <a href="#main-content" class="skip-link">{ui.skipToContent}</a>
    <slot />
    <script>
      import "../scripts/ui/init";
    </script>
  </body>
</html>

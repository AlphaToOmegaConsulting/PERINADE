---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Domaine de la Périnade",
  description = "Domaine familial près de Carcassonne. Vins authentiques du Languedoc depuis 1987."
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/assets/perinade/logo.png" />
    <link rel="apple-touch-icon" href="/assets/perinade/logo.png" />
  </head>
  <body>
    <slot />
    <script>
      import "../scripts/ui/init";
    </script>
  </body>
</html>

# .env.example — Variables d'environnement pour le développement local
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# Ne jamais committer .env avec des valeurs réelles.

# ── Astro (dev server) ────────────────────────────────────────────────────────

# URL publique du site (optionnel en local, utilisé pour les canonical links)
SITE_URL=https://www.perinade.fr

# Exposer le dev server sur le LAN (optionnel, false par défaut)
# Utiliser : ASTRO_HOST=true npm run dev
ASTRO_HOST=false

# ── Cloudflare Workers — contact-form ─────────────────────────────────────────

# Clé API Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# Adresse email de destination des messages de contact
CONTACT_EMAIL_TO=contact@perinade.fr

# Origines autorisées pour CORS (séparées par virgule)
# Exemple : https://www.perinade.fr,https://perinade.fr
ALLOWED_ORIGINS=https://www.perinade.fr

# ── Cloudflare Workers — stripe-webhook ───────────────────────────────────────

# Clé secrète Stripe (Dashboard → Developers → API keys)
# Utiliser sk_test_... en développement, sk_live_... en production
STRIPE_SECRET_KEY=sk_test_...

# Secret du webhook Stripe (Dashboard → Developers → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Bindings Cloudflare (gérés via wrangler.toml, pas des variables .env) ────
# DB       — D1 database binding (perinade-dev-db)
# CACHE    — KV namespace binding (perinade-dev-kv)
# Ces bindings sont configurés dans infra/workers/*/wrangler.toml
# et injectés automatiquement par Cloudflare lors du déploiement.

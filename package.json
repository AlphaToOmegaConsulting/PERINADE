{
  "name": "perinade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "verify": "npm run check && npm run build",
    "i18n:audit": "node --experimental-strip-types scripts/i18n/audit-language.ts",
    "i18n:extract": "node --experimental-strip-types scripts/i18n/extract-translatables.ts",
    "i18n:crawl-text": "node --experimental-strip-types scripts/i18n/crawl-site-text.ts",
    "i18n:spell-fixes": ".venv/bin/python scripts/i18n/generate-spell-fixes.py",
    "i18n:verify": "npm run check && npm run build && npm run i18n:audit",
    "lint": "eslint src --ext .ts,.astro",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/node": "^24.3.1",
    "astro": "^5.18.0",
    "astro-eslint-parser": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "stripe": "^20.4.0"
  },
  "overrides": {
    "yaml-language-server": "1.20.0"
  }
}
